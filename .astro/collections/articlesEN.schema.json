{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "h1Title": {
      "type": "string"
    },
    "seoSlug": {
      "type": "string"
    },
    "metaTitle": {
      "type": "string"
    },
    "metaDescription": {
      "type": "string"
    },
    "ogImage": {
      "type": "string"
    },
    "jsonType": {
      "type": "string"
    },
    "publishDate": {
      "type": "string",
      "format": "date-time"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "featuredPhoto": {
      "type": "object",
      "properties": {
        "image": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        }
      }
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "excerpt": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}