{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "lang": {
      "type": "string",
      "enum": [
        "it",
        "fr",
        "en"
      ]
    },
    "seoSlug": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "metaTitle": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "metaDescription": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "ogImage": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "jsonType": {
      "default": "page",
      "type": "string",
      "enum": [
        "page",
        "blog",
        "event",
        "faq",
        "blogCollection",
        "hotelRoom"
      ]
    },
    "blocks": {
      "type": "array",
      "items": {}
    },
    "featuredPhoto": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "image": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "alt": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "lang"
  ]
}