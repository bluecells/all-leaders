{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "redirects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "status": {
            "default": "301",
            "type": "string",
            "enum": [
              "301",
              "302"
            ]
          },
          "note": {
            "type": "string"
          }
        },
        "required": [
          "from",
          "to"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "redirects"
  ]
}