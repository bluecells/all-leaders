{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "lang": {
      "type": "string",
      "enum": [
        "it",
        "fr",
        "en"
      ]
    },
    "seoSlug": {
      "type": "string"
    },
    "metaTitle": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "metaDescription": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "ogImage": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "jsonType": {
      "default": "hotelRoom",
      "type": "string",
      "enum": [
        "page",
        "blog",
        "event",
        "faq",
        "blogCollection",
        "hotelRoom"
      ]
    },
    "nameDisplay": {
      "type": "string"
    },
    "punchline": {
      "type": "string"
    },
    "featuredPhoto": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "image": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "alt": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "photos": {
      "default": [],
      "maxItems": 6,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "image": {
            "anyOf": [
              {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "image": {
                        "type": "string"
                      },
                      "alt": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      }
                    },
                    "required": [
                      "image"
                    ]
                  }
                ]
              },
              {
                "type": "null"
              }
            ]
          },
          "alt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "lang",
    "nameDisplay",
    "punchline"
  ]
}