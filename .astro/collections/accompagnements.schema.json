{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "action",
        "investigation",
        "immersion",
        "inspiration"
      ]
    },
    "description": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "lang": {
      "type": "string",
      "enum": [
        "fr",
        "en"
      ]
    },
    "metaTitle": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "metaDescription": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "ogImage": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "jsonType": {
      "default": "service",
      "type": "string",
      "enum": [
        "page",
        "service"
      ]
    },
    "USP1": {
      "type": "string"
    },
    "USP2": {
      "type": "string"
    },
    "USP3": {
      "type": "string"
    },
    "USP4": {
      "type": "string"
    },
    "USP5": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "slug",
    "category",
    "type",
    "description",
    "image",
    "lang"
  ]
}