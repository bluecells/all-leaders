{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "h1Title": {
      "type": "string"
    },
    "lang": {
      "type": "string",
      "enum": [
        "it",
        "fr",
        "en"
      ]
    },
    "seoSlug": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "metaTitle": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "metaDescription": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "ogImage": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "jsonType": {
      "default": "blog",
      "type": "string",
      "enum": [
        "page",
        "blog",
        "event",
        "faq",
        "blogCollection",
        "hotelRoom"
      ]
    },
    "publishDate": {
      "type": "string",
      "format": "date-time"
    },
    "featuredPhoto": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "image": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "alt": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "excerpt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "category": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "tags": {
      "default": [],
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "lang",
    "publishDate"
  ]
}