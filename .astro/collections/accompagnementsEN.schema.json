{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "type": {
      "default": "action",
      "type": "string",
      "enum": [
        "action",
        "investigation",
        "inspiration",
        "immersion"
      ]
    },
    "description": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "metaTitle": {
      "type": "string"
    },
    "metaDescription": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "slug",
    "category",
    "description",
    "image"
  ]
}