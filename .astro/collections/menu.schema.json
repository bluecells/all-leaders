{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "type": {
            "default": "link",
            "type": "string",
            "enum": [
              "link",
              "cta"
            ]
          },
          "hasSubmenu": {
            "default": false,
            "type": "boolean"
          },
          "submenu": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                }
              },
              "required": [
                "label",
                "url"
              ]
            }
          }
        },
        "required": [
          "label",
          "url"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "links"
  ]
}