// src/components/GoogleTagManager.astro
---

<!-- Google Tag Manager - Deferred Loading for Performance -->
<script is:inline>
  window.dataLayer = window.dataLayer || [];

  let gtmLoaded = false;

  function loadGTM() {
    if (gtmLoaded) return;
    gtmLoaded = true;

    (function (w, d, s, l, i) {
      w[l] = w[l] || [];
      w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });

      var f = d.getElementsByTagName(s)[0],
        j = d.createElement(s),
        dl = l != 'dataLayer' ? '&l=' + l : '';

      j.async = true;
      j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
      f.parentNode.insertBefore(j, f);
    })(window, document, 'script', 'dataLayer', 'GTM-PBZ8GS6L');
  }

  function hasConsent() {
    try {
      const raw = localStorage.getItem('all-leaders-cookie-preferences');
      if (!raw) return false;
      const prefs = JSON.parse(raw);
      return prefs.analytics === true || prefs.marketing === true;
    } catch {
      return false;
    }
  }

  function tryLoadGTM() {
    if (hasConsent()) {
      loadGTM();
    }
  }

  // 1. load si consent déjà donné
  tryLoadGTM();

  // 2. écouter les changements de consentement
  window.addEventListener('cookie-consent-changed', (e) => {
    const prefs = e.detail;

    if (prefs.analytics || prefs.marketing) {
      loadGTM();
    }
  });
</script>
<!-- End Google Tag Manager -->
