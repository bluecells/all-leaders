---
// src/components/GoogleTagManager.astro
---

<!-- Google Tag Manager - Deferred Loading for Performance -->
<script is:inline>
  window.dataLayer = window.dataLayer || [];

  let gtmLoaded = false;

  function loadGTM() {
    if (gtmLoaded) return;
    gtmLoaded = true;

    (function (w, d, s, l, i) {
      w[l] = w[l] || [];
      w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });

      var f = d.getElementsByTagName(s)[0],
        j = d.createElement(s),
        dl = l != 'dataLayer' ? '&l=' + l : '';

      j.async = true;
      j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
      f.parentNode.insertBefore(j, f);
    })(window, document, 'script', 'dataLayer', 'GTM-PBZ8GS6L');
  }

  function hasConsent() {
    try {
      const raw = localStorage.getItem('all-leaders-cookie-preferences');
      if (!raw) return false;
      const prefs = JSON.parse(raw);
      return prefs.analytics === true || prefs.marketing === true;
    } catch {
      return false;
    }
  }

  function tryLoadGTM() {
    if (hasConsent()) {
      loadGTM();
      // Mettre à jour le consentement Google avec les préférences sauvegardées
      const prefs = getStoredPreferences();
      if (prefs && typeof window.gtag === 'function') {
        window.gtag('consent', 'update', {
          analytics_storage: prefs.analytics ? 'granted' : 'denied',
          ad_storage: prefs.marketing ? 'granted' : 'denied',
          ad_user_data: prefs.marketing ? 'granted' : 'denied',
          ad_personalization: prefs.marketing ? 'granted' : 'denied',
        });
      }
    }
  }

  function getStoredPreferences() {
    try {
      const raw = localStorage.getItem('all-leaders-cookie-preferences');
      if (!raw) return null;
      return JSON.parse(raw);
    } catch {
      return null;
    }
  }

  // 1. load si consent déjà donné
  tryLoadGTM();

  // 2. écouter les changements de consentement
  window.addEventListener('cookie-consent-changed', (e) => {
    const prefs = e.detail;

    if (prefs.analytics || prefs.marketing) {
      loadGTM();
      // Mettre à jour le consentement Google après chargement de GTM
      if (typeof window.gtag === 'function') {
        window.gtag('consent', 'update', {
          analytics_storage: prefs.analytics ? 'granted' : 'denied',
          ad_storage: prefs.marketing ? 'granted' : 'denied',
          ad_user_data: prefs.marketing ? 'granted' : 'denied',
          ad_personalization: prefs.marketing ? 'granted' : 'denied',
        });
      }
    } else {
      // Si tous les consentements sont refusés, mettre à jour Google aussi
      if (typeof window.gtag === 'function') {
        window.gtag('consent', 'update', {
          analytics_storage: 'denied',
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
        });
      }
    }
  });
</script>
<!-- End Google Tag Manager -->
