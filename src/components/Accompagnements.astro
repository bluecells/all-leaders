---
import { getCollection } from 'astro:content';

interface Props {
  lang: 'fr' | 'en';
  category?: string;
  fullBleed?: boolean;
}

const { lang, category, fullBleed = false } = Astro.props;

let accompagnements = await getCollection('accompagnements');
const allCategories = await getCollection('accompagnements-categories');

// Filtrer par langue
accompagnements = accompagnements.filter((item) => item.data.lang === lang);

// Filtrer par catégorie si spécifiée
if (category) {
  accompagnements = accompagnements.filter((item) => item.data.categorie === category);
}

// Récupérer les catégories uniques pour affichage
const categories = Array.from(new Set(accompagnements.map((item) => item.data.categorie)));

// Fonction pour obtenir la description d'une catégorie
function getCategoryDescription(categoryName: string): string {
  const categoryData = allCategories.find(
    (cat) => (lang === 'fr' ? cat.data.name_fr : cat.data.name_en) === categoryName
  );
  return lang === 'fr' ? categoryData?.data.description_fr || '' : categoryData?.data.description_en || '';
}
---

<div class={fullBleed ? '' : 'mx-auto max-w-6xl px-4'}>
  {categories.length > 0 ? (
    categories.map((cat) => (
      <section class="mb-16">
        <h2 class="font-serif text-limolo-green mb-4">{cat}</h2>
        <p class="category-description text-center! mx-auto mb-12">{getCategoryDescription(cat)}</p>
        <div class="accompagnements-grid">
          {accompagnements
            .filter((item) => item.data.categorie === cat)
            .map((item) => (
              <article class="accompagnement-card">
                <div class="card-image">
                  <div class="card-image-wrapper">
                    <img src={item.data.image} alt={item.data.title} />
                  </div>
                  <span class={`card-type card-type-${item.data.type}`}>{item.data.type}</span>
                </div>
                <div class="card-content">
                  <h3 class="font-serif font-semibold text-limolo-green">{item.data.title}</h3>
                  <p class="text-2xl card-description text-center!">{item.data.description}</p>
                  {(item.data.USP1 || item.data.USP2 || item.data.USP3 || item.data.USP4 || item.data.USP5) && (
                    <div class="usp-section">
                      <p class="usp-text">
                        {[item.data.USP1, item.data.USP2, item.data.USP3, item.data.USP4, item.data.USP5]
                          .filter(Boolean)
                          .join(' • ')}
                      </p>
                    </div>
                  )}
                </div>
              </article>
            ))}
        </div>
      </section>
    ))
  ) : (
    <p class="text-center text-gray-500">Aucun accompagnement trouvé.</p>
  )}
</div>

<style>
  .category-description {
    font-size: 1rem;
    line-height: 1.6;
    color: #555;
    max-width: 800px;
  }

  .accompagnements-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .accompagnement-card {
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 300ms, box-shadow 300ms;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 0.8rem 1.2rem;
  }

  .accompagnement-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .card-image {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%; /* 3:2 aspect ratio */
    overflow: visible;
    background: #f0f0f0;
  }

  .card-image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .card-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-type {
    position: absolute;
    top: -0.35rem;
    left: -2rem;
    color: white;
    padding: 0.25rem 1rem;
    border-radius: 0;
    font-size: 0.5rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    z-index: 10;
  }

  /* Couleurs dynamiques par type */
  .card-type-investigation {
    background: #8AC20A;
  }

  .card-type-inspiration {
    background: #DDB800;
  }

  .card-type-action {
    background: #08AAC2;
  }

  .card-type-immersion {
    background: #B577F0;
  }

  .card-content {
    padding: 0.8rem 0;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-content h3 {
    margin: 0 0 0.6rem 0;
    font-size: 1.1rem;
    line-height: 1.4;
  }

  .card-description {
    margin: 0;
    font-size: clamp(0.95rem, 1.5vw, 1rem);
    line-height: 1.6;
    color: #555;
    flex: 1;
  }

  .usp-section {
    margin-top: 0.6rem;
    padding-top: 0.6rem;
    border-top: 1px solid #e5e5e5;
  }

  .usp-text {
    margin: 0;
    padding-top: 8px;
    font-size: clamp(0.75rem, 1.2vw, 0.85rem);
    font-weight: 700;
    line-height: 1.5;
    color: #555;
    text-align: center;
    word-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .accompagnements-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
