---
/**
 * Breadcrumb.astro - Composant de fil d'Ariane intelligent avec localisation FR/EN
 *
 * Ce composant génère automatiquement un fil d'Ariane adapté au type de contenu
 * en analysant l'URL de la page actuelle et la langue fournie.
 *
 * @example
 * // Détection automatique
 * <Breadcrumb lang="fr" />
 *
 * @example
 * // Avec override du titre et catégorie
 * <Breadcrumb lang="en" category="Services" title="Individual Coaching" />
 *
 * @example
 * // Avec items manuels
 * <Breadcrumb lang="fr" items={[
 *   { label: 'Accueil', href: '/' },
 *   { label: 'Custom', href: '/custom' }
 * ]} />
 */

import { breadcrumbTranslations } from '@/data/breadcrumbTranslations';

interface Props {
  /** Langue du breadcrumb : 'fr' ou 'en' */
  lang?: 'fr' | 'en';
  /** Items manuels du fil d'Ariane. Si fournis, la détection automatique est désactivée */
  items?: Array<{ label: string; href: string }>;
  /** Nom de la catégorie. Override la catégorie extraite de l'URL */
  category?: string;
  /** Titre de la page. Override le titre extrait de l'URL */
  title?: string;
}

const { items = [], category, title, lang = 'fr' } = Astro.props;
const t = breadcrumbTranslations[lang];

// Ne pas afficher le breadcrumb sur les pages d'accueil (FR et EN)
const currentPath = Astro.url.pathname;
const isHomepage = currentPath === '/' || currentPath === '/en';

/**
 * Convertit un slug en texte avec capitalisation adaptée à la langue
 * FR: gestion-de-la-conflictualité → Gestion de la conflictualité
 * EN: psychological-safety-continuum → Psychological Safety Continuum
 */
function slugToLabel(slug: string, language: 'fr' | 'en'): string {
  // Mots qui restent en minuscules (sauf au début) selon la langue
  const smallWords = breadcrumbTranslations[language].smallWords;

  const words = slug.split('-').map((word) => word.toLowerCase());

  // Mettre en majuscule le premier mot toujours
  if (words.length > 0) {
    words[0] = words[0].charAt(0).toUpperCase() + words[0].slice(1);
  }

  // Mettre en majuscule les autres mots sauf les petits mots
  for (let i = 1; i < words.length; i++) {
    if (!smallWords.has(words[i])) {
      words[i] = words[i].charAt(0).toUpperCase() + words[i].slice(1);
    }
  }

  return words.join(' ');
}

let breadcrumbItems: Array<{ label: string; href: string }> = [];

/**
 * PRIORITÉ 1 : Utiliser les items manuels si fournis
 * Permet un contrôle total sur le fil d'Ariane
 */
if (items.length > 0) {
  breadcrumbItems = items;
} else {
  /**
   * PRIORITÉ 2 : Génération automatique basée sur l'URL
   */
  // Récupérer le chemin de l'URL actuelle (ex: /faq/categorie/article)
  const currentPath = Astro.url.pathname;

  // Découper le chemin en segments et retirer les segments vides
  // Ex: "/faq/categorie/article" → ["faq", "categorie", "article"]
  const pathSegments = currentPath.split('/').filter((segment) => segment);

  // Détecter le type de contenu en analysant les segments du path
  const isFAQ = pathSegments.includes('faq');
  const isEventi = pathSegments.includes('eventi');
  const isAccompagnements = pathSegments.includes('accompagnements');
  const isRessources = pathSegments.includes('ressources') || pathSegments.includes('resources');

  /**
   * CAS 0 : Ressources avec catégorie
   * Structure attendue : /ressources/categorie/article ou /en/resources/category/article
   * Résultat : Home / Ressources / Catégorie (avec filtre) / Titre
   */
  if (isRessources && pathSegments.length >= 3) {
    // Déterminer le segment ressources (ressources ou resources)
    const resourcesSegment = lang === 'en' ? 'resources' : 'ressources';
    const resourcesLabel = lang === 'en' ? 'Resources' : 'Ressources';

    // Extraire la catégorie depuis l'URL
    // Ex: /ressources/idees/mon-article → "idees"
    // Ex: /en/resources/ideas/my-article → "ideas"
    const categoryFromPath = pathSegments[lang === 'en' ? 2 : 1];

    // Formater la catégorie : utiliser la prop si fournie, sinon formatter depuis l'URL
    const categoryLabel = category || slugToLabel(categoryFromPath, lang);

    // Extraire le titre depuis l'URL (dernier segment)
    const titleFromPath = pathSegments[pathSegments.length - 1];

    // Formater le titre : utiliser la prop si fournie, sinon formatter depuis l'URL
    const titleLabel = title || slugToLabel(titleFromPath, lang);

    // Construire le lien vers les ressources avec le filtre de catégorie appliqué
    const resourcesBaseUrl = lang === 'en' ? '/en/resources' : '/ressources';
    const resourcesLinkWithFilter = `${resourcesBaseUrl}?category=${categoryFromPath}`;

    // Construire le fil d'Ariane à 4 niveaux avec lien filtré pour la catégorie
    breadcrumbItems = [
      { label: t.home, href: lang === 'en' ? '' : '/' },
      { label: resourcesLabel, href: resourcesBaseUrl },
      { label: categoryLabel, href: resourcesLinkWithFilter },
      { label: titleLabel, href: '' }, // Pas de href pour la page actuelle
    ];
  } else if (isFAQ && pathSegments.length >= 2) {
    // Identifier le dossier faq
    const folderName = lang === 'en' ? 'faq' : 'faq';
    const folderLabel = t.faq;

    // Extraire la catégorie depuis l'URL (2ème segment ou 3ème si /en/faq)
    // Ex: /faq/categorie/article → "categorie"
    // Ex: /en/faq/categorie/article → "categorie"
    const categoryFromPath = pathSegments[lang === 'en' ? 2 : 1];

    // Formater la catégorie : utiliser la prop si fournie, sinon formatter depuis l'URL
    // Si category prop existe (ex: "How to"), l'utiliser
    // Sinon, formatter depuis l'URL : "how-to" → "How To"
    const categoryLabel = category || slugToLabel(categoryFromPath, lang);

    // Créer le slug de la catégorie pour l'URL
    // Si category prop existe (ex: "How To"), le slugifier → "how-to"
    // Sinon, utiliser le segment de l'URL en minuscules
    const categorySlug = category
      ? category.toLowerCase().replace(/\s+/g, '-')
      : categoryFromPath.toLowerCase();

    // Extraire le titre depuis l'URL (dernier segment)
    // Ex: /faq/categorie/question-slug → "question-slug"
    const titleFromPath = pathSegments[pathSegments.length - 1];

    // Formater le titre : utiliser la prop si fournie, sinon formatter depuis l'URL
    // "how-to-lead" → "How To Lead"
    const titleLabel = title || slugToLabel(titleFromPath, lang);

    // Construire le lien FAQ
    const faqBaseUrl = lang === 'en' ? '/en/faq' : '/faq';

    // Construire le fil d'Ariane à 4 niveaux
    breadcrumbItems = [
      { label: t.home, href: lang === 'en' ? '' : '/' },
      { label: folderLabel, href: faqBaseUrl },
      { label: categoryLabel, href: `${faqBaseUrl}/${categorySlug}` },
      { label: titleLabel, href: '' }, // Pas de href pour la page actuelle
    ];
  } else if (isAccompagnements && pathSegments.length >= 2) {
    /**
     * CAS 2 : Accompagnements avec catégorie
     * Structure attendue : /accompagnements/categorie-slug/titre-slug (FR)
     *                      /accompagnements/categorie-slug/titre-slug (EN)
     * Résultat : Home / Services/Accompagnements / Catégorie (ancre) / Titre
     */
    // Extraire la catégorie depuis l'URL (2ème segment ou 3ème si /en/accompagnements)
    const categoryFromPath = pathSegments[lang === 'en' ? 2 : 1];

    // Formater la catégorie : utiliser la prop si fournie, sinon formatter depuis l'URL
    const categoryLabel = category || slugToLabel(categoryFromPath, lang);

    // Extraire le titre depuis l'URL (dernier segment)
    const titleFromPath = pathSegments[pathSegments.length - 1];

    // Formater le titre : utiliser la prop si fournie, sinon formatter depuis l'URL
    const titleLabel = title || slugToLabel(titleFromPath, lang);

    // Construire le lien accompagnements
    const accompanementsBaseUrl = lang === 'en' ? '/en/services' : '/accompagnements';
    const accompanementsLabel = t.accompagnements;

    // Construire le fil d'Ariane à 4 niveaux avec ancre pour la catégorie
    breadcrumbItems = [
      { label: t.home, href: lang === 'en' ? '' : '/' },
      { label: accompanementsLabel, href: accompanementsBaseUrl },
      { label: categoryLabel, href: `${accompanementsBaseUrl}#category-${categoryFromPath}` },
      { label: titleLabel, href: '' }, // Pas de href pour la page actuelle
    ];
  } else if (isEventi && pathSegments.length >= 2) {
    /**
     * CAS 3 : Eventi sans catégorie
     * Structure attendue : /eventi/nom-event
     * Résultat : Home / Eventi / Titre
     */
    // Extraire le titre depuis l'URL (dernier segment)
    const titleFromPath = pathSegments[pathSegments.length - 1];

    // Formater le titre : utiliser la prop si fournie, sinon formatter depuis l'URL
    const titleLabel = title || slugToLabel(titleFromPath, lang);

    // Construire le fil d'Ariane à 3 niveaux
    breadcrumbItems = [
      { label: t.home, href: lang === 'en' ? '' : '/' },
      { label: 'Eventi', href: '/eventi' },
      { label: titleLabel, href: '' },
    ];
  } else {
    /**
     * CAS 4 : Pages normales
     * Génération standard basée sur tous les segments de l'URL
     * Résultat : Home / Segment1 / Segment2 / ...
     * Le titre du frontmatter override le dernier segment s'il est fourni
     */
    breadcrumbItems = [
      { label: t.home, href: lang === 'en' ? '' : '/' },
      // Pour chaque segment, construire un élément du fil d'Ariane
      ...pathSegments.map((segment, index) => {
        const isLast = index === pathSegments.length - 1;

        // Construire le href cumulatif
        // Ex: index=0 → '/chi-siamo', index=1 → '/chi-siamo/team'
        let href = '/' + pathSegments.slice(0, index + 1).join('/');

        // Redirectionner certains segments vers des pages canoniques ou ancres
        if (segment === 'expertises' && index === 0) {
          href = '/speakers/conferenciers-expertises';
        } else if (segment === 'types-interventions' && index === 0) {
          href = '/speakers/conferenciers-types-interventions';
        } else if (segment === 'equipe-all-leaders' && index === 0) {
          href = '/#fondateurs';
        }

        // Formater le label : utiliser le title si c'est le dernier segment et qu'il est fourni
        // Sinon formatter avec slugToLabel : "chi-siamo" → "Chi Siamo"
        let label: string;
        if (isLast && title) {
          label = title;
        } else {
          label = slugToLabel(segment, lang);
        }

        // Pas de href pour le dernier élément (page actuelle)
        if (isLast) {
          href = '';
        }

        return { label, href };
      }),
    ];
  }
}
---

<!--
  Navigation Breadcrumb accessible avec aria-label
  Structure sémantique <nav> > <ol> > <li>
  N'affiche pas le breadcrumb sur la page d'accueil
-->
{!isHomepage && (
<nav aria-label={t.ariaLabel} class="breadcrumb-nav">
  <ol class="breadcrumb-list">
    {
      breadcrumbItems.map((item, index) => {
        // Vérifier si c'est le dernier élément (page actuelle)
        const isLast = index === breadcrumbItems.length - 1;

        return (
          <li class="breadcrumb-item">
            {/* Liens cliquables pour tous les éléments sauf le dernier */}
            {!isLast && item.href ? (
              <>
                <a href={item.href} class="breadcrumb-link">
                  {item.label}
                </a>
                {/* Séparateur visuel entre les éléments */}
                <span class="breadcrumb-separator" aria-hidden="true">
                  /
                </span>
              </>
            ) : (
              /* Dernier élément : texte non cliquable avec aria-current pour l'accessibilité */
              <span aria-current={isLast ? 'page' : undefined} class="breadcrumb-current">
                {item.label}
              </span>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>
)}

<style>
  /* ========================================
     MOBILE FIRST
     ======================================== */

  .breadcrumb-nav {
    margin: 0 auto;
    padding: 1.5rem 0.75rem;
    width: 100%;
  }

  .breadcrumb-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    font-size: 0.625rem;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  ol.breadcrumb-list {
    max-width: 100%;
  }

  li.breadcrumb-item {
    border-top: 0;
    padding: 0;
  }

  .breadcrumb-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.625rem;
  }

  .breadcrumb-link {
    color: var(--color-brand-primary);
    text-decoration: none;
    font-weight: 300;
    transition: color 0.2s ease;
  }

  .breadcrumb-link:hover {
    color: var(--color-brand-secondary);
  }

  .breadcrumb-separator {
    user-select: none;
    padding-right: 0;
    font-weight: 100;
  }

  /* ========================================
     DESKTOP (> 640px)
     ======================================== */
  @media (min-width: 641px) {
    .breadcrumb-nav {
      padding: 0.75rem 0 0 1rem;
    }

    .breadcrumb-list {
      font-size: 0.75rem;
      gap: 0.5rem;
    }

    .breadcrumb-item {
      font-size: 0.75rem;
    }
  }
</style>
