<script is:inline>
  window.dataLayer = window.dataLayer || [];

  function gtag() {
    dataLayer.push(arguments);
  }

  // Récupérer les préférences sauvegardées ou utiliser les défauts
  function getInitialConsent() {
    try {
      const raw = localStorage.getItem('all-leaders-cookie-preferences');
      if (raw) {
        const prefs = JSON.parse(raw);
        return {
          analytics_storage: prefs.analytics ? 'granted' : 'denied',
          ad_storage: prefs.marketing ? 'granted' : 'denied',
          ad_user_data: prefs.marketing ? 'granted' : 'denied',
          ad_personalization: prefs.marketing ? 'granted' : 'denied',
        };
      }
    } catch (e) {
      // Ignorer les erreurs de parsing
    }
    // Défaut: tout refusé (RGPD safe)
    return {
      analytics_storage: 'denied',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
    };
  }

  const initialConsent = getInitialConsent();

  // Default consent (RGPD safe par défaut, ou préférences sauvegardées)
  gtag('consent', 'default', {
    ...initialConsent,
    wait_for_update: 500,
  });

  window.gtag = gtag;
</script>
