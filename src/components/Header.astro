---
import menuFR from '@/content/menu/fr.json';
import menuEN from '@/content/menu/en.json';
import { footerTranslations } from '../data/footerTranslations';

interface Props {
  lang?: 'fr' | 'en';
}

const { lang = 'fr' } = Astro.props;

const validLang = lang === 'fr' || lang === 'en' ? lang : 'fr';
const tFooter = footerTranslations[validLang];

const localizedSlugs = {
  fr: { blog: 'ressources', faq: 'faq', privacy: 'privacy', cookie: 'cookies' },
  en: {
    blog: 'resources',
    faq: 'faq-en',
    privacy: 'privacy-policy-en',
    cookie: 'cookies-policy-en',
  },
} as const;

const slugs = localizedSlugs[validLang] ?? localizedSlugs.fr;
const langPrefix = validLang === 'fr' ? '' : `/${validLang}`;

const footerNavLinks = {
  blog: `${langPrefix}/${slugs.blog}`,
  faq: `${langPrefix}/${slugs.faq}`,
  privacy: `${langPrefix}/${slugs.privacy}`,
  cookie: `${langPrefix}/${slugs.cookie}`,
};

const menuData = lang === 'fr' ? menuFR : lang === 'en' ? menuEN : menuFR;
const liensDuMenu = menuData?.links || [];
const logoUrl = lang === 'fr' ? '/' : `/${lang}`;
---

<header class="header-main">
  <div class="header-container">
    <div class="header-content">
      <div class="logo-container">
        <a href={logoUrl} class="logo-link">
          <img class="logo-img" src="/images/logo-all-leaders-initiative.webp" alt="Logo" />
        </a>
      </div>

      <nav class="nav-desktop">
        {
          liensDuMenu.map((item) => (
            <div class="nav-item-wrapper">
              {item.hasSubmenu && item.submenu ? (
                <div class="nav-item-with-submenu">
                  <button class="nav-link nav-link-with-arrow" data-submenu-trigger>
                    {item.label}
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="2"
                      stroke="currentColor"
                      class="chevron-icon"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M19.5 8.25l-7.5 7.5-7.5-7.5"
                      />
                    </svg>
                  </button>
                  <div class="submenu-dropdown">
                    {item.submenu.map((subitem) => (
                      <a href={subitem.url} class="submenu-link">
                        {subitem.label}
                      </a>
                    ))}
                  </div>
                </div>
              ) : (
                <a href={item.url} class={item.type === 'cta' ? 'btn-nav' : 'nav-link'}>
                  {item.label}
                </a>
              )}
            </div>
          ))
        }
        <div class="lang-switcher">
          <a
            href="/"
            style="display: inline-block; padding-right:2px; transform:translateY(2px);"
            class={lang === 'fr' ? 'lang-link lang-active' : 'lang-link '}>🇫🇷</a
          >
          <span class="lang-separator">|</span>
          <a
            href="/en"
            style="display: inline-block; padding-right:2px; transform:translateY(2px);"
            class={lang === 'en' ? 'lang-link lang-active' : 'lang-link'}>🇬🇧</a
          >
        </div>
      </nav>

      <div class="mobile-menu-button">
        <button id="menu-toggle" class="menu-toggle" aria-label="Toggle menu">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="menu-icon"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu-content">
    <div class="mobile-menu-scroll">
      {/* Menu Principal */}
      {
        liensDuMenu.map((item) => (
          <div class="mobile-menu-item">
            {item.hasSubmenu && item.submenu ? (
              <div class="mobile-submenu-wrapper">
                <button class="mobile-menu-link mobile-submenu-trigger" data-mobile-submenu>
                  {item.label}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="mobile-chevron"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19.5 8.25l-7.5 7.5-7.5-7.5"
                    />
                  </svg>
                </button>
                <div class="mobile-submenu-items">
                  {item.submenu.map((subitem) => (
                    <a href={subitem.url} class="mobile-submenu-link">
                      {subitem.label}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a
                href={item.url}
                class={`mobile-menu-link ${item.type === 'cta' ? 'mobile-menu-cta' : ''}`}
              >
                {item.label}
              </a>
            )}
          </div>
        ))
      }

      {/* Menu Secondaire (Footer) - Même format mobile-menu-item */}
      <div class="mobile-footer-separator"></div>

      <div class="mobile-menu-item">
        <a href="https://bureaudureel.fr" target="_blank" rel="noopener" class="mobile-menu-link"
          >{tFooter.bureauDuReel}</a
        >
      </div>
      <div class="mobile-menu-item">
        <a href={footerNavLinks.blog} class="mobile-menu-link">{tFooter.blog}</a>
      </div>
      <div class="mobile-menu-item">
        <a href={footerNavLinks.faq} class="mobile-menu-link">{tFooter.faq}</a>
      </div>
      <div class="mobile-menu-item">
        <a href={footerNavLinks.privacy} class="mobile-menu-link">{tFooter.privacy}</a>
      </div>
      <div class="mobile-menu-item">
        <a href={footerNavLinks.cookie} class="mobile-menu-link">{tFooter.cookie}</a>
      </div>

      <div class="mobile-lang-switcher">
        <a
          href="/"
          style="display: inline-block; padding-right:2px; transform:translateY(2px);"
          class={lang === 'fr' ? 'mobile-lang-link mobile-lang-active' : 'mobile-lang-link'}>🇫🇷</a
        >
        <span class="lang-separator">|</span>
        <a
          href="/en"
          style="display: inline-block; padding-right:2px; transform:translateY(2px);"
          class={lang === 'en' ? 'mobile-lang-link mobile-lang-active' : 'mobile-lang-link'}>🇬🇧</a
        >
      </div>
    </div>
  </div>
</header>

<style>
  /* --- Base & Header --- */
  .header-main {
    width: 100%;
    backdrop-filter: blur(20px);
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(192, 192, 192, 0.1);
  }
  .header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  .header-content {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 3.5rem;
    position: relative;
  }

  .logo-img {
    width: 200px;
    height: auto;
  }

  @media (min-width: 1025px) {
    .header-content {
      justify-content: space-between;
    }

    .logo-img {
      width: 12vw;
      height: auto;
    }
  }

  /* --- Desktop Nav --- */
  .nav-desktop {
    display: none;
    gap: 2rem;
    align-items: center;
    background-color: white;
    border-bottom: 1px solid rgba(74, 103, 65, 0.1);
    border-radius: 10px;
    padding: 0.25rem 1rem;
  }
  .nav-link {
    font-size: 14px;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand-primary);
    text-decoration: none;
  }

  .nav-link.active {
    font-weight: 600;
    text-shadow: 3px 3px 4px #4a7ab073;
  }
  .nav-link:active {
    font-weight: 600;
    text-shadow: 3px 3px 4px #4a7ab073;
  }
  .nav-link:hover {
    text-shadow: 3px 3px 5px #031a3431;
  }

  .btn-nav {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--color-brand-primary);
    color: var(--color-brand-primary);
    text-decoration: none;
  }

  /* --- Mobile Toggle --- */
  .mobile-menu-button {
    position: absolute;
    right: 1rem;
    display: flex;
    align-items: center;
  }
  .menu-toggle {
    background: none;
    border: none;
    color: var(--color-brand-primary);
    cursor: pointer;
    padding: 0.5rem;
  }
  .menu-icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  /* --- Mobile Menu Content --- */
  .mobile-menu-content {
    display: none;
    position: fixed;
    top: 5rem;
    left: 0;
    width: 100%;
    height: calc(100vh - 5rem);
    background-color: white;
    z-index: 49;
    overflow-y: auto;
  }
  .mobile-menu-scroll {
    padding: 2rem 1.5rem 5rem;
  }

  /* --- Harmonisation du format --- */
  .mobile-menu-item {
    margin-bottom: 1.5rem;
  }

  .mobile-menu-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-brand-primary);
    text-decoration: none;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
    padding: 0;
    font-family: inherit;
    cursor: pointer;
  }

  .mobile-menu-cta {
    color: var(--color-brand-accent);
    font-weight: 700;
  }

  .mobile-footer-separator {
    margin: 2rem 0;
    border-top: 1px dashed rgba(74, 103, 65, 0.2);
  }

  /* --- Submenus & Lang --- */
  .mobile-submenu-items {
    display: none;
    flex-direction: column;
    padding-left: 1rem;
    margin-top: 0.5rem;
  }
  .mobile-submenu-link {
    padding: 0.5rem 0;
    font-size: 0.9rem;
    text-transform: uppercase;
    color: var(--color-brand-primary);
    text-decoration: none;
    opacity: 0.8;
  }
  .mobile-chevron {
    width: 1.2rem;
    height: 1.2rem;
    transition: transform 0.3s;
  }
  .mobile-lang-switcher {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(74, 103, 65, 0.1);
    display: flex;
    gap: 1rem;
  }
  .mobile-lang-active {
    font-weight: bold;
  }

  .lang-separator {
    color: rgba(74, 103, 65, 0.4);
  }
  @media (min-width: 1025px) {
    .nav-desktop {
      display: flex;
    }
    .mobile-menu-button {
      display: none;
    }
    .mobile-menu-content {
      display: none !important;
    }
  }
</style>

<script>
  function setActiveLink() {
    const currentPath = window.location.pathname;
    const navLinks = document.querySelectorAll('.nav-link');

    navLinks.forEach((link) => {
      const href = link.getAttribute('href');
      if (href && currentPath.startsWith(href) && href !== '/') {
        link.classList.add('active');
      } else if (href === '/' && currentPath === '/') {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });
  }

  function initMenu() {
    const btn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');

    btn?.addEventListener('click', () => {
      const isOpened = menu?.style.display === 'block';
      if (menu) {
        menu.style.display = isOpened ? 'none' : 'block';
        document.body.style.overflow = isOpened ? 'auto' : 'hidden';
      }
    });

    const mobileSubmenuTriggers = document.querySelectorAll('[data-mobile-submenu]');
    mobileSubmenuTriggers.forEach((trigger) => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        const parent = trigger.closest('.mobile-submenu-wrapper');
        const submenuItems = parent?.querySelector('.mobile-submenu-items') as HTMLElement;
        if (submenuItems) {
          const isHidden = getComputedStyle(submenuItems).display === 'none';
          submenuItems.style.display = isHidden ? 'flex' : 'none';
          const svg = trigger.querySelector('svg');
          if (svg) svg.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
        }
      });
    });
  }

  setActiveLink();
  initMenu();
  document.addEventListener('astro:after-swap', () => {
    setActiveLink();
    initMenu();
  });
</script>
