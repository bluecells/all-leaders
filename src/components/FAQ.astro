---
// FAQ.astro optimisé
import type { CollectionEntry } from "astro:content"

interface Props {
  entry: CollectionEntry<"faq">
  showReadMore?: boolean
}

const { entry, showReadMore = true } = Astro.props
const { question } = entry.data
const answer = ''
const defaultOpen = false

const displayQuestion = question
const displayAnswer = answer
---

<div class="faq-item mb-3 group">
  {/* Ajout d'une marge entre les blocs plutôt que dans le bloc */}
  <button
    class="faq-trigger w-full text-left p-3 flex items-center justify-between gap-4 bg-indigo-100/50 dark:bg-white/5 rounded-md hover:bg-indigo-100 dark:hover:bg-white/10 transition-all border border-transparent hover:border-indigo-200 dark:hover:border-indigo-500/30"
    aria-expanded={defaultOpen ? "true" : "false"}
  >
    <span
      class="font-bold text-base sm:text-lg text-indigo-950 dark:text-indigo-200 leading-tight break-words"
      set:html={displayQuestion}
    />
    <div
      class="faq-icon-container bg-white dark:bg-slate-800 p-1 rounded-md shadow-sm group-hover:text-indigo-400 transition-colors"
    >
      <svg
        class="faq-icon w-5 h-5 transition-transform duration-300"
        class:list={[defaultOpen && "rotate-180"]}
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
        ></path>
      </svg>
    </div>
  </button>

  <div
    class="faq-content transition-all duration-300 ease-in-out"
    style={defaultOpen ? "" : "max-height: 0;"}
  >
    {/* On réduit le padding-top ici (pt-2) pour rapprocher la réponse du bouton */}
    <div
      class="px-5 pt-5 pb-3 max-w-none border-x border-b border-slate-100 dark:border-white/5 rounded-b-md -mt-2"
    >
      <div
        class="text-slate-600 dark:text-slate-300 leading-relaxed text-sm sm:text-base max-w-none"
      >
        <Fragment set:html={displayAnswer} />
      </div>

      {
        showReadMore && (
          <a
            href={`/faq/${entry.id}`}
            class="inline-flex items-center gap-1 mt-2 text-sm text-indigo-800 dark:text-indigo-500 font-semibold hover:underline"
          >
            Lire l'article complet
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const faqItems = document.querySelectorAll(".faq-item")

    faqItems.forEach((item) => {
      const trigger = item.querySelector(".faq-trigger") as HTMLButtonElement

      const content = item.querySelector(".faq-content") as HTMLElement

      const icon = item.querySelector(".faq-icon") as SVGElement

      if (!trigger || !content || !icon) return

      trigger.addEventListener("click", () => {
        const isExpanded = trigger.getAttribute("aria-expanded") === "true"

        // Toggle current item

        trigger.setAttribute("aria-expanded", (!isExpanded).toString())

        icon.classList.toggle("rotate-180")

        if (isExpanded) {
          content.style.maxHeight = "0"
        } else {
          content.style.maxHeight = content.scrollHeight + "px"
        }
      })
    })
  })
</script>

<style>
  .faq-content {
    transition: max-height 0.3s ease-in-out;
    overflow: hidden;
  }

  .faq-icon {
    transition: transform 0.3s ease-in-out;
  }

  .faq-content > div > div {
    word-wrap: break-word;
    overflow-wrap: break-word;
    white-space: normal;
    width: 100%;
  }
</style>
