---
import { footerTranslations, type Language } from '../data/footerTranslations';

interface Props {
  lang?: 'fr' | 'en';
}

const { lang = 'fr' } = Astro.props as Props;
const validLang = lang === 'fr' || lang === 'en' ? lang : 'fr';
const t = footerTranslations[validLang];
const currentYear = new Date().getFullYear();

const localizedSlugs = {
  fr: {
    blog: 'ressources',
    faq: 'faq',
    privacy: 'privacy',
    cookie: 'cookies',
  },
  en: {
    blog: 'resources',
    faq: 'faq-en',
    privacy: 'privacy-policy-en',
    cookie: 'cookies-policy-en',
  },
} as const;

const slugs = localizedSlugs[lang] ?? localizedSlugs.fr;
const langPrefix = lang === 'fr' ? '' : `/${lang}`;

const navigationLinks = {
  blog: `${langPrefix}/${slugs.blog}`,
  faq: `${langPrefix}/${slugs.faq}`,
  privacy: `${langPrefix}/${slugs.privacy}`,
  cookie: `${langPrefix}/${slugs.cookie}`,
};
---

<footer class="footer-main">
  <div class="footer-container">
    <div class="footer-grid">
      <!-- Section 1: Logo & Adresse -->
      <div class="footer-section">
        <img
          src="/images/pages/logo-all-leaders-rond-fonce.svg"
          alt="Logo"
          class="footer-logo-brand"
        />
        <h3 class="footer-title">{t.company}</h3>
        <p class="footer-address">
          {t.address},<br />
          {t.city}
        </p>
      </div>

      <!-- Section 2: Explorer & Pilote -->
      <div class="footer-section">
        <div class="footer-explorer">
          <div class="pilotine"></div>
          <div class="menu-explorer">
            <ol class="footer-links">
              <li><a href="https://bureaudureel.fr" class="footer-link">{t.bureauDuReel}</a></li>
              <li><a href={navigationLinks.blog} class="footer-link">{t.blog}</a></li>
              <li><a href={navigationLinks.faq} class="footer-link">{t.faq}</a></li>
              <li><a href={navigationLinks.privacy} class="footer-link">{t.privacy}</a></li>
              <li><a href={navigationLinks.cookie} class="footer-link">{t.cookie}</a></li>
            </ol>
          </div>
        </div>
      </div>

      <!-- Section 3: Newsletter -->
      <div class="footer-section">
        <img src="/images/pages/bateau.webp" alt="Bateau" class="footer-logo-ship" />
        <h4 class="footer-heading mb-0!">{t.keepInTouch}</h4>
        <p class="leading-snug! mb-0">
          {t.newsletterText}
        </p>
        <a href="https://bureaudureel.kessel.media/" target="_blank" class="btn-limolo">
          <span class="btn-subtitle">{t.subscribe}</span><br />
          <span class="btn-title">{t.newsletterTitle}</span>
        </a>
      </div>
    </div>

    <!-- Bottom: Social & Copyright -->
    <div class="footer-bottom">
      <div class="footer-social">
        <a href="https://www.instagram.com/bureaudureel/" class="social-link">{t.instagram}</a>
        <a href="https://www.youtube.com/@bureaudureel" class="social-link">{t.youtube}</a>
        <a href="https://www.linkedin.com/company/all-leaders-initiative/" class="social-link"
          >{t.linkedin}</a
        >
        <a href="mailto:contact@all-leaders.fr" class="social-link email-link"
          >contact@all-leaders.fr</a
        >
      </div>
      <div class="footer-copyright">
        © {currentYear}
        {t.copyright}
        <a href="https://bluecells.eu" target="_blank">{t.blueCells}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ========================================
     BASE & RESET
     ======================================== */
  .footer-main,
  .footer-main * {
    box-sizing: border-box;
  }

  .footer-main {
    width: 100%;
    background-color: var(--color-bg-body);
    border-top: 10px solid var(--color-brand-primary);
    padding: 3rem 0 1.5rem 0;
    margin-top: 4rem;
    color: var(--color-text-main);
    font-family: serif;
    overflow-x: hidden;
  }

  .footer-container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ========================================
     GRID & SECTIONS (MOBILE FIRST)
     ======================================== */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .footer-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
  }

  .footer-logo-brand {
    width: 160px;
    height: auto;
  }
  .footer-logo-ship {
    width: 120px;
    height: auto;
  }

  .footer-title {
    font-family: serif;
    font-size: 1.1rem;
    color: var(--color-brand-primary);
    margin: 0;
  }

  .footer-address {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.6;
    margin: 0;
  }

  /* ========================================
     MENU EXPLORER
     ======================================== */
  .footer-explorer {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 1rem;
    width: 100%;
    max-width: 100%;
  }

  .pilotine {
    width: 50%;
    min-height: 150px;
    background-image: url('/images/pages/pilote.webp');
    background-size: conver;
    background-repeat: no-repeat;
    background-position: bottom center;
  }

  .menu-explorer {
    flex: 1;
    text-align: left;
    min-width: 0;
    padding: 2rem 0;
  }

  @media (min-width: 768px) {
    .pilotine {
      width: 32%;
      min-height: 200px;
      background-size: cover;
      background-position: center;
    }
    .menu-explorer {
      padding: 1rem 0 0 0;
    }
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    padding: 5px 0;
  }

  .footer-link {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-main);
    text-decoration: none;
    padding: 0.2rem 0;
    transition: color 300ms;
    text-align: left;
  }

  .footer-heading {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-brand-primary);
    margin-bottom: 0.5rem;
    text-align: center;
  }

  /* ========================================
     FOOTER BOTTOM (MOBILE FIRST)
     ======================================== */
  .footer-bottom {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-social {
    display: flex;
    flex-direction: column; /* Stacked sur mobile */
    gap: 0.8rem;
    text-align: center;
  }

  .social-link {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-main);
    display: block;
  }

  .email-link {
    text-transform: uppercase;
    word-break: break-all;
  }

  .footer-copyright {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.8;
    text-align: center;
  }

  /* ========================================
     BUTTONS
     ======================================== */
  .btn-subtitle {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 300;
  }

  .btn-title {
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* ========================================
     DESKTOP ADAPTATIONS (min 768px)
     ======================================== */
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1.5fr 1fr;
      text-align: left;
      align-items: stretch;
    }

    .footer-section {
      align-items: flex-start;
      justify-content: flex-end;
    }

    .footer-heading {
      text-align: left;
    }

    .footer-explorer {
      max-width: none;
      justify-content: flex-start;
    }

    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .footer-social {
      flex-direction: row; /* Côte à côte sur desktop */
      gap: 1.5rem;
    }

    .footer-copyright {
      text-align: right;
    }
  }
</style>
