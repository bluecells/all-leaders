---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  lang: 'fr' | 'en';
  category?: string;
  fullBleed?: boolean;
  textColor?: string;
}

const { lang, category, fullBleed = false } = Astro.props;

// 1. Récupération des données
const [allAccompagnements, allCategories] = await Promise.all([
  getCollection('accompagnements'),
  getCollection('accompagnements-categories')
]);

// 2. Préparation du dictionnaire de catégories pour un accès rapide (O(1))
const categoryMap = new Map();
allCategories.forEach(cat => {
  const name = lang === 'fr' ? cat.data.name_fr : cat.data.name_en;
  categoryMap.set(name, {
    order: cat.data.order ?? 999,
    description: lang === 'fr' ? cat.data.description_fr : cat.data.description_en,
    slug: cat.data.slug || name.toLowerCase().replace(/\s+/g, '-')
  });
});

// 3. Filtrage et tri des données
const filteredAccompagnements = allAccompagnements.filter(item => 
  item.data.lang === lang && (!category || item.data.categorie === category)
);

// 4. Extraction et tri des noms de catégories présentes
const sortedCategoryNames = [...new Set(filteredAccompagnements.map(item => item.data.categorie))]
  .sort((a, b) => {
    const orderA = categoryMap.get(a)?.order ?? 999;
    const orderB = categoryMap.get(b)?.order ?? 999;
    return orderB - orderA; // Garde ton tri original (décroissant)
  });

// 5. Helper pour l'URL (plus simple car on a déjà le slug de catégorie)
const getAccompagnementUrl = (item: CollectionEntry<'accompagnements'>, catSlug: string) => {
  const itemSlug = lang === 'fr' ? item.data.slug_fr : item.data.slug_en;
  return `/accompagnements/${catSlug}/${itemSlug}`;
};
---

<div class={fullBleed ? '' : 'mx-auto max-w-4xl px-4'}>
  {sortedCategoryNames.length > 0 ? (
    sortedCategoryNames.map((catName) => {
      const catData = categoryMap.get(catName);
      const itemsInCategory = filteredAccompagnements.filter(item => item.data.categorie === catName);

      return (
        <section class="category-section mb-16" id={`category-${catData?.slug}`}>
          
          <!-- COLONNE GAUCHE -->
          <div class="category-left">
            <h2 class="font-serif text-limolo-green mb-4">{catName}</h2>
            <p class="category-description">{catData?.description || ''}</p>
            <a href="#" class="back-to-top-link">
              {lang === 'fr' ? 'Revenir au début' : 'Back to top'}
              <svg class="back-to-top-arrow" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 5v14M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          <!-- COLONNE DROITE -->
          <div class="accompagnements-list">
            {itemsInCategory.map((item) => (
              <article class="accompagnement-card-horizontal">
                <a href={getAccompagnementUrl(item, catData?.slug)} class="card-link">
                  <div class="card-image-mini">
                    <img src={item.data.image} alt={item.data.title} loading="lazy" />
                  </div>

                  <div class={`card-content-mini card-type-${item.data.type}-trans`}>
                    
                    <h3 class="font-serif text-limolo-green">
                      {item.data.title}
                    </h3>
                    <span class="card-type-tag">
                      <span class={`modalite-dot modalite-dot-${item.data.type}`}></span>
                      <span class={`card-type-text card-type-text-${item.data.type}`}>
                        {item.data.type}
                      </span>
                    </span>

                  </div>
                </a>
              </article>
            ))}
          </div>
        </section>
      );
    })
  ) : (
    <p class="text-center text-gray-500">
      {lang === 'fr' ? 'Aucun accompagnement trouvé.' : 'No results found.'}
    </p>
  )}
</div>

<style>
  /* 1. VARIABLES & RESET BASIQUE */
  :root {
    --transition-smooth: all 0.25s ease;
  }

  /* 2. LAYOUT GLOBAL (Mobile First) */
  .category-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: start;
    padding-top: 4rem;
    border-top: 1px solid #eee;
    margin-bottom: 4rem; /* Équivalent mb-16 */
  }

  /* 3. COLONNE GAUCHE (Contenu & Texte) */
  .category-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    max-width: 500px;
  }

  .category-left h2 {
    width: 100%;
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.75rem;
    text-align: center !important;
  }

  .category-description {
    font-size: 1.05rem;
    line-height: 1.6;
    color: #555;
    margin-bottom: 1.5rem;
  }

  .back-to-top-link {
    display: inline-block;
    width: 100%;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-brand-primary);
    text-align: center;
    text-decoration: underline;
    text-decoration-color: var(--color-brand-muted);
    text-underline-offset: 5px;
    transition: var(--transition-smooth);
  }

  .back-to-top-link:hover {
    color: var(--color-brand-accent);
    text-decoration-color: var(--color-brand-accent);
  }

  .back-to-top-arrow {
    display: inline-block;
    width: 1rem;
    height: 1rem;
    margin-left: 0.5rem;
    vertical-align: middle;
    transition: transform 0.3s ease;
  }

  .back-to-top-link:hover .back-to-top-arrow {
    transform: translateY(-3px);
  }

  /* 4. LISTE & CARTES */
  .accompagnements-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }

  .accompagnements-list article {
    padding: 0;
  }
  .accompagnement-card-horizontal {
    background: white;
    border: 1px solid #eee;
    border-radius: 6px;
    overflow: hidden;
    transition: var(--transition-smooth);
  }

  .accompagnement-card-horizontal:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none !important;
    border: none !important;
  }

  .card-image-mini {
    position: relative;
    width: 100%;
    height: 180px;
    overflow: hidden;
  }

  .card-image-mini img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .accompagnement-card-horizontal:hover img {
    transform: scale(1.05);
  }

  /* 5. CONTENU DE CARTE & TAGS */
  .card-content-mini {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 1rem;
    position: relative;
  }

  .card-content-mini h3 {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 500;
    font-family: sans-serif;
    letter-spacing: 0.02em;
    text-align: center !important;
    width: 100%;
  }

  .card-type-tag {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .modalite-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* 6. COULEURS THÉMATIQUES */
  .card-type-text-investigation, .modalite-dot-investigation { background-color: #8ac20a; color: #8ac20a; }
  .card-type-text-inspiration, .modalite-dot-inspiration { background-color: #ddb800; color: #ddb800; }
  .card-type-text-action, .modalite-dot-action { background-color: #08aac2; color: #08aac2; }
  .card-type-text-immersion, .modalite-dot-immersion { background-color: #b577f0; color: #b577f0; }

  /* Reset background pour le texte uniquement */
  .card-type-text { background-color: transparent !important; font-weight: 500; }

  /* Gradients */
  .card-type-investigation-trans { background: radial-gradient(ellipse at top right, rgba(139, 194, 10, 0.15), #ffffff 75%); }
  .card-type-inspiration-trans { background: radial-gradient(ellipse at top right, rgba(221, 184, 0, 0.15), #ffffff 75%); }
  .card-type-action-trans { background: radial-gradient(ellipse at top right, rgba(8, 170, 194, 0.15), #ffffff 75%); }
  .card-type-immersion-trans { background: radial-gradient(ellipse at top right, rgba(181, 119, 240, 0.15), #ffffff 75%); }

  /* 7. MEDIA QUERIES (Regroupées par breakpoint) */

  /* Tablette (MD) */
  @media (min-width: 768px) {
    .category-left h2 { font-size: 2rem; text-align: left !important; }
    .back-to-top-link { text-align: left; width: auto; }
    
    .card-link {
      display: grid;
      grid-template-columns: 180px 1fr;
      height: 120px;
    }

    .card-image-mini { height: 100%; width: auto; }
    .card-content-mini { padding: 1.5rem 1.25rem; align-items: flex-start;}
    .card-content-mini h3 { font-size: 1rem; text-align: left !important; width: auto; }
    .card-type-tag { font-size: 0.75rem; justify-content: flex-start; }

    .accompagnement-card-horizontal:hover {
      box-shadow: none;
      transform: translateX(8px) scale(1.01);
    }
  }

  /* Desktop (LG) */
  @media (min-width: 1024px) {
    .category-section {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 4rem;
    }

    .category-left { width: auto; }
    
    .accompagnements-list { width: 800px; }

    .card-link {
      grid-template-columns: 250px 1fr;
      height: 130px;
    }
  }
</style>