---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  lang: 'fr' | 'en';
  category?: string;
  fullBleed?: boolean;
  textColor?: string;
}

const { lang, category, fullBleed = false } = Astro.props;

let accompagnements = await getCollection('accompagnements');
const allCategories = await getCollection('accompagnements-categories');

// Filtrer par langue
accompagnements = accompagnements.filter((item) => item.data.lang === lang);

// Filtrer par catégorie si spécifiée
if (category) {
  accompagnements = accompagnements.filter(
    (item) => item.data.categorie === category
  );
}

// Créer un map d'ordre des catégories
const categoryOrderMap = new Map<string, number>();
allCategories.forEach((cat) => {
  const catName = lang === 'fr' ? cat.data.name_fr : cat.data.name_en;
  categoryOrderMap.set(catName, cat.data.order);
});

// Récupérer les catégories uniques
const uniqueCategories = Array.from(
  new Set(accompagnements.map((item) => item.data.categorie))
);

// Trier les catégories
const categories = uniqueCategories.sort((a, b) => {
  const orderA = categoryOrderMap.get(a) ?? 999;
  const orderB = categoryOrderMap.get(b) ?? 999;
  return orderA - orderB;
});

// Description catégorie
function getCategoryDescription(categoryName: string): string {
  const categoryData = allCategories.find(
    (cat) =>
      (lang === 'fr' ? cat.data.name_fr : cat.data.name_en) === categoryName
  );

  return lang === 'fr'
    ? categoryData?.data.description_fr || ''
    : categoryData?.data.description_en || '';
}

// Slug catégorie
function getCategorySlug(categoryName: string): string {
  const categoryData = allCategories.find(
    (cat) =>
      (lang === 'fr' ? cat.data.name_fr : cat.data.name_en) === categoryName
  );

  return (
    categoryData?.data.slug ||
    categoryName.toLowerCase().replace(/\s+/g, '-')
  );
}

// URL accompagnement
function buildAccompagnementUrl(
  accompagnement: CollectionEntry<'accompagnements'>,
  categorySlug: string
): string {
  const slug =
    lang === 'fr'
      ? accompagnement.data.slug_fr
      : accompagnement.data.slug_en;

  return `/accompagnements/${categorySlug}/${slug}`;
}
---

<div class={fullBleed ? '' : 'mx-auto max-w-4xl px-4'}>
  {categories.length > 0 ? (
    categories.map((category) => {
      const categorySlug = getCategorySlug(category);

      const categoryAccompagnements = accompagnements.filter(
        (item) => item.data.categorie === category
      );

      return (
        <section class="category-section mb-16" id={`category-${categorySlug}`}>

          <!-- COLONNE GAUCHE -->
          <div class="category-left">
            <h2 class="font-serif text-limolo-green mb-4">
              {category}
            </h2>
            <p class="category-description">
              {getCategoryDescription(category)}
            </p>
          </div>

          <!-- COLONNE DROITE -->
          <div class="accompagnements-list">
            {categoryAccompagnements.map((item) => {
              const itemUrl = buildAccompagnementUrl(
                item,
                categorySlug
              );

              return (
                <article class="accompagnement-card-horizontal">
                  <a href={itemUrl} class="card-link">

                    <div class="card-image-mini">
                      <img
                        src={item.data.image}
                        alt={item.data.title}
                      />
                      <span class={`card-type-tag card-type-${item.data.type}`}>
                        {item.data.type}
                      </span>
                    </div>

                    <div class={`card-content-mini card-type-${item.data.type}-trans`}>
                      <h3 class="font-serif text-limolo-green">
                        {item.data.title}
                      </h3>
                    </div>

                  </a>
                </article>
              );
            })}
          </div>

        </section>
      );
    })
  ) : (
    <p class="text-center text-gray-500">
      Aucun accompagnement trouvé.
    </p>
  )}
</div>

<style>
/* ===== LAYOUT GLOBAL ===== */

.category-section {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  align-items: start;
}

@media (min-width: 1024px) {
  .category-section {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 4rem;
  }

  .category-left {
    width: auto;
  }

  .accompagnements-list {
    width: 800px;
  }
}

/* ===== COLONNE GAUCHE ===== */

.category-left {
  max-width: 500px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}

.category-left h2 {
  font-size: 2rem;
  text-align: left;
  margin-top: 2rem;
}

.category-section {
  border-top: 1px solid #eee;
  padding-top: 4rem;
}

.category-description {
  font-size: 1.05rem;
  line-height: 1.6;
  color: #555;
}

/* ===== COLONNE DROITE ===== */

.accompagnements-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.accompagnements-list article {
  padding: 0;
}

/* ===== CARTE HORIZONTALE ===== */

.accompagnement-card-horizontal {
  background: white;
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid #eee;
  transition: all 0.25s ease;
}

.accompagnement-card-horizontal:hover {
  transform: translateX(8px) scale(1.01);
}

.card-link {
  display: grid;
  grid-template-columns: 200px 1fr;
  height: 110px;
  text-decoration: none;
  color: inherit;
}

/* IMAGE */

.card-image-mini {
  position: relative;
  overflow: hidden;
}

.card-image-mini img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.accompagnement-card-horizontal:hover img {
  transform: scale(1.05);
}

/* CONTENU */

.card-content-mini {
  display: flex;
  align-items: center;
  padding: 0 1.25rem;
}

.card-content-mini h3 {
  margin: 0;
  font-size: 1rem;
  font-weight: 500;
  text-align: left;
}

/* TAG */

.card-type-tag {
  position: absolute;
  top: 0;
  left: 0;
  font-size: 0.6rem;
  padding: 3px 8px;
  color: white;
  font-weight: 600;
  text-transform: uppercase;
}

/* COLORS */

.card-type-investigation { background: #8ac20a; }
.card-type-inspiration { background: #ddb800; }
.card-type-action { background: #08aac2; }
.card-type-immersion { background: #b577f0; }

.card-type-investigation-trans { background: #8bc20a3f; }
.card-type-inspiration-trans { background: #ddb8003f; }
.card-type-action-trans { background: #08aac23f; }
.card-type-immersion-trans { background: #b577f03f; }

</style>