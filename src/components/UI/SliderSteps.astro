---
interface Step {
  title: string;
  subtitle: string;
  description: string;
  image: string;
}

interface Props {
  steps: Step[];
  id?: string;
  background?: string;
}

const { steps = [], id = 'slider-1', background = 'transparent' } = Astro.props;
---

<div class="slider-step-wrapper" style={`background-color: ${background};`}>
  {
    steps.map((_, index) => (
      <input
        type="radio"
        name={`slider-${id}`}
        id={`${id}-step-${index}`}
        class="step-state"
        checked={index === 0}
      />
    ))
  }

  <div class="slider-viewport">
    {
      steps.map((step, index) => (
        <div class={`step-slide slide-${index}`}>
          <div class="step-center">
            <h2 class="handwriting-title">{step.title}</h2>
            <div class="main-image-wrapper">
              <img src={step.image} alt={step.title} class="main-round-image" />
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <div class="step-navigation-right">
    {
      steps.map((navStep, navIndex) => (
        <label for={`${id}-step-${navIndex}`} class="nav-item">
          <div class="nav-thumb-wrapper">
            <img src={navStep.image} alt={navStep.title} class="nav-thumb" />
            <div class="dashed-circle" />
          </div>
        </label>
      ))
    }
  </div>

  <div class="step-content-wrapper">
    {
      steps.map((step, index) => (
        <div class={`step-content-left slide-content-${index}`} data-slide={index}>
          <span class="step-subtitle">{step.subtitle}</span>
          <p class="step-description">{step.description}</p>
        </div>
      ))
    }
  </div>
</div>

<style>
  /* ========================================
     MOBILE FIRST – Améliorations centrage & marges
     ======================================== */

  .slider-step-wrapper {
    position: relative;
    width: 100vw;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    display: flex;
    flex-direction: column;
    gap: 1rem; /* + de marge verticale entre sections */
    padding: 1rem; /* plus d'espace global */
    min-height: auto;
    align-items: center; /* recentrage global */
  }

  .step-state {
    display: none;
  }

  .slider-viewport {
    position: relative;
    width: 100%;
    max-width: 60vw; /* limite la largeur pour mieux centrer */
    display: flex;
    flex-direction: column;
    gap: 0;
    align-items: center;
  }

  .slider-viewport .step-slide {
    position: relative !important;
    opacity: 0;
    visibility: hidden;
    height: 0;
    overflow: hidden;
  }

  #slider-1-step-0:checked ~ .slider-viewport .slide-0,
  #slider-1-step-1:checked ~ .slider-viewport .slide-1,
  #slider-1-step-2:checked ~ .slider-viewport .slide-2,
  #slider-1-step-3:checked ~ .slider-viewport .slide-3 {
    opacity: 1;
    visibility: visible;
    height: auto;
    overflow: visible;
  }

  .step-slide {
    display: flex;
    flex-direction: column;
    gap: 1.5rem; /* + marge entre image et titre */
    align-items: center;
    width: 100%;
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .step-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    order: 1;
  }

  .main-image-wrapper {
    width: 100%;
    max-width: 350px; /* ← plus gros sur mobile */
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    border: 8px solid white; /* bordure plus épaisse */
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2); /* ombre plus marquée */
  }

  .main-round-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .handwriting-title {
    font-family: 'PlayFair', cursive;
    font-size: 2rem; /* ← plus gros titre */
    color: var(--color-brand-primary);
    margin: 0 0 -1rem 0; /* ajusté pour chevauchement plus marqué */
    z-index: 2;
    filter: drop-shadow(3px 3px 0px white);
    text-align: center;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
  }

  .step-content-wrapper {
    position: relative;
    width: 100%;
    order: 3;
    text-align: center;
    min-height: 240px; /* + marge pour contenu */
    padding: 0;
  }

  .step-content-left {
    text-align: center;
    padding: 0 1rem; /* plus d'espace autour du texte */
    opacity: 0;
    visibility: hidden;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    transition:
      opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
      visibility 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #slider-1-step-0:checked ~ .step-content-wrapper .slide-content-0,
  #slider-1-step-1:checked ~ .step-content-wrapper .slide-content-1,
  #slider-1-step-2:checked ~ .step-content-wrapper .slide-content-2,
  #slider-1-step-3:checked ~ .step-content-wrapper .slide-content-3 {
    opacity: 1;
    visibility: visible;
    position: relative;
  }

  .step-subtitle {
    display: block;
    font-family: serif;
    color: var(--color-brand-primary);
    font-size: 1.5rem; /* ← plus gros */
    margin-bottom: 0.8rem;
    font-style: italic;
  }

  .step-description {
    line-height: 1.4;
    color: var(--color-brand-tertiary);
    font-size: 1.05rem; /* ← plus lisible */
    font-style: italic;
    font-family: serif;
    margin: 0 auto;
  }

  .step-navigation-right {
    position: static;
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: 1.5rem; /* + espace entre boutons */
    width: 100%;
    order: 3;
    margin-top: 0; /* plus de marge verticale */
    margin-left: auto;
    margin-right: auto;
    z-index: 10;
  }

  .nav-item {
    cursor: pointer;
    position: relative;
  }

  .nav-thumb-wrapper {
    position: relative;
    width: 60px; /* ← boutons plus gros */
    height: 60px;
  }

  .nav-thumb {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    transition:
      filter 0.3s ease,
      transform 0.3s ease;
    filter: grayscale(1);
  }

  .dashed-circle {
    position: absolute;
    top: -8px; /* ajusté pour plus gros bouton */
    left: -8px;
    width: 76px;
    height: 76px;
    border: 3px dashed var(--color-brand-primary); /* trait plus épais */
    border-radius: 50%;
    opacity: 0;
    transition: all 0.4s ease;
    pointer-events: none;
  }

  .nav-item:hover .nav-thumb {
    filter: grayscale(0);
    transform: scale(1.1);
  }

  .nav-item:hover .dashed-circle {
    opacity: 0.6;
    transform: rotate(15deg);
  }

  /* Active state */
  #slider-1-step-0:checked ~ .step-navigation-right .nav-item:nth-child(1) .nav-thumb,
  #slider-1-step-1:checked ~ .step-navigation-right .nav-item:nth-child(2) .nav-thumb,
  #slider-1-step-2:checked ~ .step-navigation-right .nav-item:nth-child(3) .nav-thumb {
    filter: grayscale(0);
    transform: scale(1.15); /* plus gros quand actif */
  }

  #slider-1-step-0:checked ~ .step-navigation-right .nav-item:nth-child(1) .dashed-circle,
  #slider-1-step-1:checked ~ .step-navigation-right .nav-item:nth-child(2) .dashed-circle,
  #slider-1-step-2:checked ~ .step-navigation-right .nav-item:nth-child(3) .dashed-circle {
    opacity: 1;
    transform: rotate(-10deg);
  }

  /* ========================================
     DESKTOP – Améliorations centrage & tailles
     ======================================== */
  @media (min-width: 1025px) {
    .slider-step-wrapper {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 5rem; /* + marge entre sections */
      padding: 2rem;
    }

    .step-content-wrapper {
      order: 1;
      flex: 0 0 28%;
      max-width: 28%;
      text-align: right;
      padding: 0 2rem 0 0;
    }

    .slider-viewport {
      order: 2;
      flex: 1 1 auto;
      max-width: 44%; /* ← élément central plus gros */
    }

    .step-content-left {
      text-align: center;
      padding: 1.5rem 1rem;
    }

    .step-navigation-right {
      order: 3;
      flex: 0 0 28%;
      max-width: 28%;
      padding-top: 2.5rem;
      gap: 1.5rem; /* + espace entre boutons */
      flex-direction: column;
    }

    .main-image-wrapper {
      width: 400px; /* ← beaucoup plus gros */
      max-width: 400px;
      margin-bottom: 0;
    }

    .handwriting-title {
      font-size: 3.25rem; /* ← titre encore plus imposant */
      margin: 0;
      filter: drop-shadow(4px 4px 0px white);
    }

    .step-subtitle {
      font-size: 2.2rem;
      margin-bottom: 1.2rem;
    }

    .step-description {
      font-size: 1.25rem !important;
      line-height: 1.4 !important;
    }

    .nav-thumb-wrapper {
      width: 80px; /* ← boutons de navigation plus gros */
      height: 80px;
    }

    .dashed-circle {
      width: 96px;
      height: 96px;
      top: -8px;
      left: -8px;
      border-width: 4px;
    }
  }

  @media (min-width: 1600px) {
    .main-image-wrapper {
      width: 520px; /* ← beaucoup plus gros */
      max-width: 520px;
      margin-bottom: 0;
    }

    .handwriting-title {
      font-size: 5rem; /* ← titre encore plus imposant */
      margin: 0 0 -1rem 0;
    }

    .step-description {
      font-size: 1.75rem !important;
      line-height: 1.4 !important;
    }

    .nav-thumb-wrapper {
      width: 120px; /* ← boutons de navigation plus gros */
      height: 120px;
    }

    .dashed-circle {
      width: 136px;
      height: 136px;
      top: -8px;
      left: -8px;
      border-width: 4px;
    }
  }
</style>
