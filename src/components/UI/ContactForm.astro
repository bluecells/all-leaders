---
import { contactFormTranslations } from '@/data/translations';

interface Props {
  formId: string;
  formPosition?: 'left' | 'right';
  lang?: 'it' | 'fr' | 'en';
}

const { formId, formPosition = 'right', lang = 'it' } = Astro.props;
const t = contactFormTranslations[lang] || contactFormTranslations.it;
---

<div class="contact-form-grid">
  <!-- Content slot (markdown) -->
  <div class={`contact-content ${formPosition === 'left' ? 'order-2' : 'order-1'}`}>
    <slot />
  </div>

  <!-- Form -->
  <div class={`contact-form-column ${formPosition === 'left' ? 'order-1' : 'order-2'}`}>
    <form
      class="contact-form"
      action={`https://formspree.io/f/${formId}`}
      method="POST"
      id="contact-form"
    >
      <div class="form-group">
        <label for="name">{t.name}</label>
        <input type="text" id="name" name="name" placeholder={t.namePlaceholder} required />
      </div>

      <div class="form-group">
        <label for="email">{t.email}</label>
        <input type="email" id="email" name="email" placeholder={t.emailPlaceholder} required />
      </div>

      <div class="form-group">
        <label for="phone">{t.phone}</label>
        <input type="tel" id="phone" name="phone" placeholder={t.phonePlaceholder} />
      </div>

      <div class="form-group">
        <label for="subject">{t.subject}</label>
        <input
          type="text"
          id="subject"
          name="subject"
          placeholder={t.subjectPlaceholder}
          required
        />
      </div>

      <div class="form-group">
        <label for="message">{t.message}</label>
        <textarea id="message" name="message" placeholder={t.messagePlaceholder} rows="6" required
        ></textarea>
      </div>

      <button type="submit" class="submit-btn">
        {t.sendButton}
      </button>

      <p class="form-message success-message" id="success-message" style="display: none;">
        {t.successMessage}
      </p>
      <p class="form-message error-message" id="error-message" style="display: none;">
        {t.errorMessage}
      </p>
    </form>
  </div>
</div>

<style>
  /* ========================================
     MOBILE FIRST
     ======================================== */

  .contact-form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    width: 100%;
    margin: 2rem 0;
    align-items: stretch;
  }

  .contact-content {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-right: 0;
  }

  .contact-content :global(h2:first-child) {
    margin-top: 0;
  }

  .contact-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .contact-form-column {
    display: flex;
    flex-direction: column;
  }

  .order-1 {
    order: 1;
  }

  .order-2 {
    order: 2;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text-main);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-group input,
  .form-group textarea {
    padding: 0.875rem;
    font-size: 1rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-family: inherit;
    transition: all 0.3s ease;
    background-color: white;
    color: var(--color-text-main);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-brand-primary);
    box-shadow: 0 0 0 3px rgba(74, 103, 65, 0.1);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #999;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 150px;
  }

  .submit-btn {
    padding: 0.875rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    background-color: var(--color-brand-primary);
    color: white;
    border: 1px solid var(--color-brand-primary);
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.3s ease;
    align-self: stretch;
    width: 100%;
  }

  .submit-btn:hover {
    background-color: var(--color-brand-accent);
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .form-message {
    font-size: 0.95rem;
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 4px;
    margin-bottom: 0;
  }

  .success-message {
    color: #2d5016;
    background-color: #e8f5e9;
    border-left: 4px solid var(--color-brand-primary);
  }

  .error-message {
    color: #7d2b56;
    background-color: #fce4ec;
    border-left: 4px solid var(--color-brand-alert);
  }

  /* ========================================
     TABLET & DESKTOP
     ======================================== */
  @media (min-width: 769px) {
    .contact-form-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .contact-content {
      justify-content: center;
      padding-right: 2rem;
    }

    .submit-btn {
      padding: 1rem 2.5rem;
      align-self: flex-start;
      width: auto;
    }
  }
</style>

<script define:vars={{ loadingText: contactFormTranslations[lang as keyof typeof contactFormTranslations]?.loadingText || contactFormTranslations.it.loadingText }}>
  const form = document.getElementById('contact-form');
  const successMessage = document.getElementById('success-message');
  const errorMessage = document.getElementById('error-message');
  const submitBtn = form?.querySelector('button[type="submit"]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form || !submitBtn) return;

    // Disabilita il bottone durante l'invio
    submitBtn.disabled = true;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = loadingText;

    try {
      const formData = new FormData(form);
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: {
          Accept: 'application/json',
        },
      });

      // Nascondi i messaggi precedenti
      successMessage?.style.setProperty('display', 'none');
      errorMessage?.style.setProperty('display', 'none');

      if (response.ok) {
        successMessage?.style.setProperty('display', 'block');
        form.reset();
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      } else {
        errorMessage?.style.setProperty('display', 'block');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    } catch (error) {
      console.error('Errore:', error);
      errorMessage?.style.setProperty('display', 'block');
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
    }
  });
</script>
