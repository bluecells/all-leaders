---
import { getImageSrc, getImageAlt } from '../../utils/imageHelper';

interface ImageData {
  image?: string | { src: string; alt?: string };
  src?: string;
  alt: string;
}

interface Props {
  height?: string;
  mobileHeight?: string;
  speed?: number;
  images: ImageData[];
  title?: string;
  titleTag?: 'h1' | 'h2' | 'h3' | 'p' | 'div';
  subtitle?: string;
  framePosition?: 'left' | 'right';
  verticalGap?: string;
  lang?: 'it' | 'fr' | 'en';
}

const {
  height = 'calc(100vh - 7rem)',
  mobileHeight = 'calc(100vh - 80px)',
  speed = 3000,
  images,
  title,
  titleTag = 'h2',
  subtitle,
  framePosition = 'left',
  verticalGap = '0',
  lang = 'it',
} = Astro.props;

const TitleTag = titleTag;

const limitedImages = images.slice(0, 10).map((img) => ({
  src: getImageSrc(img.image),
  alt: img.alt || getImageAlt(img.image, ''),
}));

const regionLabels = {
  it: 'sardegna',
  fr: 'sardaigne',
  en: 'sardinia',
};
const region = regionLabels[lang];
const actionUrl = `https://www.bed-and-breakfast.it/${lang}/${region}/limolo-house-56-green-cabras/57031`;
---

<div
  class="slider-container full-bleed"
  style={`--slider-height-mobile: ${mobileHeight}; --slider-height: ${height}; --vertical-gap: ${verticalGap};`}
>
  <!-- Slides -->
  <div class="slider-wrapper">
    {
      limitedImages.map((image, index) => (
        <div class="slide" data-index={index} style={index === 0 ? 'opacity: 1; z-index: 1;' : ''}>
          <img src={image.src} alt={image.alt} loading={index === 0 ? 'eager' : 'lazy'} />
        </div>
      ))
    }
  </div>

  <!-- Frame avec contenu -->
  {
    (title || subtitle) && (
      <div class={`slider-frame frame-${framePosition}`}>
        <div class="frame-content frame-content--centered">
          {title && <TitleTag class="frame-title" set:html={title} />}
          {subtitle && <p class="frame-subtitle" set:html={subtitle} />}
          <div class="frame-booking">
            <div
              class="js-booking-engine-container"
              data-idstruttura="57031"
              data-tipostruttura="bbit"
              data-tipo="widget"
              data-colore="ciano"
              data-lingua={lang}
              data-action={actionUrl}
              data-wl="true"
            />
            <script src="https://d117yjdt0789wg.cloudfront.net/CDN-widget/grunt/wdg-booking-engine.min.js" />
          </div>
        </div>
      </div>
    )
  }

  <!-- Navigation dots -->
  <div class="slider-dots">
    {
      limitedImages.map((_, index) => (
        <button
          class={`dot ${index === 0 ? 'active' : ''}`}
          data-slide={index}
          aria-label={`Aller à la diapositive ${index + 1}`}
        />
      ))
    }
  </div>
</div>

<style>
  /* ========================================
     MOBILE FIRST
     Image en bas, contenu en haut sur le fond crème
     ======================================== */

  .slider-container {
    position: relative;
    overflow: hidden;
    background: linear-gradient(to bottom, white, var(--color-bg-body));
    height: var(--slider-height-mobile);
  }

  .slider-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /* Mobile : image dans le tiers inférieur */
  .slide {
    position: absolute;
    top: 58%;
    left: 0;
    width: 100%;
    height: 42%;
    opacity: 0;
    transition: opacity 1s ease-in-out;
    z-index: 0;
  }

  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* FRAME - Mobile : ancrée en haut, pas de fond (le container sert de fond) */
  .slider-frame {
    position: absolute;
    top: 1.5rem;
    left: 1rem;
    right: 1rem;
    z-index: 10;
  }

  .frame-left {
    left: 1rem;
  }

  .frame-right {
    right: 1rem;
  }

  .frame-content {
    display: flex;
    flex-direction: column;
    gap: calc(0.5 * var(--vertical-gap));
  }

  .frame-content--centered {
    align-items: center;
    text-align: center;
  }

  /* TITLE - Mobile */
  .frame-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-brand-primary);
    margin: 0;
    text-align: center;
  }

  /* SUBTITLE - Mobile */
  .frame-subtitle {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-text-main);
    margin: 0;
    text-align: center;
  }

  /* BOOKING - Mobile */
  .frame-booking {
    width: 100%;
  }

  /* DOTS - Mobile : juste au-dessus de l'image */
  .slider-dots {
    position: absolute;
    bottom: calc(42% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 10;
  }

  .dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--color-brand-primary);
    background-color: transparent;
    cursor: pointer;
    transition: all 300ms;
    padding: 0;
  }

  .dot:hover {
    background-color: rgba(74, 103, 65, 0.3);
  }

  .dot.active {
    background-color: var(--color-brand-primary);
  }

  /* ========================================
     TABLET (769px+)
     Image plein écran, frame centrée avec dégradé
     ======================================== */
  @media (min-width: 769px) {
    .slider-container {
      height: var(--slider-height) !important;
    }

    /* Image plein cadre */
    .slide {
      top: 0;
      height: 100%;
    }

    .slider-frame {
      top: 220px;
      left: 50%;
      right: auto;
      transform: translate(-50%, -50%);
      width: 100%;
      padding: 2rem 2rem 3rem;
      background: linear-gradient(
        to bottom,
        rgba(245, 241, 232, 1) 0%,
        rgba(245, 241, 232, 1) 30%,
        rgba(245, 241, 232, 0.3) 80%,
        rgba(245, 241, 232, 0) 90%,
        rgba(245, 241, 232, 0) 100%
      );
      backdrop-filter: blur(2px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    }

    .frame-content {
      gap: calc(0.5rem + var(--vertical-gap));
    }

    .frame-left,
    .frame-right {
      left: 50%;
      transform: translate(-50%, -50%);
    }

    .frame-title {
      font-size: 3.5rem;
    }

    .frame-subtitle {
      font-size: 1.5rem;
    }

    /* Dots blancs sur image */
    .slider-dots {
      bottom: 1.5rem;
      gap: 0.75rem;
    }

    .dot {
      width: 18px;
      height: 18px;
      border-color: white;
    }

    .dot:hover {
      background-color: rgba(255, 255, 255, 0.5);
    }

    .dot.active {
      background-color: white;
    }
  }

  @media (min-width: 1025px) {
    .slider-frame {
      top: 200px;
      left: 50%;
      transform: translate(-50%, -50%);
    }
  }

  /* ========================================
     LARGE DESKTOP (1600px+)
     ======================================== */
  @media (min-width: 1600px) {
    .slider-container {
      height: var(--slider-height) !important;
    }

    .slider-frame {
      padding: 4rem 2rem;
      top: 220px;
      left: 50%;
      transform: translate(-50%, -50%);
    }

    .frame-left,
    .frame-right {
      left: 50%;
      transform: translate(-50%, -50%);
    }

    .frame-title {
      font-size: 6rem;
    }

    .frame-subtitle {
      font-size: 2.75rem;
    }

    .slider-dots {
      bottom: 2rem;
      gap: 0.75rem;
    }

    .dot {
      width: 22px;
      height: 22px;
    }
  }
</style>

<script is:inline define:vars={{ speed, totalSlides: limitedImages.length }}>
  let currentSlide = 0;
  let autoplayInterval;

  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.dot');

  function showSlide(index) {
    slides.forEach((slide) => {
      slide.style.opacity = '0';
      slide.style.zIndex = '0';
    });

    dots.forEach((dot) => dot.classList.remove('active'));

    if (slides[index]) {
      slides[index].style.opacity = '1';
      slides[index].style.zIndex = '1';
    }

    if (dots[index]) {
      dots[index].classList.add('active');
    }

    currentSlide = index;
  }

  function nextSlide() {
    const next = (currentSlide + 1) % totalSlides;
    showSlide(next);
  }

  function startAutoplay() {
    autoplayInterval = setInterval(nextSlide, speed);
  }

  function stopAutoplay() {
    clearInterval(autoplayInterval);
  }

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      showSlide(index);
      stopAutoplay();
      startAutoplay();
    });
  });

  const sliderContainer = document.querySelector('.slider-container');
  sliderContainer?.addEventListener('mouseenter', stopAutoplay);
  sliderContainer?.addEventListener('mouseleave', startAutoplay);

  if (totalSlides > 1) {
    startAutoplay();
  }
</script>
