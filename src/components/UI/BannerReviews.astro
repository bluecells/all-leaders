<section class="banner-reviews-section">
  <div class="banner-container">
    <div class="reviews-track">
      {
        allReviews.map((review) => (
          <div class="review-item" data-review-id={review.id}>
            <p class="review-text">{review.text}</p>
            <p class="review-role">{review.role}</p>
            <p class="review-name">{review.name}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const track = document.querySelector('.reviews-track');
  const reviewItems = Array.from(document.querySelectorAll('.review-item'));
  const totalReviews = reviewItems.length;
  const groupSize = 3;
  let currentGroupIndex = 0;

  // Fonction pour afficher un groupe de 3 reviews
  function displayGroup(groupIndex) {
    reviewItems.forEach((item, index) => {
      const isInGroup =
        (index >= groupIndex && index < groupIndex + groupSize) ||
        (groupIndex + groupSize > totalReviews && index < (groupIndex + groupSize) % totalReviews);
      item.style.display = isInGroup ? 'flex' : 'none';
    });
  }

  // Fonction pour animer l'apparition consécutive de 3 reviews (gauche, centre, droite / haut, milieu, bas)
  function animateGroupEntry(groupIndex) {
    const visibleItems = [];
    for (let i = 0; i < groupSize; i++) {
      const idx = (groupIndex + i) % totalReviews;
      visibleItems.push(reviewItems[idx]);
    }

    // Cacher tous les items
    reviewItems.forEach((item) => {
      item.style.opacity = '0';
    });

    // Afficher les 3 reviews en séquence (gauche/haut, centre/milieu, droite/bas)
    displayGroup(groupIndex);

    gsap.fromTo(
      visibleItems[0],
      { opacity: 0 },
      {
        opacity: 1,
        duration: 0.6,
        ease: 'power2.inOut',
      }
    );

    gsap.fromTo(
      visibleItems[1],
      { opacity: 0 },
      {
        opacity: 1,
        duration: 0.6,
        delay: 0.5,
        ease: 'power2.inOut',
      }
    );

    gsap.fromTo(
      visibleItems[2],
      { opacity: 0 },
      {
        opacity: 1,
        duration: 0.6,
        delay: 1,
        ease: 'power2.inOut',
      }
    );
  }

  // Animation initiale
  animateGroupEntry(0);

  // Rotation des groupes toutes les 5 secondes (3s d'affichage + 1.5s de fadeout + 0.5s buffer)
  setInterval(() => {
    const currentVisibleItems = [];
    for (let i = 0; i < groupSize; i++) {
      const idx = (currentGroupIndex + i) % totalReviews;
      currentVisibleItems.push(reviewItems[idx]);
    }

    // Fadeout
    gsap.to(currentVisibleItems, {
      opacity: 0,
      duration: 1.5,
      ease: 'power2.inOut',
      onComplete: () => {
        currentGroupIndex = (currentGroupIndex + groupSize) % totalReviews;
        animateGroupEntry(currentGroupIndex);
      },
    });
  }, 8000);
</script>

<style>
  /* ========================================
     Mobile First
     ======================================== */

  .banner-reviews-section {
    padding: 2rem 0.75rem 0 0.75rem;
    background: white;
  }

  .banner-container {
    max-width: 1200px;
    margin: 0 auto;
    overflow: hidden;
  }

  .reviews-track {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    width: 100%;
  }

  .review-item {
    background: white;
    border: 1px solid #e8e9eb8e;
    border-radius: 8px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.03);
    opacity: 0;
  }

  .review-role {
    font-size: 0.6rem !important;
    font-weight: 600;
    color: var(--color-brand-primary);
    margin: 0;
    line-height: 1.2;
    text-align: center !important;
  }

  .review-name {
    font-size: 0.6rem !important;
    color: #6b7280;
    margin: 0;
    line-height: 1;
    text-align: center !important;
  }

  .review-text {
    font-size: 0.8rem !important;
    font-style: italic;
    line-height: 1.4;
    color: var(--color-brand-primary);
    margin: 0;
    text-align: center !important;

    /* --- AJOUT CRITIQUE ICI --- */
    position: relative;
    padding-top: 2.5rem; /* Crée de l'espace au-dessus pour accueillir la quote centrée */
  }

  .review-text::before {
    content: '“';
    position: absolute;

    /* --- CORRECTION DU CENTRAGE ICI --- */
    top: 0;
    left: 50%;
    transform: translateX(-50%); /* Centre parfaitement le guillemet au milieu horizontal */

    /* Style et taille (Inchangés et parfaits) */
    font-size: 5rem;
    font-family: Georgia, serif;
    line-height: 1;
    font-weight: bold;
    color: #6b7280;
    opacity: 0.3;
    pointer-events: none;
    padding-bottom: 0.5rem;
  }

  /* ========================================
     Tablet (768px+)
     ======================================== */
  @media (min-width: 768px) {
    .banner-reviews-section {
      padding: 0;
    }

    .reviews-track {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .review-item {
      padding: 1rem;
    }

    .review-name {
      font-size: 0.8rem;
    }

    .review-role {
      font-size: 0.7rem;
    }

    .review-text {
      font-size: 0.75rem;
    }
  }

  /* ========================================
     Desktop (1024px+)
     ======================================== */
  @media (min-width: 1024px) {
    .banner-reviews-section {
      padding: 0;
    }

    .reviews-track {
      gap: 1.25rem;
    }

    .review-item {
      padding: 1.25rem;
    }

    .review-name {
      font-size: 0.9rem;
    }

    .review-role {
      font-size: 0.8rem;
    }

    .review-text {
      font-size: 0.85rem;
    }
  }
</style>
