      role: 'Chef de service (à l’issue d’un Parcours de développement managérial)',
      rating: 5,
      text: 'Ce parcours m’a offert une belle remise en question. Il permet d’objectiver des pratiques, des postures et des réflexions nécessaires à un management plus construit.',
    },
    {
      id: 7,
      name: 'Acteur de l’industrie nucléaire',
      role: 'Chef de service (à l’issue d’un Parcours de développement managérial)',
      rating: 5,
      text: "Les apports de ce parcours sont individuels et collectifs. En pratique le fait de pouvoir s'approprier les concepts managériaux pour les appliquer avec son équipe dynamise les relations",
    },
  ],
  en: [
    {
      id: 1,
      name: 'Anne-Flore Roger',
      role: 'Director of Networks and Mobile Services, Orange',
      rating: 5,
      text: 'Our management team is now more engaged, coherent and confident in its strategic direction.',
    },
    {
      id: 2,
      name: 'Thibault Lemoigne',
      role: 'Director of Client Relations, HomeServe',
      rating: 5,
      text: 'A pragmatic and well-adapted development approach. A moment of collective construction through the individual action of each member within a common management principle: leadership by intention.',
    },
    {
      id: 3,
      name: 'Christophe Jeanneau',
      role: 'HR Director of Nuclear Power Generation Plant, EDF',
      rating: 5,
      text: 'A strategic "sparring partner" posture… High-level pedagogical expertise… Systemic vision and agility.',
    },
    {
      id: 4,
      name: 'Jean-Luc Mitry',
      role: 'Controller Director at VINCI Construction',
      rating: 5,
      text: 'Mission fully accomplished to the great satisfaction of the teams involved.',
    },
    {
      id: 5,
      name: 'Martine Neuville',
      role: 'Director of FIPHFP',
      rating: 5,
      text: "Through various support modalities, I was able to measure the full extent of Marie Emmanuelle Py's skills, both professional and relational.",
    },
    {
      id: 6,
      name: 'Nuclear Industry Professional',
      role: 'Service Manager (following a Managerial Development Program)',
      rating: 5,
      text: 'This program offered me a valuable opportunity for self-reflection. It enables us to objectify practices, postures and reflections necessary for more constructive management.',
    },
    {
      id: 7,
      name: 'Nuclear Industry Professional',
      role: 'Service Manager (following a Managerial Development Program)',
      rating: 5,
      text: 'The benefits of this program are both individual and collective. In practice, being able to grasp the managerial concepts and apply them with your team strengthens relationships.',
    },
  ],
};

const allReviews = reviews[lang] || reviews.fr;
---

<section class="banner-reviews-section">
  <div class="banner-container">
    <div class="reviews-track">
      {
        allReviews.map((review) => (
          <div class="review-item" data-review-id={review.id}>
            <p class="review-text">{review.text}</p>
            <p class="review-role">{review.role}</p>
            <p class="review-name">{review.name}</p>
          </div>
        ))
      }
    </div>
    <div class="reviews-dots">
      {
        Array.from({ length: Math.ceil(allReviews.length / 3) }).map((_, index) => (
          <button
            class="dot"
            data-group-index={index}
            aria-label={lang === 'en' ? `Group ${index + 1}` : `Groupe ${index + 1}`}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const reviewItems = Array.from(document.querySelectorAll('.review-item'));
  const dots = Array.from(document.querySelectorAll('.dot'));
  const totalReviews = reviewItems.length;
  const groupSize = 3;
  const totalGroups = Math.ceil(totalReviews / groupSize);
  let currentGroupNumber = 0;
  let autoPlayTimer: ReturnType<typeof setTimeout> | null = null;

  // Fonction pour afficher un groupe de 3 reviews
  function displayGroup(groupNumber: number) {
    const startIndex = groupNumber * groupSize;
    reviewItems.forEach((item, index) => {
      const isInGroup = index >= startIndex && index < startIndex + groupSize;
      item.style.display = isInGroup ? 'flex' : 'none';
    });
  }

  // Fonction pour mettre à jour les dots
  function updateDots(groupNumber: number) {
    dots.forEach((dot, index) => {
      dot.classList.toggle('active', index === groupNumber);
    });
  }

  // Fonction pour animer l'apparition d'un bloc de 3 reviews ensemble
  function animateGroupEntry(groupNumber: number) {
    const startIndex = groupNumber * groupSize;
    const visibleItems = [];
    for (let i = 0; i < groupSize; i++) {
      const idx = startIndex + i;
      if (idx < totalReviews) {
        visibleItems.push(reviewItems[idx]);
      }
    }

    // Cacher tous les items
    reviewItems.forEach((item) => {
      item.style.opacity = '0';
    });

    // Afficher les 3 reviews en même temps
    displayGroup(groupNumber);
    updateDots(groupNumber);

    // Fadein du bloc de 3 reviews ensemble
    gsap.fromTo(
      visibleItems,
      { opacity: 0 },
      {
        opacity: 1,
        duration: 0.6,
        ease: 'power2.inOut',
      }
    );
  }

  // Fonction pour démarrer l'autoplay
  function startAutoPlay() {
    if (autoPlayTimer) clearTimeout(autoPlayTimer);
    autoPlayTimer = setTimeout(() => {
      const startIndex = currentGroupNumber * groupSize;
      const currentVisibleItems = [];
      for (let i = 0; i < groupSize; i++) {
        const idx = startIndex + i;
        if (idx < totalReviews) {
          currentVisibleItems.push(reviewItems[idx]);
        }
      }

      // Fadeout
      gsap.to(currentVisibleItems, {
        opacity: 0,
        duration: 1.5,
        ease: 'power2.inOut',
        onComplete: () => {
          currentGroupNumber = (currentGroupNumber + 1) % totalGroups;
          animateGroupEntry(currentGroupNumber);
          startAutoPlay();
        },
      });
    }, 8000);
  }

  // Fonction pour naviguer vers un groupe spécifique
  function goToGroup(groupNumber: number) {
    const startIndex = currentGroupNumber * groupSize;
    const currentVisibleItems = [];
    for (let i = 0; i < groupSize; i++) {
      const idx = startIndex + i;
      if (idx < totalReviews) {
        currentVisibleItems.push(reviewItems[idx]);
      }
    }

    // Fadeout
    gsap.to(currentVisibleItems, {
      opacity: 0,
      duration: 0.8,
      ease: 'power2.inOut',
      onComplete: () => {
        currentGroupNumber = groupNumber;
        animateGroupEntry(currentGroupNumber);
        startAutoPlay();
      },
    });
  }

  // Animation initiale
  animateGroupEntry(0);
  startAutoPlay();

  // Ajouter les event listeners aux dots
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      goToGroup(index);
    });
  });
</script>

<style>
  /* ========================================
     Mobile First
     ======================================== */

  .banner-reviews-section {
    padding: 2rem 0.75rem 0 0.75rem;
    background: white;
  }

  .banner-container {
    max-width: 1200px;
    margin: 0 auto;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .reviews-track {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    width: 100%;
    min-height: 30vh;
    justify-content: center;
    align-items: center;
  }

  .review-item {
    background: white;
    border: 1px solid #e8e9eb8e;
    border-radius: 8px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.03);
    opacity: 0;
    justify-content: flex-start;
    align-items: center;
    flex: 1 1 100%;
    height: 38vh;
  }

  .review-role {
    font-size: 0.6rem !important;
    font-weight: 600;
    color: var(--color-brand-primary);
    margin: 0;
    line-height: 1.2;
    text-align: center !important;
  }

  .review-name {
    font-size: 0.6rem !important;
    color: #6b7280;
    margin: 0;
    line-height: 1;
    text-align: center !important;
  }

  .review-text {
    font-size: 0.8rem !important;
    font-style: italic;
    line-height: 1.4;
    color: var(--color-brand-primary);
    margin: 0;
    text-align: center !important;

    /* --- AJOUT CRITIQUE ICI --- */
    position: relative;
    padding-top: 2.5rem; /* Crée de l'espace au-dessus pour accueillir la quote centrée */
  }

  .review-text::before {
    content: '“';
    position: absolute;

    /* --- CORRECTION DU CENTRAGE ICI --- */
    top: 0;
    left: 50%;
    transform: translateX(-50%); /* Centre parfaitement le guillemet au milieu horizontal */

    /* Style et taille (Inchangés et parfaits) */
    font-family: Georgia, 'Times New Roman', Times, serif;
    font-size: 5rem;
    line-height: 1;
    font-weight: bold;
    color: #6b7280;
    opacity: 0.3;
    pointer-events: none;
    padding-bottom: 0.5rem;
  }

  .reviews-dots {
    display: flex;
    justify-content: center;
    gap: 1rem;
    padding: 0.5rem 0;
  }

  .dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    border: none;
    background-color: #d1d5db;
    cursor: pointer;
    transition: background-color 0.3s ease;
    padding: 0;
  }

  .dot.active {
    background-color: var(--color-brand-primary);
  }

  .dot:hover {
    background-color: #9ca3af;
  }

  .dot.active:hover {
    background-color: var(--color-brand-primary);
  }

  /* ========================================
     Tablet (768px+)
     ======================================== */
  @media (min-width: 768px) {
    .banner-reviews-section {
      padding: 0;
    }

    .reviews-track {
      flex-wrap: nowrap;
    }

    .review-item {
      padding: 1rem;
      flex: 1 1 calc(33.333% - 1rem);
    }

    .review-name {
      font-size: 0.8rem;
    }

    .review-role {
      font-size: 0.7rem;
    }

    .review-text {
      font-size: 0.75rem;
    }
  }

  /* ========================================
     Desktop (1024px+)
     ======================================== */
  @media (min-width: 1024px) {
    .banner-reviews-section {
      padding: 0;
    }

    .reviews-track {
      gap: 1.25rem;
    }

    .review-item {
      padding: 1.25rem;
    }

    .review-name {
      font-size: 0.9rem;
    }

    .review-role {
      font-size: 0.8rem;
    }

    .review-text {
      font-size: 0.85rem;
    }
  }
</style>
