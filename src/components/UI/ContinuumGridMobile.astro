---
// Composant ContinuumGrid pour mobile parfaitement centré H&V
interface Props {
  lang?: 'fr' | 'en';
}

const { lang = 'fr' } = Astro.props;

const texts = {
  fr: {
    title: 'Continuum de la performance collective',
    zone_blue: 'Collectif hautement performant',
    zone_3_title: '(Sur)performance à maintenir',
    zone_3_desc: 'Déployer le leadership à tout niveau',
    zone_2_title: 'Opportunités à développer',
    zone_2_desc: 'Amplifier les points forts et réguler les vulnérabilités',
    zone_1_title: 'Difficultés à résoudre',
    zone_1_desc: 'Bien-être mental fondamental à récréer',
    zone_red: 'Groupe dysfonctionnel',
  },
  en: {
    title: 'Collective performance continuum',
    zone_blue: 'High performing team',
    zone_3_title: 'High performance to maintain',
    zone_3_desc: 'Deploy leadership at all levels',
    zone_2_title: 'Opportunities to develop',
    zone_2_desc: 'Amplify strengths and regulate vulnerabilities',
    zone_1_title: 'Challenges to resolve',
    zone_1_desc: 'Rebuild fundamental mental wellbeing',
    zone_red: 'Dysfunctional group',
  },
};

const t = texts[lang] || texts.fr;
---

<div class="continuum-mobile-outer">
  <div class="continuum-mobile-wrapper" role="img" aria-label={t.title}>
    <div class="continuum-mobile-grid">
      <div class="mobile-zone zone-blue">
        <span>{t.zone_blue}</span>
      </div>

      <div class="mobile-zone zone-3">
        <img class="img-bouees" src="/images/pages/bouee-eaux-saines.webp" alt="" />
        <div>
          <span>{t.zone_3_title}</span>{t.zone_3_desc}
        </div>
      </div>

      <div class="mobile-zone zone-2">
        <img class="img-bouees" src="/images/pages/balise-speciale.webp" alt="" />
        <div>
          <span>{t.zone_2_title}</span>{t.zone_2_desc}
        </div>
      </div>

      <div class="mobile-zone zone-1">
        <img class="img-bouees" src="/images/pages/marque-de-danger-isole.webp" alt="" />
        <div>
          <span>{t.zone_1_title}</span>{t.zone_1_desc}
        </div>
      </div>
      <div class="mobile-zone zone-red">
        <span>{t.zone_red}</span>
      </div>
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initContinuum() {
    const outer = document.querySelector('.continuum-mobile-outer');
    const wrapper = document.querySelector('.continuum-mobile-wrapper');
    const zones = document.querySelectorAll('.mobile-zone');

    if (!outer || !wrapper || zones.length === 0) return;

    const zonesArray = Array.from(zones).reverse();

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: outer,
        start: 'top top', // Déclenchement naturel dès que le conteneur padding inclus arrive en haut
        end: '+=800',
        scrub: 1.2,
        pin: wrapper,
        pinSpacing: true,
        invalidateOnRefresh: true,
      },
    });

    zonesArray.forEach((zone, index) => {
      tl.to(
        zone,
        {
          opacity: 1,
          scale: 1,
          y: 0,
          duration: 1,
          ease: 'power2.inOut',
        },
        index * 1.2
      );
    });
  }

  document.addEventListener('DOMContentLoaded', initContinuum);
  document.addEventListener('astro:page-load', initContinuum);
</script>

<style>
  /* Le parent prend le padding demandé et laisse l'enfant s'occuper de l'écran */
  .continuum-mobile-outer {
    position: relative;
    width: 100%;
    overflow: visible;
    padding: 5rem 0 2rem 0; /* Ton padding demandé */
    box-sizing: border-box;
  }

  /* Centrage H&V mathématique pur */
  .continuum-mobile-wrapper {
    position: relative;
    width: 100%;
    height: 93svh; /* Hauteur de référence exclusive sur mobile */
    display: flex;
    justify-content: center; /* Centrage horizontal */
    align-items: center; /* Centrage vertical parfait */
    overflow: hidden;
  }

  /* La grille redevient un bloc naturel sans décalage parasite */
  .continuum-mobile-grid {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 90%;
    height: auto;
    gap: 1rem; /* Unifié pour simplifier la structure */
  }

  .mobile-zone {
    width: 100%;
    text-align: center;
    border-radius: 0.5rem;
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    will-change: opacity, transform;
    box-sizing: border-box;
  }

  .mobile-zone div {
    color: var(--color-brand-primary);
    font-weight: 600;
    font-size: 15px;
    display: block;
    line-height: 1.3;
  }

  .mobile-zone div span {
    text-transform: uppercase;
    font-weight: extra-bold;
    font-size: 18px;
    display: block;
    line-height: 1.3;
  }

  /* Blocs haut et bas simplifiés et homogènes */
  .zone-red,
  .zone-blue {
    padding: 1rem 1.5rem;
    line-height: 1.2em;
  }

  .zone-red {
    background: rgba(171, 8, 0, 0.95);
  }

  .zone-blue {
    background: rgba(3, 26, 52, 0.95);
  }

  .zone-red span,
  .zone-blue span {
    color: #ffffff !important;
  }

  /* Dégradés appliqués proprement sur les spans intermédiaires */
  .zone-1 div,
  .zone-2 div,
  .zone-3 div {
    display: block;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-fill-color: transparent;
    color: var(--color-brand-primary);
  }

  .zone-1 div {
    background-image: linear-gradient(to top, rgba(171, 8, 0, 0.95), rgba(102, 16, 112, 0.95));
  }

  .zone-2 div {
    background-image: linear-gradient(to top, rgba(102, 16, 112, 0.95), rgba(3, 26, 52, 0.85));
  }

  .zone-3 div {
    background-image: linear-gradient(to top, rgba(3, 26, 52, 0.85), rgba(3, 26, 52, 1));
  }

  .img-bouees {
    height: auto;
    width: 65px; /* Un tout petit peu optimisé pour garantir que tout l'empilement respire au centre */
    margin: 0 auto 0.25rem auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-zone {
      opacity: 1;
      transform: none;
    }
  }
</style>
