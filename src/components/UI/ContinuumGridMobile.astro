---
// Composant ContinuumGrid pour mobile centré avec dégradés
---

<div class="continuum-mobile-outer">
  <div
    class="continuum-mobile-wrapper"
    role="img"
    aria-label="Continuum de la performance collective"
  >
    <div class="continuum-mobile-grid">
      <div class="mobile-zone zone-blue">
        <span>Collectif hautement performant</span>
      </div>

      <div class="mobile-zone zone-3">
        <img class="img-bouees" src="/images/pages/bouee-eaux-saines.webp" alt="" />
        <span>Déployer le leadership<br />à tout niveau</span>
      </div>

      <div class="mobile-zone zone-2">
        <img class="img-bouees" src="/images/pages/balise-speciale.webp" alt="" />
        <span>Amplifier les points forts et réguler les vulnérabilités</span>
      </div>

      <div class="mobile-zone zone-1">
        <img class="img-bouees" src="/images/pages/marque-de-danger-isole.webp" alt="" />
        <span>Bien-être mental<br />fondamental à récréer</span>
      </div>

      <div class="mobile-zone zone-red">
        <span>Groupe dysfonctionnel</span>
      </div>
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initContinuum() {
    const outer = document.querySelector('.continuum-mobile-outer');
    const wrapper = document.querySelector('.continuum-mobile-wrapper');
    const zones = document.querySelectorAll('.mobile-zone');

    if (!outer || !wrapper || zones.length === 0) return;

    const zonesArray = Array.from(zones).reverse();

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: outer,
        start: 'top 1rem', // Calage à 1rem sous la nav
        end: '+=800',
        scrub: 1,
        pin: wrapper,
        pinSpacing: true,
        invalidateOnRefresh: true,
      },
    });

    zonesArray.forEach((zone, index) => {
      tl.to(
        zone,
        {
          opacity: 1,
          scale: 1,
          y: 0,
          duration: 1,
          ease: 'power2.inOut',
        },
        index * 1.2
      );
    });
  }

  document.addEventListener('DOMContentLoaded', initContinuum);
  document.addEventListener('astro:page-load', initContinuum);
</script>

<style>
  .continuum-mobile-outer {
    position: relative;
    width: 100%;
    overflow: visible;
  }

  .continuum-mobile-wrapper {
    position: relative;
    width: 100%;
    /* Prise en compte de ton besoin de 96.5vh moins le décalage sous nav */
    height: calc(96.5vh - 1rem);
    display: flex;
    /* On repasse sur un vrai centrage vertical parfait */
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .continuum-mobile-grid {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center; /* Centre les éléments dans la grille */
    align-items: center;
    width: 90%;
    /* On force une hauteur pour stabiliser le conteneur dès le départ */
    height: auto;
    margin-top: 10dvh; /* Ajuste cette valeur (ex: 2rem, 3rem) pour descendre l'animation pile au centre visuel */
    gap: 0.5rem;
  }

  .mobile-zone {
    width: 100%;
    text-align: center;
    border-radius: 0.5rem;
    opacity: 0;
    transform: translateY(20px) scale(0.95); /* Légèrement réduit pour éviter l'effet de saut au départ */
    will-change: opacity, transform;
  }

  .mobile-zone span {
    color: var(--color-brand-primary);
    font-weight: 700;
    font-size: 15px;
    text-transform: uppercase;
    display: block;
  }

  .zone-red {
    background: rgba(171, 8, 0, 0.95);
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    padding: 1rem 2rem;
  }

  .zone-blue {
    background: rgba(3, 26, 52, 0.95);
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    padding: 1rem 2rem;
  }

  .zone-red span,
  .zone-blue span {
    color: #ffffff !important;
  }

  .zone-1 span,
  .zone-2 span,
  .zone-3 span {
    display: block;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-fill-color: transparent;
    color: var(--color-brand-primary);
  }

  .zone-1 span {
    background-image: linear-gradient(to top, rgba(171, 8, 0, 0.95), rgba(102, 16, 112, 0.95));
  }

  .zone-2 span {
    background-image: linear-gradient(to top, rgba(102, 16, 112, 0.95), rgba(3, 26, 52, 0.85));
  }

  .zone-3 span {
    background-image: linear-gradient(to top, rgba(3, 26, 52, 0.85), rgba(3, 26, 52, 1));
  }

  .zone-1,
  .zone-2,
  .zone-3 {
    max-width: 80%;
    padding-top: 0.5rem;
  }

  .img-bouees {
    height: auto;
    width: 70px; /* Légèrement réduit pour garantir que le tout rentre sans déborder sur petits écrans */
    margin: 0 auto 0.25rem auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-zone {
      opacity: 1;
      transform: none;
    }
  }
</style>
