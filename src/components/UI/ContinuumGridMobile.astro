---
// Composant ContinuumGrid pour mobile
---

<div class="continuum-mobile-outer">
  <div class="continuum-mobile-wrapper" role="img" aria-label="Continuum de la performance collective">
    <div class="continuum-mobile-grid">
      <div class="mobile-zone zone-blue">
        <span>Collectif hautement performant</span>
      </div>

      <div class="mobile-zone zone-3">
        <span>Déployer le leadership à tout niveau</span>
      </div>

      <div class="mobile-zone zone-2">
        <span>Amplifier les points forts et réguler les vulnérabilités</span>
      </div>

      <div class="mobile-zone zone-1">
        <span>Bien-être mental fondamental à récréer</span>
      </div>

      <div class="mobile-zone zone-red">
        <span>Groupe dysfonctionnel</span>
      </div>
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initContinuum() {
    const outer = document.querySelector('.continuum-mobile-outer');
    const wrapper = document.querySelector('.continuum-mobile-wrapper');
    const zones = document.querySelectorAll('.mobile-zone');
    
    if (!wrapper || zones.length === 0) return;

    // On part de la zone-red (dernière dans le DOM) vers zone-blue (première)
    const zonesArray = Array.from(zones).reverse();

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: outer,      // On déclenche sur le conteneur extérieur
        start: '-20% top',    // Se bloque quand le haut touche le haut de l'écran
        end: '+=800',       // Définit la "longueur" du scroll de l'animation
        scrub: 1,
        pin: wrapper,        // On épingle uniquement le wrapper intérieur
        pinSpacing: true,    // CRUCIAL : Pousse le contenu suivant
        invalidateOnRefresh: true,
      },
    });

    zonesArray.forEach((zone, index) => {
      tl.to(zone, {
        opacity: 1,
        scale: 1,
        y: 0,
        duration: 1,
        ease: 'power2.inOut',
      }, index * 1.5);
    });

    tl.to({}, { duration: 0.5 }); // Petite pause finale
  }

  // Support Astro (Chargement initial + navigation client-side)
  document.addEventListener('DOMContentLoaded', initContinuum);
  document.addEventListener('astro:page-load', initContinuum);
</script>

<style>
  /* Conteneur principal qui définit l'ancrage */
  .continuum-mobile-outer {
    position: relative;
    width: 100%;
    overflow: visible;
  }

  .continuum-mobile-wrapper {
    position: relative;
    width: 100%;
    height: 100vh; /* Prend toute la hauteur pour l'effet de focus */
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  /* Flèche en arrière-plan */
  .continuum-mobile-wrapper::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 90vh; 
    height: 90vw;
    transform: translate(-50%, -50%) rotate(-90deg);
    background-image: url('/images/pages/continuum-performance-collective.webp');
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
    z-index: 1;
    pointer-events: none;
    opacity: 0.7;
  }

  .continuum-mobile-grid {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 90%;
    gap: 1rem;
  }

  .mobile-zone {
    width: 100%;
    padding: 1rem;
    text-align: center;
    border-radius: 0.5rem;
    /* État initial caché */
    opacity: 0;
    transform: translateY(30px) scale(0.9);
    will-change: opacity, transform;
  }

  .mobile-zone span {
    color: white;
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    display: block;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  .zone-red { background: rgba(171, 8, 0, 0.95); margin-top: 4rem; margin-bottom: 2rem;}
  .zone-blue { background: rgba(3, 26, 52, 0.95); margin-bottom: 8rem;}
  .zone-1 { background: rgba(171, 8, 0, 0.75); max-width: 80%;}
  .zone-2 { background: rgba(151, 106, 152, 0.75); max-width: 80%; }
  .zone-3 { background: rgba(3, 26, 52, 0.75); max-width: 80%; }

  @media (prefers-reduced-motion: reduce) {
    .mobile-zone { opacity: 1; transform: none; }
  }
</style>