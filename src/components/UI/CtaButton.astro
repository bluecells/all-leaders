---
interface Props {
  text: string;
  link: string;
  align?: 'left' | 'center' | 'right';
  variant?: 'primary' | 'secondary';
  target?: '_blank' | '_self';
}

const { text, link, align = 'center', variant = 'primary', target = '_self' } = Astro.props;

// On mappe l'alignement sur des valeurs de flexbox
const alignmentMap = {
  left: 'flex-start',
  center: 'center',
  right: 'flex-end',
};
---

<div class="cta-wrapper" style={`justify-content: ${alignmentMap[align]};`}>
  <a href={link} class={`cta-btn ${variant}`} target={target}>
    {text}
  </a>
</div>

<style>
  .cta-wrapper {
    display: flex;
    width: 100%;
    margin: 2rem 0;
  }

  .cta-btn {
    display: inline-block;
    width: 100%;
    padding: 1rem 2.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  /* Style Limolo Green */
  .primary {
    background-color: var(--color-brand-primary);
    color: white;
    border: 1px solid var(--color-brand-primary);
  }

  .primary:hover {
    background-color: var(--color-brand-accent); /* Une nuance plus claire ou terre */
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  }

  /* Style Contour/Épuré */
  .secondary {
    background-color: transparent;
    color: var(--color-brand-primary);
    border: 1px solid var(--color-brand-primary);
  }

  .secondary:hover {
    background-color: var(--color-brand-primary);
    color: white;
  }

  @media screen and (min-width: 768px) {
    .cta-btn {
      width: auto;
    }
  }
</style>
