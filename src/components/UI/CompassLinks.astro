<div class="compass-main">
  <div class="bg-white/80 my-10 p-4 shadow-2xl md:shadow-none rounded-md z-50 w-10/12 mx-auto">
    <h3 class="text-center! w-full mx-auto max-w-4xl! md:pb-2 md:pt-0">
      Transformer les <strong>intentions en actions</strong> concrètes, pour des équipes agissant avec
      <strong>sens, clarté et impact.</strong>
    </h3>
  </div>

  <div class="compass-container rounded-lg">
    <div class="compass-left"></div>

    <div class="compass-perspective-wrapper">
      <div id="compassRoseBg"></div>
      <div class="compass-compass-fixed"></div>

      <div class="compass-orbit" id="compassOrbit">
        <a
          href="/accompagnements#category-gestion-de-la-conflictualite"
          class="compass-link"
          data-index="0"
        >
          <span
            >Gestion de<br />la conflictualité<img
              src="images/pages/en-savoir-plus.webp"
              class="image-link"
            /></span
          >
        </a>
        <a
          href="/accompagnements#category-diagnostic-de-la-performance"
          class="compass-link"
          data-index="1"
        >
          <span
            >Diagnostic de<br />la performance<img
              src="images/pages/en-savoir-plus.webp"
              class="image-link"
            /></span
          >
        </a>
        <a href="/accompagnements#category-executive-coaching" class="compass-link" data-index="2">
          <span
            >Executive<br />coaching<img
              src="images/pages/en-savoir-plus.webp"
              class="image-link"
            /></span
          >
        </a>
        <a
          href="/accompagnements#category-sante-mentale-et-performance-durable"
          class="compass-link"
          data-index="3"
        >
          <span
            >Santé mentale et<br />performance durable<img
              src="images/pages/en-savoir-plus.webp"
              class="image-link"
            /></span
          >
        </a>
        <a
          href="/accompagnements#category-leadership-development"
          class="compass-link"
          data-index="4"
        >
          <span
            >Leadership<br />development<img
              src="images/pages/en-savoir-plus.webp"
              class="image-link"
            /></span
          >
        </a>
        <a
          href="/accompagnements#category-coaching-equipes-et-organisations"
          class="compass-link"
          data-index="5"
        >
          <span
            >Coaching<br />d'équipe<img
              src="images/pages/en-savoir-plus.webp"
              class="image-link"
            /></span
          >
        </a>
