---
import { Image } from 'astro:assets';
import compassIcon from '@/assets/images/ui/en-savoir-plus.webp';

interface Props {
  lang?: 'fr' | 'en';
}

const { lang = 'fr' } = Astro.props;

const categories = {
  fr: [
    {
      name: 'Gestion de la conflictualité',
      href: '/accompagnements#category-gestion-de-la-conflictualite',
      alt: 'Gestion de la conflictualité',
    },
    {
      name: 'Diagnostic de la performance',
      href: '/accompagnements#category-diagnostic-de-la-performance',
      alt: 'Diagnostic de la performance',
    },
    {
      name: 'Executive coaching',
      href: '/accompagnements#category-executive-coaching',
      alt: 'Executive coaching',
    },
    {
      name: 'Santé mentale et performance durable',
      href: '/accompagnements#category-sante-mentale-et-performance-durable',
      alt: 'Santé mentale et performance durable',
    },
    {
      name: 'Leadership development',
      href: '/accompagnements#category-leadership-development',
      alt: 'Leadership development',
    },
    {
      name: "Coaching d'équipe",
      href: '/accompagnements#category-coaching-equipes-et-organisations',
      alt: "Coaching d'équipe",
    },
  ],
  en: [
    {
      name: 'Conflict Management',
      href: '/en/services#category-conflict-management',
      alt: 'Conflict Management',
    },
    {
      name: 'Performance Diagnosis',
      href: '/en/services#category-performance-diagnosis',
      alt: 'Performance Diagnosis',
    },
    {
      name: 'Executive Coaching',
      href: '/en/services#category-executive-coaching',
      alt: 'Executive Coaching',
    },
    {
      name: 'Mental Health and Sustainable Performance',
      href: '/en/services#category-mental-health-and-sustainable-performance',
      alt: 'Mental Health and Sustainable Performance',
    },
    {
      name: 'Leadership Development',
      href: '/en/services#category-leadership-development',
      alt: 'Leadership Development',
    },
    {
      name: 'Team Coaching',
      href: '/en/services#category-team-coaching-and-organizations',
      alt: 'Team Coaching',
    },
  ],
};

const titleFr =
  'Transformer les <strong>intentions en actions</strong> concrètes, pour des équipes agissant avec <strong>sens, clarté et impact.</strong>';
const titleEn =
  'Transform <strong>intentions into concrete actions</strong>, to enable teams led by <strong>purpose, clarity and impact.</strong>';
const title = lang === 'en' ? titleEn : titleFr;
const catList = categories[lang] || categories.fr;
---

<div class="compass-main">
  <div class="flex justify-end py-10 z-50 mx-auto">
    <h3 class="title-compass" set:html={title} />
  </div>

  <div class="compass-container rounded-lg">
    <div class="compass-left"></div>

    <div class="compass-perspective-wrapper">
      <div id="compassRoseBg"></div>
      <div class="compass-compass-fixed"></div>

      <div class="compass-orbit" id="compassOrbit">
        {
          catList.map((cat, idx) => (
            <a href={cat.href} class="compass-link" data-index={idx}>
              <span>
                {cat.name}
                <Image
                  src={compassIcon}
                  alt={cat.alt}
                  width={60}
                  widths={[25, 40, 60]}
                  sizes="(max-width: 768px) 25px, 60px"
                  format="webp"
                  loading="lazy"
                  decoding="async"
                  class="image-link"
                />
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <div class="compass-right"></div>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initCompass = () => {
    const orbit = document.getElementById('compassOrbit');
    const roseBg = document.getElementById('compassRoseBg');
    const spans = document.querySelectorAll('.compass-link span');
    const links = document.querySelectorAll('.compass-link');
    const angleStep = 60;

    if (!orbit || !spans.length) return;

    // 1. On stocke la timeline dans une variable pour pouvoir y accéder au clic
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '.compass-main',
        start: '-25% top',
        end: '15%',
        scrub: 1.5,
        pin: false,
        anticipatePin: 1,
        invalidateOnRefresh: true,
        pinSpacing: false,
      },
    });

    tl.to(orbit, { y: -20, rotation: 120, ease: 'none' }, 0);
    if (roseBg) {
      tl.to(roseBg, { rotation: 15, force3D: true, ease: 'none' }, 0);
    }

    spans.forEach((span, i) => {
      const startAngle = i * angleStep;
      gsap.set(span, { transformOrigin: 'center center', rotation: -startAngle });
      tl.to(span, { rotation: -(120 + startAngle), ease: 'none' }, 0);
    });

    // 2. AXE 1 : Interception des clics pour stabiliser le scroll
    links.forEach((link) => {
      link.addEventListener('click', (e) => {
        // On récupère l'adresse cible (ex: /accompagnements#category-...)
        const targetUrl = link.getAttribute('href');
        if (!targetUrl) return;

        // Évite le changement de page immédiat du navigateur pendant qu'on nettoie GSAP
        e.preventDefault();

        // Force la timeline à sa position finale et tue le ScrollTrigger
        // Cela supprime le "pin-spacer" et rend au body sa hauteur fixe instantanément
        if (tl.scrollTrigger) {
          tl.scrollTrigger.kill(false); // Le paramètre false évite un jump visuel violent avant de partir
        }

        // Maintenant que le DOM de cette page est "propre", on change de page
        window.location.href = targetUrl;
      });
    });
  };

  // Initialisation sur le cycle de vie Astro / DOM
  document.addEventListener('DOMContentLoaded', initCompass);

  // Sécurité si vous utilisez Astro ViewTransitions (<ClientRouter />)
  document.addEventListener('astro:page-load', initCompass);

  window.addEventListener('load', () => ScrollTrigger.refresh());
</script>

<style>
  :root {
    /* Calcul dynamique de l'espace disponible */
    --title-height: 100px; /* Estimation hauteur titre + padding */
    --available-height: calc(100svh - var(--title-height) - 100px);

    /* Taille de la boussole : plus petit entre hauteur et largeur */
    --compass-size: min(calc(var(--available-height) * 0.75), 80vw);

    /* Rayon de l'orbite proportionnel */
    --radius: calc(var(--compass-size) * 0.38);
  }

  /* --- STRUCTURE GLOBALE --- */
  .compass-main {
    width: calc(100% + 2rem); /* 2rem de padding sur les cotes */
    height: 100svh;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    margin: 0 -1rem;
    z-index: 1;
  }

  .compass-container {
    width: 100%;
    flex: 1;
    min-height: 0; /* Important pour flexbox */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .compass-perspective-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* --- ÉLÉMENTS DU DÉCOR (CARTES) --- */
  .compass-left,
  .compass-right {
    width: 100%;
    height: 100%;
    background-size: 200%;
    background-repeat: no-repeat;
  }
  .compass-left {
    background-image: url('/images/pages/carte-marine-gauche.webp');
    background-position: right center;
    border-radius: 1rem 0 0 1rem;
  }
  .compass-right {
    background-image: url('/images/pages/carte-marine-droite.webp');
    background-position: left center;
    border-radius: 0 1rem 1rem 0;
  }

  #compassRoseBg {
    position: absolute;
    top: 50%;
    left: 50%;
    width: calc(var(--compass-size) * 2.8);
    height: calc(var(--compass-size) * 2.8);
    max-width: 1200px;
    max-height: 1200px;
    transform: translate(-50%, -50%);
    background-size: 200%;
    background-position: center;
    opacity: 0.6;
    z-index: -1;
    pointer-events: none;
    will-change: transform;
  }

  .compass-compass-fixed {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: var(--compass-size);
    height: var(--compass-size);
    max-width: 600px; /* Limite sur très grands écrans */
    max-height: 600px;
    background-image: url('/images/pages/boussole.webp');
    background-size: contain;
    background-repeat: no-repeat;
    z-index: 5;
    pointer-events: none;
  }

  /* --- TITRE --- */
  .title-compass {
    flex-shrink: 0; /* Ne rétrécit jamais */
    box-sizing: border-box;
    text-align: center;
    width: clamp(70%, 5vw + 55%, 90%);
    margin: 0 auto;
    line-height: 1.4;
  }

  /* --- LIENS ET ORBITE --- */
  .compass-orbit {
    position: relative;
    width: 2px;
    height: 2px;
    z-index: 10;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .compass-link {
    position: absolute;
    width: calc(var(--compass-size) * 0.45); /* Proportionnel */
    max-width: 250px;
    text-decoration: none;
    transform-origin: center center;
    transition: color 0.3s ease;
    z-index: 20;
  }

  .compass-link[data-index='0'] {
    transform: rotate(0deg) translateY(calc(-1 * var(--radius)));
  }
  .compass-link[data-index='1'] {
    transform: rotate(60deg) translateY(calc(-1 * var(--radius)));
  }
  .compass-link[data-index='2'] {
    transform: rotate(120deg) translateY(calc(-1 * var(--radius)));
  }
  .compass-link[data-index='3'] {
    transform: rotate(180deg) translateY(calc(-1 * var(--radius)));
  }
  .compass-link[data-index='4'] {
    transform: rotate(240deg) translateY(calc(-1 * var(--radius)));
  }
  .compass-link[data-index='5'] {
    transform: rotate(300deg) translateY(calc(-1 * var(--radius)));
  }

  .compass-link span {
    display: block;
    font-size: clamp(0.7rem, calc(var(--compass-size) / 25), 1.1rem);
    font-weight: 400;
    color: #1a1a1a;
    text-align: center;
    line-height: 1.3;
    padding: clamp(4px, calc(var(--compass-size) * 0.02), 12px);
    border-radius: 4px;
    text-shadow: 2px 2px 6px rgba(0, 0, 0, 0.2);
    transition:
      transform 0.2s ease,
      text-shadow 0.2s ease;
  }

  .compass-link:hover span {
    color: #c98b3a;
    transform: scale(1.05);
    text-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
  }

  .compass-link:hover img {
    opacity: 0.7;
  }

  img.image-link {
    display: block;
    width: clamp(25px, calc(var(--compass-size) / 8), 60px) !important;
    height: auto;
    margin: 0 auto clamp(4px, calc(var(--compass-size) * 0.015), 8px);
    opacity: 0.5;
  }

  /* --- MEDIA QUERIES BASÉES SUR HAUTEUR ET LARGEUR --- */

  /* Mobile landscape (hauteur faible, priorité compacité) */
  @media (max-height: 500px) {
    :root {
      --title-height: 80px;
      --compass-size: min(calc(100svh - 140px), 68vw);
    }

    .title-compass {
      font-size: 0.85rem;
    }

    .compass-main {
      padding-bottom: 0.5rem;
    }
  }

  /* Mobile portrait (hauteur moyenne) */
  @media (min-height: 500px) and (max-width: 767px) {
    :root {
      --compass-size: min(calc(var(--available-height) * 0.7), 75vw);
    }

    .title-compass {
      font-size: 1.25rem;
    }

    .compass-container {
      display: grid;
      grid-template-columns: 3fr 1fr 3fr;
    }
  }

  /* Tablette portrait ou desktop petit */
  @media (min-width: 768px) {
    :root {
      --title-height: 140px;
      --radius: calc(var(--compass-size) * 0.45);
    }

    .compass-main {
      width: 100%;
    }

    .compass-container {
      display: grid;
      grid-template-columns: 2fr 3fr 2fr;
    }

    .compass-left,
    .compass-right {
      display: block;
      background-size: 120%;
    }

    #compassRoseBg {
      background-size: 100%;
    }
  }

  /* Desktop avec hauteur confortable */
  @media (min-width: 768px) and (min-height: 800px) {
    :root {
      --compass-size: min(calc(var(--available-height) * 0.7), 500px);
    }

    .compass-container {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  /* Large desktop */
  @media (min-width: 1920px) {
    :root {
      --title-height: 180px;
      --compass-size: min(calc(var(--available-height) * 0.75), 650px);
    }
  }

  /* Très grande hauteur (ex: écran vertical) */
  @media (min-height: 1200px) {
    :root {
      --compass-size: min(60vh, 700px);
    }
  }
</style>
