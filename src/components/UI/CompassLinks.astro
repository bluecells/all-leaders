<div class="compass-main">
  <h3 class="text-center! w-full mx-auto max-w-4xl! md:pb-2 md:pt-0">
    Transformer les <strong>intentions en actions</strong> concrètes, pour des équipes agissant avec <strong
      >sens, clarté et impact.</strong
    >
  </h3>
  <div class="compass-container">
    <div class="compass-perspective-wrapper">
      <div class="compass-rose-bg" id="compassRoseBg"></div>
      <div class="compass-compass-fixed"></div>
      <div class="compass-orbit" id="compassOrbit">
        <a
          href="/accompagnements#category-gestion-de-la-conflictualite"
          class="compass-link"
          data-index="0"><span>🔗 Gestion de la<br />conflictualité</span></a
        >
        <a
          href="/accompagnements#category-diagnostic-de-la-performance"
          class="compass-link"
          data-index="1"><span>🔗 Diagnostic de la<br />performance</span></a
        >
        <a href="/accompagnements#category-executive-coaching" class="compass-link" data-index="2"
          ><span>🔗 Executive<br />coaching</span></a
        >
        <a
          href="/accompagnements#category-sante-mentale-et-performance-durable"
          class="compass-link"
          data-index="3"><span>🔗 Santé mentale et<br />performance durable</span></a
        >
        <a
          href="/accompagnements#category-leadership-development"
          class="compass-link"
          data-index="4"><span>🔗 Leadership<br />development</span></a
        >
        <a href="/accompagnements#category-coaching-equipe" class="compass-link" data-index="5"
          ><span>🔗 Coaching<br />d'équipe</span></a
        >
      </div>
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const orbit = document.getElementById('compassOrbit');
    const roseBg = document.getElementById('compassRoseBg');
    const spans = document.querySelectorAll('.compass-link span');
    const angleStep = 60; // 360 / 6 liens

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '.compass-main',
        start: 'top top',
        end: '+=100%',
        scrub: 1.5,
        pin: true,
        anticipatePin: 1,
      },
    });

    // Fond stable et fluide
    tl.to(
      roseBg,
      {
        rotation: 15,
        force3D: true,
        ease: 'none',
      },
      0
    );

    // Rotation de l'orbite
    tl.to(
      orbit,
      {
        rotation: 120,
        ease: 'none',
      },
      0
    );

    // Contre-rotation des textes pour rester lisibles
    spans.forEach((span, i) => {
      const startAngle = i * angleStep;
      gsap.set(span, { rotation: -startAngle });

      tl.to(
        span,
        {
          rotation: -(120 + startAngle),
          ease: 'none',
        },
        0
      );
    });
  });
</script>

