    height: 70vh;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid #121010;
  }

  .compass-perspective-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* SOLUTION : Carré géant centré */
  .compass-rose-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    /* Utilisation de vmax pour être sûr que le carré dépasse du rectangle de l'écran */
    width: 130vmax;
    height: 130vmax;
    /* Le centrage est crucial ici */
    transform: translate(-50%, -50%);
    opacity: 0.6;

    background-image: url('/images/pages/carte-marine.webp');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    background-size: 110%;
