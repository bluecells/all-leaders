---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: Array<{
    image: string | ImageMetadata;
    alt: string;
  }>;
  height?: string;
  speed?: number;
  background?: string;
  spacing?: string;
  title?: string;
  visibleItemsMobile?: number;
  visibleItemsDesktop?: number;
}

const {
  images,
  height = '20vh',
  speed = 1000, // Vitesse de base par image
  background = 'transparent',
  spacing = '1rem',
  title,
  visibleItemsMobile = 1,
  visibleItemsDesktop = 5,
} = Astro.props;

const limitedImages = images.slice(0, 10);
const duplicatedImages = [...limitedImages, ...limitedImages];
---

<section class="carousel full-bleed" style={`background-color: ${background};`}>
  <h3 style="text-align: center;" set:html={title} />
  <div class="carousel-track-container" style={`height: ${height};`}>
    <div
      id="generic-track"
      class="carousel-track"
      style={`--spacing: ${spacing}; --speed: ${speed * limitedImages.length}ms; --visible-mobile: ${visibleItemsMobile}; --visible-desktop: ${visibleItemsDesktop};`}
    >
      {
        duplicatedImages.map((image) => (
          <div class="carousel-item">
            {typeof image.image === 'string' ? (
              <img src={image.image} alt={image.alt} loading="lazy" draggable="false" />
            ) : (
              <Image
                src={image.image}
                alt={image.alt}
                width={1920}
                height={1080}
                widths={[400, 800, 1200, 1920]}
                sizes="(max-width: 768px) 100vw, 20vw"
                format="webp"
                loading="lazy"
                decoding="async"
                class="carousel-image"
              />
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ========================================
     MOBILE FIRST
     ======================================== */

  .carousel {
    cursor: grab;
    user-select: none;
    width: 100vw;
    margin-left: calc(-41vw + 50%);
    padding-top: 1rem;
    padding-bottom: 1rem;
    overflow: hidden;
  }

  .carousel:active {
    cursor: grabbing;
  }

  .carousel-track-container {
    width: 100vw;
    position: relative;
    touch-action: pan-y;
    height: 20vh;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: var(--spacing);
    height: 100%;
    width: max-content;
    will-change: transform;
  }

  .carousel-item {
    height: 100%;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: 4px;
    width: calc((100vw / var(--visible-mobile)) - var(--spacing));
    aspect-ratio: 16 / 9;
  }

  .carousel-item img,
  .carousel-item .carousel-image {
    height: 100%;
    width: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none; /* Empêche l'arrachage de l'image */
    transition: transform 0.5s ease;
  }

  .carousel-item:hover img,
  .carousel-item:hover .carousel-image {
    transform: scale(1.1);
  }

  /* ========================================
     DESKTOP
     ======================================== */
  @media (min-width: 768px) {
    .carousel {
      padding: 0 0 3rem 0;
    }

    .carousel-track-container {
      height: 20vh;
    }

    .carousel-item {
      width: calc((100vw / var(--visible-desktop)) - var(--spacing));
    }
  }
</style>

<script>
  const track = document.getElementById('generic-track');
  if (track) {
    const rawSpeed = track.style.getPropertyValue('--speed');
    const duration = parseInt(rawSpeed) || 30000;

    let animation: Animation | null = null;
    let isDragging = false;
    let startX = 0;
    let startCurrentTime = 0;

    // Initialiser l'animation (pausée initialement)
    const initAnimation = () => {
      if (!animation) {
        animation = track.animate(
          [{ transform: 'translateX(0px)' }, { transform: 'translateX(-50%)' }],
          {
            duration: duration,
            iterations: Infinity,
            easing: 'linear',
          }
        );
        animation.pause(); // Démarrer en pause
      }
    };

    // Gestionnaires pour le drag
    const startDrag = (e: MouseEvent | TouchEvent) => {
      if (!animation) return;
      isDragging = true;
      animation.pause();

      const x = e instanceof MouseEvent ? e.pageX : e.touches[0].pageX;
      startX = x;
      startCurrentTime = Number(animation.currentTime) || 0;
    };

    const moveDrag = (e: MouseEvent | TouchEvent) => {
      if (!isDragging || !animation) return;

      const x = e instanceof MouseEvent ? e.pageX : e.touches[0].pageX;
      const walk = x - startX;

      const trackWidth = track.scrollWidth / 2;
      const timeOffset = (walk / trackWidth) * duration;

      let newTime = Number(startCurrentTime) - timeOffset;

      if (newTime < 0) newTime += duration;
      if (newTime > duration) newTime -= duration;

      animation.currentTime = newTime;
    };

    const stopDrag = () => {
      if (!isDragging || !animation) return;
      isDragging = false;
      animation.play();
    };

    // Intersection Observer pour détecter l'entrée dans le viewport
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Le carousel rentre dans le viewport
            initAnimation();
            if (!isDragging && animation) {
              animation.play();
            }
          } else {
            // Le carousel sort du viewport
            if (animation && !isDragging) {
              animation.pause();
            }
          }
        });
      },
      { threshold: 0.1 } // Déclenche quand 10% du carousel est visible
    );

    observer.observe(track);

    // Events Souris
    track.addEventListener('mousedown', startDrag);
    window.addEventListener('mousemove', moveDrag);
    window.addEventListener('mouseup', stopDrag);

    // Events Tactile
    track.addEventListener('touchstart', startDrag, { passive: false });
    window.addEventListener('touchmove', moveDrag, { passive: false });
    window.addEventListener('touchend', stopDrag);

    // Pause au hover si on ne drag pas
    track.addEventListener('mouseenter', () => {
      if (!isDragging && animation) animation.pause();
    });
    track.addEventListener('mouseleave', () => {
      if (!isDragging && animation) animation.play();
    });
  }
</script>
