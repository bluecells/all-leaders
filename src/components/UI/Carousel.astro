---
interface Props {
  images: Array<{
    image: string;
    alt: string;
  }>;
  height?: string;
  speed?: number;
  background?: string;
  spacing?: string;
  title?: string;
}

const {
  images,
  height = '30vh',
  speed = 1000, // Vitesse de base par image
  background = 'transparent',
  spacing = '1rem',
  title,
} = Astro.props;

const limitedImages = images.slice(0, 10);
const duplicatedImages = [...limitedImages, ...limitedImages];
---

<section class="carousel full-bleed" style={`background-color: ${background};`}>
  <h3 style="text-align: center;" set:html={title} />
  <div class="carousel-track-container" style={`height: ${height};`}>
    <div
      id="generic-track"
      class="carousel-track"
      style={`--spacing: ${spacing}; --speed: ${speed * limitedImages.length}ms;`}
    >
      {
        duplicatedImages.map((image) => (
          <div class="carousel-item">
            <img src={image.image} alt={image.alt} loading="lazy" draggable="false" />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ========================================
     MOBILE FIRST
     ======================================== */

  .carousel {
    overflow: hidden;
    padding: 2rem 0;
    cursor: grab;
    user-select: none;
  }

  .carousel:active {
    cursor: grabbing;
  }

  .carousel-track-container {
    width: 100%;
    position: relative;
    touch-action: pan-y;
    height: 20vh;
  }

  .carousel-track {
    display: flex;
    gap: var(--spacing);
    height: 100%;
    width: max-content;
    will-change: transform;
  }

  .carousel-item {
    height: 100%;
    flex-shrink: 0;
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    background: #f0f0f0;
    /* Aspect ratio optionnel pour garder une cohérence si les images varient */
    aspect-ratio: 16 / 9;
  }

  .carousel-item img {
    height: 100%;
    width: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none; /* Empêche l'arrachage de l'image */
    transition: transform 0.5s ease;
  }

  .carousel-item:hover img {
    transform: scale(1.1);
  }

  /* ========================================
     DESKTOP
     ======================================== */
  @media (min-width: 769px) {
    .carousel {
      padding: 3rem 0;
    }

    .carousel-track-container {
      height: 30vh;
    }
  }
</style>

<script>
  const track = document.getElementById('generic-track');
  if (track) {
    const rawSpeed = track.style.getPropertyValue('--speed');
    const duration = parseInt(rawSpeed) || 30000;

    // Initialisation de l'animation WAAPI
    const animation = track.animate(
      [{ transform: 'translateX(0px)' }, { transform: 'translateX(-50%)' }],
      {
        duration: duration,
        iterations: Infinity,
        easing: 'linear',
      }
    );

    let isDragging = false;
    let startX = 0;
    let startCurrentTime = 0;

    const startDrag = (e: MouseEvent | TouchEvent) => {
      isDragging = true;
      animation.pause();

      const x = e instanceof MouseEvent ? e.pageX : e.touches[0].pageX;
      startX = x;

      // On capture le temps actuel de l'animation
      startCurrentTime = Number(animation.currentTime) || 0;
    };

    const moveDrag = (e: MouseEvent | TouchEvent) => {
      if (!isDragging) return;

      const x = e instanceof MouseEvent ? e.pageX : e.touches[0].pageX;
      const walk = x - startX;

      // Calcul du décalage temporel basé sur la distance scrollée
      // On divise la largeur par 2 car le contenu est doublé
      const trackWidth = track.scrollWidth / 2;
      const timeOffset = (walk / trackWidth) * duration;

      let newTime = Number(startCurrentTime) - timeOffset;

      // Boucle infinie temporelle
      if (newTime < 0) newTime += duration;
      if (newTime > duration) newTime -= duration;

      animation.currentTime = newTime;
    };

    const stopDrag = () => {
      if (!isDragging) return;
      isDragging = false;
      animation.play(); // Reprise fluide sans saut
    };

    // Events Souris
    track.addEventListener('mousedown', startDrag);
    window.addEventListener('mousemove', moveDrag);
    window.addEventListener('mouseup', stopDrag);

    // Events Tactile
    track.addEventListener('touchstart', startDrag, { passive: false });
    window.addEventListener('touchmove', moveDrag, { passive: false });
    window.addEventListener('touchend', stopDrag);

    // Pause au hover si on ne drag pas
    track.addEventListener('mouseenter', () => {
      if (!isDragging) animation.pause();
    });
    track.addEventListener('mouseleave', () => {
      if (!isDragging) animation.play();
    });
  }
</script>
