---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="All Leaders - Content Management"
  description="Access the All Leaders content management interface"
  lang="en"
  alternateUrls={{ fr: '/edit', en: '/en/edit' }}
>
  <main class="min-h-screen bg-white">
    <div class="container py-16">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h1 class="text-4xl text-left! font-bold text-gray-900 mb-4">Welcome to All Leaders</h1>
          <h2 class="text-xl mt-0! pt-0! text-gray-600">
            Coachin in collective performance and leadership
          </h2>
          <p class="mt-6 text-gray-600">
            Click on the « Admin » link to access Keystatic portal and manage content.
          </p>
        </div>
        <a
          href="/keystatic"
          target="_blank"
          class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
        >
          Admin
        </a>
        <a
          href="en/admin/seo"
          target="_blank"
          class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
        >
          SEO checker
        </a>
      </div>
    </div>
  </main>
</Layout>
