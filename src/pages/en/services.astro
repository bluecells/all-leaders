---
import Layout from '../../layouts/Layout.astro';
import ActionBar from '../../components/ActionBar.astro';
import Accompagnements from '../../components/Accompagnements.astro';
---

<Layout
  title="Services - All Leaders"
  metaTitle="Our services - All Leaders Initiative"
  metaDescription="Discover our services in performance diagnostics, training, coaching and consulting."
  lang="en"
>
  <div class="mx-auto px-4 py-12">
    <h1 class="font-serif text-limolo-green mb-8 text-center">Our services</h1>
    <h2>Diagnostic and development solutions for your organizations</h2>
    <!-- Accompagnements Component -->
    <Accompagnements lang="en" fullBleed={true} />
  </div>

  <ActionBar />
</Layout>

<style>
  h1 {
    margin-bottom: 0;
    padding-bottom: 1rem;
  }
  h2 {
    margin: 0 !important;
    padding: 0 0 2rem !important;
    max-width: 100%;
    text-align: center;
    font-size: large;
  }
</style>
