---

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  try {
    gsap.registerPlugin(ScrollTrigger);
  } catch (e) {
    console.error('Issue with ScrollTrigger installation:', e);
  }

  function animateHero() {
    const heroTitle = document.querySelector('.hero-title');
    const heroQuestion = document.querySelector('.hero-question');
    const heroQuoteWrapper = document.querySelector('.hero-quote-wrapper');

    // Basic Hero animation (without matchMedia for testing)
    if (heroTitle) {
      gsap.fromTo(heroTitle, { autoAlpha: 0 }, { autoAlpha: 1, duration: 0.6 });
    }

    if (heroQuestion) {
      gsap.fromTo(heroQuestion, { autoAlpha: 0 }, { autoAlpha: 1, duration: 1, delay: 0.6 });
    }

    // ScrollTrigger animation
    if (heroQuoteWrapper) {
      gsap.fromTo(
        heroQuoteWrapper,
        { autoAlpha: 0, y: 50 },
        {
          autoAlpha: 1,
          y: 0,
          duration: 1.2,
          scrollTrigger: {
            trigger: heroQuoteWrapper,
            start: '20% 85%',
            toggleActions: 'play none none none',
          },
        }
      );
    }
  }

  // Compatible with or without Astro ViewTransitions
  document.addEventListener('astro:page-load', animateHero);
  window.addEventListener('DOMContentLoaded', animateHero);
  ScrollTrigger.refresh();
</script>

<Layout
