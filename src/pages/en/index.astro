  <style>
    /* ==========================================
     HERO SECTION — GSAP Animation
  =========================================== */

    .hero-section {
      position: relative;
      height: calc(100vh - 44px);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }

    .hero-title {
      position: relative;
      text-align: center;
      width: 100%;
      max-width: 900px;
      padding: 0;
      margin: 0;
      z-index: 2;
      font-size: 2rem;
    }

    /* 1. Declare the variables so the browser knows to animate them smoothly */
    @property --x1 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 25%;
    }
    @property --y1 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 85%;
    }
    @property --x2 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 55%;
    }
    @property --y2 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 85%;
    }
    @property --x3 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 35%;
    }
    @property --y3 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 85%;
    }

    .halos-confines {
      width: 100%;
      background-color: #ffffff; /* Imposed white background */

      /* Absolute safety: nothing visually overflows */
      overflow: hidden;
      position: relative;

      /* 3 restricted radial halos (they stop at 25% or 30% max of their size) */
      background-image:
        radial-gradient(
          circle at var(--x1, 20%) var(--y1, 20%),
          rgba(255, 182, 193, 0.4),
          transparent 25%
        ),
        radial-gradient(
          circle at var(--x2, 25%) var(--y2, 30%),
          rgba(173, 216, 230, 0.4),
          transparent 20%
        ),
        radial-gradient(
