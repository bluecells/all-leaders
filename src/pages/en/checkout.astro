---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Payment - All Leaders"
  lang="en"
  metaTitle="Payment - Booking Engine"
  metaDescription="Online Booking - Redirection to the All Leaders booking engine"
>
  <div id="loader">
    <h1>Redirecting to the booking system...</h1>
    <div class="spinner"></div>

    <!-- Correct link with final URL -->
    <a id="booking-link" href="https://www.bed-and-breakfast.it/en/booking/sardinia/limolo-house-56-green-cabras/57031"
      >Go to All Leaders booking engine</a
    >
  </div>
</Layout>

<script>
  const regionLabels: Record<string, string> = {
    it: 'sardegna',
    fr: 'sardaigne',
    en: 'sardinia',
  };

  const lang = 'en';
  const region = regionLabels[lang];

  const targetUrl = `https://www.bed-and-breakfast.it/${lang}/booking/${region}/limolo-house-56-green-cabras/57031`;

  const link = document.getElementById('booking-link');
  if (link) {
    (link as HTMLAnchorElement).href = targetUrl;
  }

  setTimeout(() => {
    window.location.href = targetUrl;
  }, 800);
</script>

<style>
  #loader {
    text-align: center;
    padding: 4rem 1rem;
    max-width: 600px;
    margin: 0 auto;
  }
  h1 {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
    color: #6b705c;
  }
  .spinner {
    margin: 2rem auto;
    width: 50px;
    height: 50px;
    border: 5px solid #e0d9d1;
    border-top-color: #6b705c;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  #booking-link {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.8rem 1.5rem;
    background: #6b705c;
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: bold;
  }
  #booking-link:hover {
    background: #8a9a7a;
  }
</style>
