---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const [articles, landingPages, services, faq] = await Promise.all([
  getCollection('articles'),
  getCollection('landing-pages'),
  getCollection('services'),
  getCollection('faq'),
]);

// Fonction helper pour extraire le titre selon le type de collection
const getTitle = (data: Record<string, unknown>): string => {
  if ('title' in data && typeof data.title === 'string') return data.title;
  if ('nameDisplay' in data && typeof data.nameDisplay === 'string') return data.nameDisplay;
  if ('question' in data && typeof data.question === 'string') return data.question;
  return 'N/A';
};

// Fonction helper pour extraire la catégorie (seulement pour articles)
const getCategory = (data: Record<string, unknown>): string => {
  if ('category' in data && typeof data.category === 'string') return data.category;
  return '';
};

// Fonction helper pour obtenir la classe de surligné pour metaTitle
const getMetaTitleClass = (text: string): { className: string; displayText: string } => {
  if (text.includes('❌')) {
    return { className: 'highlight-red', displayText: text };
  }
  const len = text.length;
  if (len > 60) {
    return { className: 'highlight-red-bright', displayText: `${text} (${len})` };
  }
  if (len < 40 || len > 60) {
    return { className: 'highlight-yellow', displayText: `${text} (${len})` };
  }
  return { className: 'highlight-green', displayText: `${text} (${len})` };
};

// Fonction helper pour obtenir la classe de surligné pour metaDescription
const getMetaDescriptionClass = (text: string): { className: string; displayText: string } => {
  if (text.includes('❌')) {
    return { className: 'highlight-red', displayText: text };
  }
  const len = text.length;
  if (len > 155) {
    return { className: 'highlight-red-bright', displayText: `${text} (${len})` };
  }
  if (len < 122 || len > 155) {
    return { className: 'highlight-yellow', displayText: `${text} (${len})` };
  }
  return { className: 'highlight-green', displayText: `${text} (${len})` };
};

// Fonction pour déterminer l'état SEO (complete, partial, incomplete)
const getSeoStatus = (
  metaTitle: string,
  metaDescription: string
): 'complete' | 'partial' | 'incomplete' => {
  // Incomplet : manque metaTitle OU metaDescription
  if (metaTitle.includes('❌') || metaDescription.includes('❌')) {
    return 'incomplete';
  }

  // Partiel : hors du range optimal pour metaTitle (40-60 chars)
  const titleLen = metaTitle.length;
  if (titleLen < 40 || titleLen > 60) {
    return 'partial';
  }

  // Partiel : hors du range optimal pour metaDescription (122-155 chars)
  const descLen = metaDescription.length;
  if (descLen < 122 || descLen > 155) {
    return 'partial';
  }

  // Complet : tous les critères respectés
  return 'complete';
};

const allEntries = [
  ...articles.map((e) => ({ ...e, type: 'Article' as const })),
  ...landingPages.map((e) => ({ ...e, type: 'Page' as const })),
  ...services.map((e) => ({ ...e, type: 'Room' as const })),
  ...faq.map((e) => ({ ...e, type: 'FAQ' as const })),
].map((entry) => {
  const lang = entry.data.lang || 'it';
  const seoSlug = entry.data.seoSlug as string | undefined;
  const metaTitle = entry.data.metaTitle as string | undefined;
  const metaDescription = entry.data.metaDescription as string | undefined;

  const cleanSlug = (seoSlug || entry.id.split('/').pop())?.replace(/^\/|\/$/g, '');

  // --- CALCUL DE LA ROUTE FINALE ---
  let finalPath = '';
  const langPrefix = lang === 'it' ? '' : `/${lang}`;

  if (entry.type === 'Article') {
    const category = getCategory(entry.data as Record<string, unknown>);
    const resourcesSegment = lang === 'fr' ? 'ressources' : 'resources';
    finalPath = lang === 'fr'
      ? `/${resourcesSegment}/${category}/${cleanSlug}`
      : `/${lang}/${resourcesSegment}/${category}/${cleanSlug}`;
  } else if (entry.type === 'Room') {
    finalPath = lang === 'fr'
      ? `/services/${cleanSlug}`
      : `/${lang}/services/${cleanSlug}`;
  } else if (entry.type === 'Page') {
    // Les landing pages (gérées via contenu)
    finalPath = lang === 'fr'
      ? `/${cleanSlug}`
      : `/${lang}/${cleanSlug}`;
  } else if (entry.type === 'FAQ') {
    finalPath = lang === 'fr'
      ? `/faq/${cleanSlug}`
      : `/${lang}/faq/${cleanSlug}`;
  }

  finalPath = finalPath.replace(/\/+/g, '/');

  // --- CALCUL DES CLASSES POUR META FIELDS ---
  const metaTitleText = metaTitle || '❌ Mancante';
  const metaDescriptionText = metaDescription || '❌ Mancante';
  const metaTitleHighlight = getMetaTitleClass(metaTitleText);
  const metaDescriptionHighlight = getMetaDescriptionClass(metaDescriptionText);

  // --- CALCUL DE L'ÉTAT SEO ---
  const seoStatus = getSeoStatus(metaTitleText, metaDescriptionText);

  // --- RETOUR DES DONNÉES COMPLETES ---
  return {
    lang,
    type: entry.type,
    title: getTitle(entry.data as Record<string, unknown>),
    metaTitle: metaTitleText,
    metaTitleClass: metaTitleHighlight.className,
    metaTitleDisplay: metaTitleHighlight.displayText,
    metaDescription: metaDescriptionText,
    metaDescriptionClass: metaDescriptionHighlight.className,
    metaDescriptionDisplay: metaDescriptionHighlight.displayText,
    seoStatus,
    computedRoute: finalPath || '/',
    filePath: entry.id,
  };
});

// Tri pour une lecture plus facile
allEntries.sort((a, b) => a.lang.localeCompare(b.lang) || a.type.localeCompare(b.type));
---

<Layout title="Audit SEO - Toutes les pages">
  <main style="padding: 2rem; font-family: sans-serif;">
    <h1>Audit SEO delle collezioni</h1>

    <!-- FILTRES ÉVOLUÉS (COMPACTS) -->
    <div
      id="filters"
      style="background: #f9f9f9; padding: 0.75rem; border-radius: 6px; margin-bottom: 1.5rem; border: 1px solid #ddd; font-size: 0.85rem;"
    >
      <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
        <!-- Filtre Langue -->
        <select
          id="filterLang"
          style="padding: 0.35rem 0.5rem; border: 1px solid #ccc; border-radius: 3px; font-size: 0.85rem;"
        >
          <option value="">Lingua</option>
          <option value="it">🇮🇹 IT</option>
          <option value="fr">🇫🇷 FR</option>
          <option value="en">🇬🇧 EN</option>
        </select>

        <!-- Filtre Type -->
        <select
          id="filterType"
          style="padding: 0.35rem 0.5rem; border: 1px solid #ccc; border-radius: 3px; font-size: 0.85rem;"
        >
          <option value="">Tipo</option>
          <option value="Article">Articolo</option>
          <option value="Page">Page</option>
          <option value="Room">Room</option>
          <option value="FAQ">FAQ</option>
        </select>

        <!-- Filtre État SEO -->
        <select
          id="filterSeo"
          style="padding: 0.35rem 0.5rem; border: 1px solid #ccc; border-radius: 3px; font-size: 0.85rem;"
        >
          <option value="">Status SEO</option>
          <option value="complete">✅ Complet</option>
          <option value="partial">⚠️ Parziale</option>
          <option value="incomplete">❌ Mancante</option>
        </select>

        <!-- Recherche Texte -->
        <input
          type="text"
          id="filterSearch"
          placeholder="Rechercher..."
          style="padding: 0.35rem 0.5rem; border: 1px solid #ccc; border-radius: 3px; font-size: 0.85rem; min-width: 150px;"
        />

        <!-- Bouton Réinitialiser -->
        <button
          id="resetFilters"
          style="padding: 0.35rem 0.75rem; color: white; border: none; border-radius: 3px; cursor: pointer; font-weight: bold; font-size: 1.4rem;"
        >
          🔄
        </button>

        <!-- Compteur -->
        <span style="margin-left: auto; color: #666; font-size: 0.8rem;">
          <strong id="visibleCount">{allEntries.length}</strong> / {allEntries.length} items
        </span>
      </div>

      <!-- LEGENDE -->

      <div class="flex gap-4 mt-2">
        <span class=""><b>Codici colore</b></span>
        <span class="highlight-yellow">troppo corto</span>
        <span class="highlight-green">ottimale</span>
        <span class="highlight-red">troppo lungo</span>
      </div>
    </div>

    <!-- TABLE -->
    <div class="full-bleed text-xs" style="overflow-x: auto;">
      <table
        border="1"
        style="width: 100%; border-collapse: collapse; text-align: left;"
        id="seoTable"
      >
        <thead>
          <tr style="background: #f4f4f4;">
            <th style="padding: 6px; min-width:60px; cursor: pointer;" data-sort="lang">Ling ▼</th>
            <th style="padding: 6px; min-width:60px; cursor: pointer;" data-sort="type">Tipo ▼</th>
            <th style="padding: 6px; cursor: pointer;" data-sort="title">Titre Page ▼</th>
            <th style="padding: 6px; cursor: default;">Meta Title (40-60 car.)</th>
            <th style="padding: 6px;">Meta Description (122-155 car.)</th>
            <th style="padding: 6px;">URL Finale</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          {
            allEntries.map((item) => (
              <tr
                class="table-row"
                data-lang={item.lang}
                data-type={item.type}
                data-seo={item.seoStatus}
                data-title={item.title}
                data-url={item.computedRoute}
              >
                <td style="padding: 6px;">
                  <code>{item.lang}</code>
                </td>
                <td style="padding: 6px;">{item.type}</td>
                <td style="padding: 6px;">{item.title}</td>
                <td style="padding: 6px;">
                  <span class={item.metaTitleClass}>{item.metaTitleDisplay}</span>
                </td>
                <td style="padding: 6px; max-width: 500px;">
                  <span class={item.metaDescriptionClass}>{item.metaDescriptionDisplay}</span>
                </td>
                <td style="padding: 6px;">
                  <a
                    href={item.computedRoute}
                    target="_blank"
                    style="color: #007bff; text-decoration: none; font-size:smaller;"
                  >
                    <code>{item.computedRoute}</code>
                  </a>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </main>

  <script>
    const rows = Array.from(document.querySelectorAll('.table-row'));
    const filterLang = document.getElementById('filterLang');
    const filterType = document.getElementById('filterType');
    const filterSeo = document.getElementById('filterSeo');
    const filterSearch = document.getElementById('filterSearch');
    const resetBtn = document.getElementById('resetFilters');
    const visibleCount = document.getElementById('visibleCount');
    const tableBody = document.getElementById('tableBody');
    const sortHeaders = document.querySelectorAll('th[data-sort]');

    let currentSort = { field: null, direction: 'asc' };

    function applyFilters() {
      let visible = 0;
      const searchTerm = filterSearch.value.toLowerCase();

      rows.forEach((row) => {
        const lang = row.dataset.lang;
        const type = row.dataset.type;
        const seo = row.dataset.seo;
        const title = row.dataset.title.toLowerCase();
        const url = row.dataset.url.toLowerCase();

        const langMatch = !filterLang.value || lang === filterLang.value;
        const typeMatch = !filterType.value || type === filterType.value;
        const seoMatch = !filterSeo.value || seo === filterSeo.value;
        const searchMatch = !searchTerm || title.includes(searchTerm) || url.includes(searchTerm);

        const show = langMatch && typeMatch && seoMatch && searchMatch;
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      visibleCount.textContent = visible;
    }

    function updateSortIndicators() {
      sortHeaders.forEach((header) => {
        const baseText = header.textContent.replace(/[▲▼]/g, '').trim();
        if (header.dataset.sort === currentSort.field) {
          const indicator = currentSort.direction === 'asc' ? '▲' : '▼';
          header.textContent = baseText + ' ' + indicator;
          header.style.fontWeight = 'bold';
          header.style.backgroundColor = '#e8f4f8';
        } else {
          header.textContent = baseText + ' ▼';
          header.style.fontWeight = 'normal';
          header.style.backgroundColor = 'inherit';
        }
      });
    }

    function sortTable(field) {
      if (currentSort.field === field) {
        currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
      } else {
        currentSort.field = field;
        currentSort.direction = 'asc';
      }

      const visibleRows = rows.filter((row) => row.style.display !== 'none');

      visibleRows.sort((a, b) => {
        let aVal = a.dataset[field];
        let bVal = b.dataset[field];

        if (field === 'lang' || field === 'type' || field === 'title') {
          return currentSort.direction === 'asc'
            ? aVal.localeCompare(bVal)
            : bVal.localeCompare(aVal);
        }
        return 0;
      });

      visibleRows.forEach((row) => tableBody.appendChild(row));
      updateSortIndicators();
    }

    sortHeaders.forEach((header) => {
      header.addEventListener('click', () => {
        const field = header.dataset.sort;
        sortTable(field);
      });
    });

    filterLang.addEventListener('change', applyFilters);
    filterType.addEventListener('change', applyFilters);
    filterSeo.addEventListener('change', applyFilters);
    filterSearch.addEventListener('input', applyFilters);

    resetBtn.addEventListener('click', () => {
      filterLang.value = '';
      filterType.value = '';
      filterSeo.value = '';
      filterSearch.value = '';
      applyFilters();
    });
  </script>
</Layout>

<style>
  table tr:nth-child(even) {
    background: #fafafa;
  }
  table th {
    position: sticky;
    top: 0;
    background: #eee;
    z-index: 10;
    padding: 6px;
  }
  code {
    background: #eee;
    padding: 2px 4px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  /* Styles de surlignage */
  .highlight-yellow {
    position: relative;
    display: inline-block;
    z-index: 1;
  }
  .highlight-yellow::before {
    content: '';
    position: absolute;
    inset: 0.1em -0.3em;
    background-color: #ffd64f3d;
    border-radius: 0.2rem;
    z-index: -1;
  }

  .highlight-green {
    position: relative;
    display: inline-block;
    z-index: 1;
  }
  .highlight-green::before {
    content: '';
    position: absolute;
    inset: 0.1em -0.3em;
    background-color: #a8f5a83e;
    border-radius: 0.2rem;
    z-index: -1;
  }

  .highlight-red {
    position: relative;
    display: inline-block;
    z-index: 1;
  }
  .highlight-red::before {
    content: '';
    position: absolute;
    inset: 0.1em -0.3em;
    background-color: #ffcccc42;
    border-radius: 0.2rem;
    z-index: -1;
  }

  .highlight-red-bright {
    position: relative;
    display: inline-block;
    z-index: 1;
  }
  .highlight-red-bright::before {
    content: '';
    position: absolute;
    inset: 0.1em -0.3em;
    background-color: #ff999945;
    border-radius: 0.2rem;
    z-index: -1;
  }
</style>
