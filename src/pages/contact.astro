---
import Layout from '../layouts/Layout.astro';
import ActionBar from '../components/ActionBar.astro';
---

<Layout
  title="Contacter All Leaders Initiative"
  metaTitle="Contacter All Leaders Initiative"
  metaDescription="N'hésitez pas à contacter All Leaders Initiative pour toutes questions relatives aux accompagnements et à leur logistique."
  lang="fr"
>
  <div class="mx-auto max-w-4xl px-4 py-12">
    <!-- Titre principal -->
    <h1 class="font-serif text-limolo-green text-4xl mb-4 text-center">
      Contacter All Leaders Initiative
    </h1>

    <!-- Description -->
    <p class="text-center text-gray-700 mb-12 text-lg">
      N'hésitez pas à nous contacter pour toutes questions relatives aux accompagnements et à leur logistique.
    </p>

    <!-- Section d'invitation -->
    <div class="bg-gray-50 rounded-lg p-8 mb-12">
      <h2 class="font-serif text-limolo-green text-2xl mb-4">
        Rencontrons-nous pour parler des challenges qui vous animent !
      </h2>
      <p class="text-gray-700 leading-relaxed">
        Nos équipes sont à votre écoute pour discuter des défis professionnels qui vous occupent et vous proposer des solutions adaptées à vos besoins.
      </p>
    </div>

    <!-- Contacts directs -->
    <div class="mb-12">
      <h2 class="font-serif text-limolo-green text-2xl mb-8">Contacts directs</h2>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Marie Emmanuelle PY -->
        <div class="border border-gray-200 rounded-lg p-6 hover:shadow-md transition-shadow">
          <h3 class="text-xl font-bold text-limolo-green mb-2">
            Marie Emmanuelle PY
          </h3>
          <p class="text-sm text-gray-600 mb-4">Associée fondatrice</p>

          <div class="space-y-3">
            <div>
              <a
                href="mailto:me@all-leaders.fr"
                class="text-limolo-green hover:text-limolo-accent transition-colors font-semibold"
              >
                ✉ me@all-leaders.fr
              </a>
            </div>
            <div>
              <a
                href="tel:+33603555452"
                class="text-limolo-green hover:text-limolo-accent transition-colors font-semibold"
              >
                ☎ +33 6 03 55 54 52
              </a>
            </div>
            <div class="pt-4 border-t border-gray-200">
              <a
                href="https://calendly.com/all-leaders"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block px-4 py-2 bg-limolo-green text-white rounded hover:bg-limolo-accent transition-colors text-sm font-semibold"
              >
                Réserver un entretien gratuit
              </a>
            </div>
          </div>
        </div>

        <!-- Pierre-Etienne BOST -->
        <div class="border border-gray-200 rounded-lg p-6 hover:shadow-md transition-shadow">
          <h3 class="text-xl font-bold text-limolo-green mb-2">
            Pierre-Etienne BOST
          </h3>
          <p class="text-sm text-gray-600 mb-4">Associé fondateur</p>

          <div class="space-y-3">
            <div>
              <a
                href="mailto:pe@all-leaders.fr"
                class="text-limolo-green hover:text-limolo-accent transition-colors font-semibold"
              >
                ✉ pe@all-leaders.fr
              </a>
            </div>
            <div>
              <a
                href="tel:+33685540511"
                class="text-limolo-green hover:text-limolo-accent transition-colors font-semibold"
              >
                ☎ +33 6 85 54 05 11
              </a>
            </div>
            <div class="pt-4 border-t border-gray-200">
              <a
                href="https://calendly.com/all-leaders"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block px-4 py-2 bg-limolo-green text-white rounded hover:bg-limolo-accent transition-colors text-sm font-semibold"
              >
                Réserver un entretien gratuit
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Coordonnées générales -->
    <div class="bg-limolo-green bg-opacity-5 rounded-lg p-8">
      <h2 class="font-serif text-limolo-green text-2xl mb-6">Coordonnées générales</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <h3 class="font-bold text-gray-900 mb-2">Adresse</h3>
          <p class="text-gray-700">
            69, rue la Condamine<br/>
            75017 Paris<br/>
            France
          </p>
        </div>

        <div>
          <h3 class="font-bold text-gray-900 mb-2">Email</h3>
          <p>
            <a
              href="mailto:contact@all-leaders.fr"
              class="text-limolo-green hover:text-limolo-accent transition-colors"
            >
              contact@all-leaders.fr
            </a>
          </p>
        </div>

        <div>
          <h3 class="font-bold text-gray-900 mb-2">Téléphone</h3>
          <p>
            <a
              href="tel:+33685540511"
              class="text-limolo-green hover:text-limolo-accent transition-colors"
            >
              +33 6 85 54 05 11
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>

</Layout>

<style>
  h1 {
    line-height: 1.2;
  }
</style>
