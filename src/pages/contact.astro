---
import Layout from '../layouts/Layout.astro';
import ActionBar from '../components/ActionBar.astro';
---

<Layout
  title="Contacter All Leaders Initiative"
  metaTitle="Contacter All Leaders Initiative"
  metaDescription="N'hésitez pas à contacter All Leaders Initiative pour toutes questions relatives aux accompagnements et à leur logistique."
  lang="fr"
>
  <div class="mx-auto max-w-4xl px-4 py-12">
    <!-- Titre principal -->
    <h1 class="font-serif text-limolo-green mb-4 text-center">
      Contacter All Leaders Initiative
    </h1>

  <!-- ==========================================
         SECTION 4 — Fondateurs
    =========================================== -->
    <section id="fondateurs" aria-labelledby="h2-fondateurs">
      <div class="container">

        <h2 id="h2-fondateurs" class="text-center! mt-0! mt-8">
          <strong>Deux fondateurs</strong>, une vision commune du <strong>leadership basé sur l'intention</strong>
        </h2>

        <p class="text-center! mt-4">
          Forts de nos différences et de nos complémentarités, nous sommes garants de la qualité
          et de l'engagement des professionnels que nous rassemblons au service de vos objectifs.
        </p>

        <div class="founders-grid" role="list">

          <article role="listitem" itemscope itemtype="https://schema.org/Person">
            <h3 itemprop="name">Marie Emmanuelle PY</h3>
            <p itemprop="jobTitle">Associée fondatrice</p>
            <ul class="contact-list">
              <li>
                <a href="mailto:me@all-leaders.fr" itemprop="email" aria-label="Envoyer un email à Marie Emmanuelle Py">
                  me@all-leaders.fr
                </a>
              </li>
              <li>
                <a href="tel:+33603555452" itemprop="telephone" aria-label="Appeler Marie Emmanuelle Py">
                  +33 6 03 55 54 52
                </a>
              </li>
              <li>
                <a href="#" rel="noopener noreferrer" target="_blank" aria-label="Profil LinkedIn de Marie Emmanuelle Py">
                  LinkedIn
                </a>
              </li>
              <li>
                <a href="#" rel="noopener noreferrer" target="_blank" aria-label="Profil complet de Marie Emmanuelle Py">
                  Profil complet
                </a>
              </li>
            </ul>
          </article>

          <article role="listitem" itemscope itemtype="https://schema.org/Person">
            <h3 itemprop="name">Pierre-Etienne BOST</h3>
            <p itemprop="jobTitle">Associé fondateur</p>
            <ul class="contact-list">
              <li>
                <a href="mailto:pe@all-leaders.fr" itemprop="email" aria-label="Envoyer un email à Pierre-Etienne Bost">
                  pe@all-leaders.fr
                </a>
              </li>
              <li>
                <a href="tel:+33685540511" itemprop="telephone" aria-label="Appeler Pierre-Etienne Bost">
                  +33 6 85 54 05 11
                </a>
              </li>
              <li>
                <a href="#" rel="noopener noreferrer" target="_blank" aria-label="Profil LinkedIn de Pierre-Etienne Bost">
                  LinkedIn
                </a>
              </li>
              <li>
                <a href="#" rel="noopener noreferrer" target="_blank" aria-label="Profil complet de Pierre-Etienne Bost">
                  Profil complet
                </a>
              </li>
            </ul>
          </article>

        </div>

      </div>

              <p class="text-center! mt-8">
                Rencontrons-nous pour parler des challenges qui vous animent !
              </p>
    </section>

</Layout>

<style>
  h1 {
    line-height: 1.2;
  }

   /* ==========================================
     FONDATEURS — Layout 2 Colonnes
  =========================================== */

  .founders-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
    max-width: 800px;
    margin: auto;
  }

  .founders-grid article {
    padding: 1.5rem 1.5rem 1rem 1.5rem;
    border: 1px solid rgba(74, 103, 65, 0.2);
    border-radius: 0.5rem;
  }

  .founders-grid h1,
  .founders-grid h2,
  .founders-grid h3 {
    text-align: left;
  }

  .founders-grid h3 {
    margin: 0 0 0.5rem 0;
  }

  .founders-grid p {
    margin: 0 0 1rem 0;
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contact-list h1,
  .contact-list h2,
  .contact-list h3 {
    text-align: left;
  }

  .contact-list li {
    margin-bottom: 0.35rem;
    margin-left: -1rem;
  }

  .contact-list a {
    color: var(--color-brand-primary);
    text-decoration: none;
    transition: color 200ms;
  }

  .contact-list a:hover {
    color: var(--color-brand-accent);
  }

  /* Mode desktop : 2 colonnes */
  @media (min-width: 768px) {
    .founders-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  /* Values section avec images latérales */
  .values-section {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    margin-top: 3rem;
  }

  .values-image-left,
  .values-image-right {
    flex: 0 0 20%;
    max-height: 500px;
  }

  .values-image-left img,
  .values-image-right img {
    height: 100%;
  }

  .values-grid {
    flex: 1;
  }

  /* Mobile : images au-dessus en 50-50 */
  @media (max-width: 767px) {
    .values-section {
      flex-direction: column;
      gap: 1.5rem;
    }

    .values-image-left,
    .values-image-right {
      flex: 0 0 auto;
      max-height: 100%;
    }
  }
</style>
