---
import Layout from '../layouts/Layout.astro';

// French is the default language
---

<Layout
  title="All Leaders - Conseil en Performance Collective"
  description="All Leaders Initiative accompagne les équipes managériales et dirigeants vers le leadership basé sur l'intention."
  lang="fr"
  alternateUrls={{ fr: '/edit', en: '/en/edit' }}
>
  <main class="min-h-screen bg-white">
    <div class="container py-16">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h1 class="text-4xl text-left! font-bold text-gray-900 mb-4">
            Bienvenue sur All Leaders
          </h1>
          <h2 class="text-xl mt-0! pt-0! text-gray-600">
            Conseil en performance collective pour dirigeants et équipes
          </h2>
          <p class="mt-6 text-gray-600">
            Cliquez sur le lien « Admin » ci-dessus pour accéder à Keystatic et gérer les contenus.
          </p>
        </div>
        <a
          href="/keystatic"
          target="_blank"
          class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
        >
          Admin
        </a>
        <a
          href="/admin/seo"
          target="_blank"
          class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
        >
          SEO checker
        </a>
      </div>
    </div>
  </main>
</Layout>
