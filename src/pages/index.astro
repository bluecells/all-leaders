    /* =========================================================
HALOS
========================================================= */

    @property --x1 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 65%;
    }

    @property --y1 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 85%;
    }

    @property --x2 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 55%;
    }

    @property --y2 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 85%;
    }

    @property --x3 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 35%;
    }

    @property --y3 {
      syntax: '<percentage>';
      inherits: false;
      initial-value: 85%;
    }

    .halos-confines {
      position: absolute;
      inset: 0;

      z-index: 0;

      pointer-events: none;

      overflow: hidden;

      background-color: #fff;

      --silhouette1:
        radial-gradient(
          ellipse 2.8% 4.5% at var(--x1) calc(var(--y1) - 12%),
          rgba(255, 182, 193, 0.65) 0%,
          transparent 100%
        ),
        radial-gradient(
          ellipse 6% 9% at var(--x1) calc(var(--y1) - 2%),
          rgba(255, 182, 193, 0.55) 0%,
          transparent 100%
        ),
        radial-gradient(
          ellipse 8% 16% at var(--x1) calc(var(--y1) + 13%),
          rgba(255, 182, 193, 0.45) 0%,
          transparent 100%
        );

      --silhouette2:
        radial-gradient(
          ellipse 2.6% 4.3% at var(--x2) calc(var(--y2) - 11%),
          rgba(173, 216, 230, 0.65) 0%,
          transparent 100%
        ),
        radial-gradient(
          ellipse 5.8% 8.8% at var(--x2) calc(var(--y2) - 1%),
          rgba(173, 216, 230, 0.55) 0%,
          transparent 100%
        ),
        radial-gradient(
          ellipse 8% 17% at var(--x2) calc(var(--y2) + 14%),
          rgba(173, 216, 230, 0.45) 0%,
          transparent 100%
        );

      --silhouette3:
        radial-gradient(
          ellipse 2.8% 4.5% at var(--x3) calc(var(--y3) - 12%),
          rgba(255, 250, 190, 0.7) 0%,
          transparent 100%
        ),
        radial-gradient(
          ellipse 5.8% 9% at var(--x3) calc(var(--y3) - 2%),
          rgba(255, 250, 190, 0.6) 0%,
          transparent 100%
        ),
        radial-gradient(
          ellipse 8.5% 17% at var(--x3) calc(var(--y3) + 14%),
          rgba(255, 250, 190, 0.5) 0%,
          transparent 100%
        );

      background-image: var(--silhouette1), var(--silhouette2), var(--silhouette3);

      background-repeat: no-repeat;

      filter: blur(15px) saturate(120%) contrast(105%);

      will-change: filter;

      animation: mouvementHalos 12s ease-in-out infinite alternate;
    }

    @keyframes mouvementHalos {
      0% {
        --x1: 35%;
        --y1: 85%;

        --x2: 55%;
        --y2: 85%;

        --x3: 60%;
        --y3: 85%;
      }

      33% {
        --x1: 30%;
        --y1: 75%;

        --x2: 55%;
        --y2: 80%;

        --x3: 60%;
        --y3: 85%;
      }

      66% {
        --x1: 75%;
        --y1: 65%;

        --x2: 85%;
        --y2: 65%;

        --x3: 40%;
        --y3: 80%;
      }

      100% {
        --x1: 65%;
        --y1: 85%;

        --x2: 55%;
        --y2: 85%;

        --x3: 45%;
        --y3: 85%;
      }
    }

