</Layout>

<style>
  /* ==========================================
     HERO SECTION — Animation GSAP
  =========================================== */

  .hero-section {
    position: relative;
    height: calc(100dvh - 140px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .hero-title {
    position: relative;
    text-align: center;
    width: 100%;
    max-width: 900px;
    padding: 0;
    margin: 0;
    z-index: 2;
    font-size: 2rem;
  }

  @media (min-width: 1919px) {
    .hero-title {
      max-width: 1100px;
    }
  }

  .hero-quote-wrapper {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .hero-quote {
    will-change: opacity;
    transition: none !important; /* Désactiver les transitions CSS pour GSAP */
    font-size: clamp(1.5rem, 2vw, 2.5rem);
    font-style: italic;
    font-family: Lexend, sans-serif;
    color: var(--color-brand-secondary) !important;
    text-align: center;
    padding: 3% 0 5% 0;
  }

  .hero-question {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    will-change: opacity;
    padding-bottom: 3rem;
  }

  .question-dash,
  .question-word,
  .question-mark {
    display: inline;
    will-change: transform, opacity;
  }

  .question-word {
    position: relative;
    transform-origin: center top;
    font-weight: 600;
  }

  .texte-gradient {
    /* On définit le dégradé en arrière-plan */
    background: linear-gradient(to bottom, #c65151, #9e8aa8, #172432);

    /* On "découpe" l'arrière-plan pour qu'il ne s'affiche que sur les lettres */
    -webkit-background-clip: text;
    background-clip: text;

    /* On rend le texte transparent pour laisser voir le dégradé dessous */
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  @media (min-width: 768px) {
    .texte-gradient {
      background: linear-gradient(to right, #c65151, #9e8aa8, #172432);

      -webkit-background-clip: text;
      background-clip: text;

      -webkit-text-fill-color: transparent;
      color: transparent;
    }
  }

  /* ==========================================
     PARTENAIRES — Layout Logo (1/4) + Texte (3/4)
  =========================================== */

  .partners-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem auto;
  }

  .partners-list li {
    padding: 1rem 0;
  }

  .partner-article {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    padding: 1.15rem;
    border: 2px solid rgba(74, 103, 65, 0.1);
    border-radius: 0.5rem;
    text-align: center;
  }

  .partner-logo {
    width: 100%;
    max-width: 180px;
    height: auto;
    margin: 0 auto;
  }

  .partner-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }

  .partner-content h1,
  .partner-content h2,
  .partner-content h3 {
    text-align: center;
  }

  /* Mode desktop : grille 4 colonnes (logo 1/4, texte 3/4) */
  @media (min-width: 768px) {
    .partner-article {
      grid-template-columns: 1fr 3fr;
      align-items: start;
      gap: 1rem;
      padding: 1.5rem;
      margin-bottom: 0;
      text-align: left;
    }
    .partners-list li {
      padding: 0.75rem;
    }

    .partner-logo {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
      object-fit: contain;
      margin: 0;
    }

    .partner-content {
      align-items: flex-start;
      justify-content: center;
      height: 100%;
    }

    .partner-content h1,
    .partner-content h2,
    .partner-content h3 {
      text-align: left;
    }

    .partner-article p {
      text-align: left !important;
    }

    .partner-article a {
      text-align: left;
    }
  }

  .partner-article h3 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
  }

  .partner-article p {
    margin: 0.35rem 0;
    font-size: 0.85rem;
    font-family: sans-serif;
    text-align: center;
  }

  .partner-article a {
    display: inline-block;
    margin-top: 0.25rem;
    color: var(--color-brand-accent);
    text-decoration: none;
    transition: color 200ms;
    font-family: sans-serif;
    font-size: 0.85rem;
    text-align: center;
  }

  .partner-article a:hover {
    color: var(--color-brand-accent);
  }

  /* ==========================================
     FONDATEURS — Layout 2 Colonnes
  =========================================== */

  .founders-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
    max-width: 800px;
    margin: auto;
  }

  .founders-grid article {
    padding: 1.5rem 1.5rem 1rem 1.5rem;
    border: 1px solid rgba(74, 103, 65, 0.2);
    border-radius: 0.5rem;
  }

  .founders-grid h1,
