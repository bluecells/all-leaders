---
import Layout from '../layouts/Layout.astro';
import ActionBar from '../components/ActionBar.astro';
---

<Layout
  title="All Leaders - Tourisme Responsable"
  lang="fr"
  metaTitle="All Leaders - Tourisme responsable & Éco-living en Sardaigne"
  metaDescription="Découvrez All Leaders, une maison d'hôtes éco-responsable à Cabras, en Sardaigne. Vivez le tourisme durable et la culture locale authentique."
>
  <div class="mx-auto px-4 py-12">
    <h1 class="font-serif text-4xl mb-4 text-center">Bienvenue chez All Leaders</h1>
    <p class="text-xl text-center mb-8">
      Découvrez le tourisme responsable et l'éco-living en Sardaigne
    </p>
    <p class="text-center mb-8">
      Ceci est une page d'accueil temporaire. Le contenu arrivera bientôt.
    </p>
    <div class="text-center">
      <a href="/blog" class="inline-block px-6 py-3 text-white rounded bg-brand-primary hover:bg-brand-accent transition">
        Explorer notre blog
      </a>
    </div>
  </div>

  <ActionBar />
</Layout>
