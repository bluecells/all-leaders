---
import Layout from '../layouts/Layout.astro';
import Grid from '../components/UI/Grid.astro';
import Carousel from '../components/UI/Carousel.astro';
import ContinuumGrid from '../components/UI/ContinuumGrid.astro';
import ContinuumGridMobile from '../components/UI/ContinuumGridMobile.astro';
import CompassLinks from '../components/UI/CompassLinks.astro';
import BannerReviews from '../components/UI/BannerReviews.astro';
---

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  try {
    gsap.registerPlugin(ScrollTrigger);
  } catch (e) {
    console.error("Problème d'installation avec ScrollTrigger :", e);
  }

  function animateHero() {
    const heroTitle = document.querySelector('.hero-title');
    const heroQuestion = document.querySelector('.hero-question');
    const heroQuoteWrapper = document.querySelector('.hero-quote-wrapper');

    // Animation Hero basique (sans matchMedia pour tester la panne)
    if (heroTitle) {
      gsap.fromTo(heroTitle, { autoAlpha: 0 }, { autoAlpha: 1, duration: 0.6 });
    }

    if (heroQuestion) {
      gsap.fromTo(heroQuestion, { autoAlpha: 0 }, { autoAlpha: 1, duration: 1, delay: 0.6 });
    }

    // Animation ScrollTrigger
    if (heroQuoteWrapper) {
      gsap.fromTo(
        heroQuoteWrapper,
        { autoAlpha: 0, y: 50 },
        {
          autoAlpha: 1,
          y: 0,
          duration: 1.2,
          scrollTrigger: {
            trigger: heroQuoteWrapper,
            start: '20% 85%',
            toggleActions: 'play none none none',
          },
        }
      );
    }
  }

  // Compatible avec ou sans ViewTransitions d'Astro
  document.addEventListener('astro:page-load', animateHero);
  window.addEventListener('DOMContentLoaded', animateHero);
  ScrollTrigger.refresh();
</script>

<Layout
  title="All Leaders Initiative — Leadership basé sur l'intention pour dirigeants et équipes managériales"
  lang="fr"
  metaTitle="All Leaders Initiative — Conseil en Leadership et Performance Collective"
  metaDescription="All Leaders Initiative accompagne les équipes managériales, comités de direction et dirigeants pour dépasser les blocages collectifs et développer un leadership basé sur l'intention."
>
  <div class="mx-auto hero-section">
    <!-- Hero Title - Animé après -->
    <div class="hero-title">
      <h1
        class="mb-0! py-2! text-xl! font-base md:text-3xl! 2xl:text-[60px]! leading-8 md:leading-10 2xl:leading-tight!"
        style="opacity: 0;"
      >
        <q
          >&nbsp;Toutes les équipes performantes se ressemblent.<br />
          Mais chaque équipe dysfonctionnelle l'est à sa façon.&nbsp;</q
        >
      </h1>
      <h2
        class="hero-quote hero-question text-3xl! md:text-4xl! 2xl:text-[60px]! not-italic! mt-6!"
      >
        <span class="question-dash">&mdash; Et </span><span class="question-word"
          >la vôtre&nbsp;?</span
        >
      </h2>
    </div>
  </div>

  <div class="mx-auto pt-10 pb-40">
    <!-- Hero Quote - Centre au début, puis slide vers le bas -->
    <div class="hero-quote-wrapper">
      <p class="mx-auto">
        Vous sentez qu'il serait possible de <strong>mieux collaborer</strong>, de retrouver du <strong
          >sens</strong
        >, de <strong>fluidifier les relations</strong>… mais quelque chose bloque. Des habitudes
        ancrées, des non-dits, un manque de clarté.<br />
      </p>
      <p class="mx-auto py-10 text-2xl!">
        <strong
          >Ces frontières invisibles<br />freinent votre épanouissement<br />et la dynamique
          collective.</strong
        >
      </p>
      <nav aria-label="Navigation principale">
        <a href="/contact" class="mt-4 btn btn-secondary"
          >Il est temps de <strong>les dépasser</strong></a
        >
      </nav>
    </div>
  </div>

  <main>
    <!-- ==========================================
         SECTION 1 — Pourquoi All Leaders Initiative
    =========================================== -->
