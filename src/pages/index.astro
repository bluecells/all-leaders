---
import Layout from '../layouts/Layout.astro';
import Grid from '../components/UI/Grid.astro';
import Carousel from '../components/UI/Carousel.astro';
import ContinuumGrid from '../components/UI/ContinuumGrid.astro';
import CompassLinks from '../components/UI/CompassLinks.astro';
---

<script>
  import gsap from 'gsap';

  function animateHero() {
    const heroTitle = document.querySelector('.hero-title');
    const heroQuoteWrapper = document.querySelector('.hero-quote-wrapper');
    const heroQuestion = document.querySelector('.hero-question'); 
    const questionWord = document.querySelector('.question-word');

    // Sécurité : on s'assure que les éléments existent
    if (!heroTitle || !heroQuoteWrapper) return;

    const tl = gsap.timeline();

    // 1. ÉTAT INITIAL FORCÉ
    // On cache tout et on place le titre au centre exact via yPercent
    tl.set([heroTitle, heroQuoteWrapper, heroQuestion], { 
      autoAlpha: 0 
    });
    tl.set(heroTitle, { 
      top: "50%", 
      yPercent: -50, 
    });
    tl.set(questionWord, { transformOrigin: "left center" });

    // 2. APPARITIONS
    tl.to(heroQuoteWrapper, { 
      autoAlpha: 1, 
      duration: 2.5, 
      ease: 'power2.inOut' 
    })
    .to(heroQuestion, { 
      autoAlpha: 1, 
      duration: 0.8 
    }, ">-0.5") // Commence un peu avant la fin
    .to(questionWord, { 
      rotation: 15, 
      duration: 0.5, 
      x: 8,
      ease: 'back.out(2)' 
    }, "+=1");

    // 3. LE MOUVEMENT FINAL
    // On descend la citation
    tl.to(heroQuoteWrapper, {
      y: "15vh", 
      duration: 1.2,
      ease: 'power3.inOut'
    }, ">");

    // On fait apparaître le titre en le faisant remonter légèrement
    tl.to(heroTitle, {
      autoAlpha: 1,
      yPercent: -120, // Remonte de -50% (centre) à -80% pour libérer de l'espace
      x: 0, // Reste centré horizontalement
      duration: 1,
      ease: 'power2.out'
    }, "-=0.8");
  }

  // Lancement propre
  window.addEventListener('load', animateHero);
</script>

<Layout
  title="All Leaders - Tourisme Responsable"
  lang="fr"
  metaTitle="All Leaders Initiative — Conseil en Leadership et Performance Collective"
  metaDescription="All Leaders Initiative accompagne les équipes managériales, comités de direction et dirigeants pour dépasser les blocages collectifs et développer un leadership basé sur l'intention."
>
  <div class="mx-auto px-4 py-12 hero-section">

    <!-- Hero Title - Animé après -->
    <h1 class="hero-title" style="opacity: 0;">All Leaders Initiative <span style="display: block; font-size: 2.25rem;">Conseil en performance collective pour dirigeants et équipes managériales</span></h1>

    <!-- Hero Quote - Centre au début, puis slide vers le bas -->
    <div class="hero-quote-wrapper">
      <p class="hero-quote pb-0! max-w-5xl mx-auto">
        <q>&nbsp;Toutes les équipes performantes se ressemblent.<br>
        Mais chaque équipe dysfonctionnelle l'est à sa façon.&nbsp;</q>
      </p>

      <p class="hero-quote hero-question text-6xl! not-italic! pt-10!">
        <span class="question-dash">&mdash; Et </span><span class="question-word">la vôtre&nbsp;?</span>
      </p>
    </div>
  </div>

    
<div class="max-w-3xl mx-auto text-center">
    <p>
      Vous sentez qu'il serait possible de <strong>mieux collaborer</strong>, de retrouver du <strong>sens</strong>,
      de <strong>fluidifier les relations</strong>… mais quelque chose bloque.
      Des habitudes ancrées, des non-dits, un manque de clarté.
      <strong>Ces frontières invisibles freinent votre épanouissement et la dynamique collective.</strong>
    </p>

    <p class="hero-cta-text">Il est temps de les <strong>dépasser</strong>.</p>

    <nav aria-label="Navigation principale">
      <a href="/contact" class="btn btn-secondary">Prendre contact</a>
    </nav>
    </div>

  </div>


  <main>

    <!-- ==========================================
         SECTION 1 — Pourquoi All Leaders Initiative
    =========================================== -->
    <section id="notre-approche" aria-labelledby="h2-pourquoi">
      <div class="container">

        <h2 id="h2-pourquoi">
          Dépasser les barrières invisibles de votre équipe
        </h2>

        <p class="text-center">
          Nous avons créé All Leaders Initiative pour vous permettre de questionner ce qui ne fonctionne
          plus, oser de nouvelles façons d'agir et vous affranchir de ces barrières invisibles.
          Pour réussir, ensemble.
        </p>

        <div class="values-section">
          {/* Images latérales en desktop */}
          <div class="values-image-left hidden md:flex">
            <img
              src="/images/pages/marie-emmanuelle-py-acquarelle.webp"
              alt="Marie-Emmanuelle Py"
              class="w-full h-auto object-cover rounded-lg"
            />
          </div>

          <div class="values-grid" role="list">

            <article role="listitem">
              <h3><strong>Nous aimons l'entreprise</strong></h3>
              <p class="text-center">
                Nous y avons grandi et en avons tiré beaucoup de fierté. Nous savons qu'elle doit offrir
                un cadre qui favorise la responsabilité, la solidarité et l'initiative.
              </p>
            </article>

            <article role="listitem">
              <h3><strong>Nous croyons en l'humain</strong></h3>
              <p class="text-center">
                Grâce à la sécurité psychologique et à l'affirmation de son intention, chacun peut
                devenir leader et choisir consciemment d'influencer positivement son environnement.
              </p>
            </article>

            <article role="listitem">
              <h3><strong>Nous voyons l'organisation comme un équipage</strong></h3>
              <p class="text-center">
                Nos parcours de marins, dans la sécurité nucléaire et une grande diversité de cultures
                managériales nous ont appris à voir les organisations comme des équipages&nbsp;: des
                collectifs qui gagnent en cultivant courage, cohésion, alignement et sens.
                C'est dans cet esprit que nous vous accompagnons, avec la discipline des marins
                et l'audace des aventuriers.
              </p>
              <img class="w-24 h-24 mx-auto mt-4" src="/images/pages/logo-all-leaders-rond-fonce.svg" alt="Logo All Leaders Initiative" />
              <p class="text-center mt-4 text-5xl! font-serif">Cap&nbsp;?</p>
              
            </article>
          </div>

          <div class="values-image-right hidden md:flex">
            <img
              src="/images/pages/pierre-etienne-bost-acquarelle.webp"
              alt="Pierre-Etienne Bost"
              class="w-full h-auto object-cover rounded-lg"
            />
          </div>

          {/* Images mobiles - affichées au-dessus en 50-50 */}
          <div class="md:hidden grid grid-cols-2 gap-4 mb-8">
            <img
              src="/images/pages/marie-emmanuelle-py-acquarelle.webp"
              alt="Marie-Emmanuelle Py"
              class="w-full h-auto object-cover rounded-lg"
            />
            <img
              src="/images/pages/pierre-etienne-bost-acquarelle.webp"
              alt="Pierre-Etienne Bost"
              class="w-full h-auto object-cover rounded-lg"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ==========================================
         SECTION 2 — Offre / Continuum
    =========================================== -->
    <section id="offre" aria-labelledby="h2-offre">
      <div class="container">

        <h2 id="h2-offre">
          Conseil en performance collective&nbsp;: du diagnostic à la transformation
        </h2>

        <h3 class="mb-12">
          Nous intervenons sur tout le <strong>continuum de la performance collective</strong>
        </h3>

        <ContinuumGrid />

         <p class="text-center mt-12">
          Nous accompagnons les équipes managériales, comités de direction et dirigeants pour dépasser les
          blocages collectifs et développer un leadership basé sur l'intention. Nous intervenons à tous
          les stades du continuum de la performance collective, du diagnostic à la transformation.

        <Grid textColor="var(--color-text-primary)"
          items={[
            {
              title: 'Bien-être mental fondamental à récréer',
              media: '/images/pages/marque-de-danger-isole.webp',
              description: 'Analyse approfondie de la dynamique d’équipe, identification des blocages et des leviers de performance.',
            },
            {
              title: 'Amplifier les points forts et réguler les vecteurs de vulnérabilité',
              media: '/images/pages/balise-speciale.webp',
              description: 'Ateliers collaboratifs pour définir une feuille de route claire et alignée avec les objectifs stratégiques.',
            },
            {
              title: 'Déployer le leadership à tout niveau (leadership basé sur l’intention)',
              media: '/images/pages/bouee-eaux-saines.webp',
              description: 'Accompagnement personnalisé pour mener à bien les transformations organisationnelles, en soutenant les équipes dans leur évolution.',
            }
          ]}
        />

        <h3>Nous avons accompagné de nombreuses équipes managériales, comités de direction et dirigeants exigeants actifs chez&nbsp;</h3>
        <Carousel speed="5000"
          images={[
            { image: '/images/pages/homeserve.png', alt: 'HomeServe' },
            { image: '/images/pages/edf.png', alt: 'EDF' },
            { image: '/images/pages/vinci.png', alt: 'Vinci Construction' },
            { image: '/images/pages/opinionway.png', alt: 'OpinionWay' },
            { image: '/images/pages/orange.png', alt: 'Orange' },
          ]}
        />  
        <h3 class="text-center! mt-8">
          Transformer les <strong>intentions en actions</strong> concrètes, pour des équipes agissant avec <strong>sens, clarté et impact</strong>.
        </h3>

        <CompassLinks />

        <!-- Placeholder pour les modules/offres détaillées -->
        <div id="offre-modules" aria-label="Nos modules d'intervention">
          <!-- Insérer ici les cards d'offres -->
        </div>

      </div>
    </section>

    <!-- ==========================================
         SECTION 3 — Partenaires & Écosystème
    =========================================== -->
    <section id="ecosysteme" aria-labelledby="h2-ecosysteme">
      <div class="container">

        <h2 id="h2-ecosysteme" class="text-center! mt-8">
          Un écosystème de partenaires experts en leadership et cohésion d'équipe
        </h2>

        <p class="text-center! mt-4">
          Découvrez ceux qui naviguent avec vous et incarnent <strong>le leadership</strong> que nous développons.
        </p>

        <ul class="partners-list" role="list">

          <li>
            <article class="partner-article" role="listitem">
              <img src="/images/pages/logo-bureau-du-reel.webp" alt="Logo du Bureau du Réel" class="partner-logo" />
              <div class="partner-content">
                <h3>Le Bureau du Réel</h3>
                <p>
                  All Leaders Initiative est partie prenante du Bureau du Réel, un réseau d'intervenants
                  pour des formats de conférences disruptifs et centrés sur l'expérience vécue.
                </p>
                <a href="https://www.bureaudureel.fr/" aria-label="En savoir plus sur le Bureau du Réel">Découvrir des conférenciers disruptifs</a>
              </div>
            </article>
          </li>

          <li>
            <article class="partner-article" role="listitem">
              <img src="/images/pages/logo-da-crew.webp" alt="Logo de Da CREW" class="partner-logo" />
              <div class="partner-content">
                <h3>Da CREW — Mission One</h3>
                <p>
                  Simulation en réalité virtuelle&nbsp;: application concrète du Leadership basé sur
                  l'intention, faisant collaborer à « haute intensité » un équipage d'hélicoptère et un
                  équipage de sous-marin. Cette mission révèle les failles de communication et de
                  collaboration, et permet d'expérimenter et d'ancrer de nouveaux comportements ajustés.
                </p>
                <a href="https://da-crew.org" aria-label="En savoir plus sur Da CREW Mission One">De l'équipe à l'équipage : simulation en VR</a>
              </div>
            </article>
          </li>

          <li>
            <article class="partner-article" role="listitem">
              <img src="/images/pages/logo-your-safety-training.webp" alt="Logo de YourSafety.training" class="partner-logo" />
              <div class="partner-content">
                <h3>YourSafety.training — Gestion des conflits</h3>
                <p>
                  Parce qu'on ne peut parler de relations sans parler de conflits, d'agressivité voire
                  de violence, nous avons intégré à notre expertise la gestion professionnelle des conflits avec notre partenariat <b>Jérôme Bouteiller</b>.
                </p>
                <a href="https://yoursafety.training" aria-label="En savoir plus sur YourSafety.training">Restaurer ou préserver la relation en cas de conflit</a>
              </div>
            </article>
          </li>

          <li>
            <article class="partner-article" role="listitem">
              <img src="/images/pages/logo-synergie-et-co.png" alt="Logo de Synergies & Co" class="partner-logo" />
              <div class="partner-content">
                <h3>Synergies &amp; Co — Excellence opérationnelle</h3>
                <p>
                  Parce que la performance dépend de l'adoption des bonnes postures, nous nous associons
                  à l'ancien dirigeant et militaire d'élite <b>Olivier Crosetta</b> et son cabinet Synergies &amp; Co
                  pour décliner l'excellence opérationnelle à tous niveaux.
                </p>
                <a href="https://www.synergiesandco.com/" aria-label="En savoir plus sur Synergies et Co">Du terrain militaire au board : la performance naît des gens.</a>
              </div>
            </article>
          </li>

          <li>
            <article class="partner-article" role="listitem">
              <img src="/images/pages/logo-pragmacie.svg" alt="Logo de Pragmacie" class="partner-logo" />
              <div class="partner-content">
                <h3>Pragmacie — Cartographie des talents CliftonStrengths</h3>
                <p>
                  Parce qu'on ne peut parler de leadership sans alignement profond avec ses talents
                  naturels, nous avons intégré à notre expertise la cartographie des points forts avec
                  notre partenaire Pragmacie, certifié Gallup CliftonStrengths (ex StrengthsFinder).
                </p>
                <a href="https://www.pragmacie.com/" aria-label="En savoir plus sur Pragmacie">Gallup CliftonStrengths, sans le PDF</a>
              </div>
            </article>
          </li>

          <li>
            <article class="partner-article" role="listitem">
              <img src="/images/pages/logo-enablers-network.webp" alt="Logo d'Enablers" class="partner-logo" />
              <div class="partner-content">
                <h3>Enablers — Accompagnement international</h3>
                <p>
                  Pour accompagner vos défis organisationnels les plus complexes et à l'international,
                  nous sommes connectés à une communauté internationale et multiculturelle de
                  professionnels chevronnés.
                </p>
                <a href="https://enablersnetwork.com/" aria-label="En savoir plus sur Enablers">Quand la disruption arrive — et elle arrive — ils sont déjà là.</a>
              </div>
            </article>
          </li>

          <li>
            <article class="partner-article" role="listitem">
              <img src="/images/pages/logo-fa3r.webp" alt="Logo de FA3R" class="partner-logo" />
              <div class="partner-content">
                <h3>FA3R — Expériences outdoor sur mesure</h3>
                <p>
                  Parce que nous voulons proposer des expériences « out-door » sur mesure allant plus
                  loin dans les possibilités scénaristiques et l'engagement de vos équipes, en toute
                  sécurité, nous nous associons avec nos « frères d'armes » FA3R.
                </p>
                <a href="https://www.fa3r.fr/" aria-label="En savoir plus sur FA3R">Apprendre sous stress, décider sous pression, tenir ensemble.</a>
              </div>
            </article>
          </li>

        </ul>

      </div>
    </section>

    

  </main>
</Layout>

<style>
  /* ==========================================
     HERO SECTION — Animation GSAP
  =========================================== */

.hero-section {
  position: relative;
  height: calc(100vh - 5rem);
  display: flex;
  flex-direction: column;
  justify-content: top; /* Centre verticalement par défaut */
  align-items: center;
  overflow: hidden;
}

.hero-title {
  position: relative;
  text-align: center;
  width: 100%;
  max-width: 900px;
  padding: 0 2rem;
  margin: 0;
  z-index: 2;
  margin-bottom: -5rem;
}

.hero-quote-wrapper {
  position: relative;
  z-index: 1;
  text-align: center;
  margin-top: 2rem;
}

  .hero-quote {
    will-change: opacity;
    transition: none !important; /* Désactiver les transitions CSS pour GSAP */
  }

  .hero-question {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    will-change: opacity;
  }

  .question-dash,
  .question-word,
  .question-mark {
    display: inline;
    will-change: transform, opacity;
  }

  .question-word {
    position: relative;
    transform-origin: center top;
  }

  /* ==========================================
     PARTENAIRES — Layout Logo (1/4) + Texte (3/4)
  =========================================== */

  .partners-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0;
  }

  .partner-article {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid rgba(74, 103, 65, 0.2);
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .partner-logo {
    width: 100%;
    max-width: 200px;
    height: auto;
  }

  .partner-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .partner-content h1,
  .partner-content h2,
  .partner-content h3 {
    text-align: left;
  }

  /* Mode desktop : grille 4 colonnes (logo 1/4, texte 3/4) */
  @media (min-width: 768px) {
    .partner-article {
      grid-template-columns: 1fr 3fr;
      align-items: start;
      gap: 2rem;
      padding: 2rem;
      margin-bottom: 0;
    }

    .partner-logo {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
      object-fit: contain;
    }
  }

  .partner-article h3 {
    margin: 0 0 0.5rem 0;
  }

  .partner-article p {
    margin: 0.5rem 0;
  }

  .partner-article a {
    display: inline-block;
    margin-top: 0.5rem;
    color: var(--color-brand-primary);
    text-decoration: none;
    font-weight: 600;
    transition: color 200ms;
  }

  .partner-article a:hover {
    color: var(--color-brand-accent);
  }

  /* ==========================================
     FONDATEURS — Layout 2 Colonnes
  =========================================== */

  .founders-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
    max-width: 800px;
    margin: auto;
  }

  .founders-grid article {
    padding: 1.5rem 1.5rem 1rem 1.5rem;
    border: 1px solid rgba(74, 103, 65, 0.2);
    border-radius: 0.5rem;
  }

  .founders-grid h1,
  .founders-grid h2,
  .founders-grid h3 {
    text-align: left;
  }

  .founders-grid h3 {
    margin: 0 0 0.5rem 0;
  }

  .founders-grid p {
    margin: 0 0 1rem 0;
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contact-list h1,
  .contact-list h2,
  .contact-list h3 {
    text-align: left;
  }

  .contact-list li {
    margin-bottom: 0.35rem;
    margin-left: -1rem;
  }

  .contact-list a {
    color: var(--color-brand-primary);
    text-decoration: none;
    transition: color 200ms;
  }

  .contact-list a:hover {
    color: var(--color-brand-accent);
  }

  /* Mode desktop : 2 colonnes */
  @media (min-width: 768px) {
    .founders-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  /* Values section avec images latérales */
  .values-section {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    margin-top: 3rem;
  }

  .values-image-left,
  .values-image-right {
    flex: 0 0 20%;
    max-height: 500px;
  }

  .values-image-left img,
  .values-image-right img {
    height: 100%;
  }

  .values-grid {
    flex: 1;
  }

  /* Mobile : images au-dessus en 50-50 */
  @media (max-width: 767px) {
    .values-section {
      flex-direction: column;
      gap: 1.5rem;
    }

    .values-image-left,
    .values-image-right {
      flex: 0 0 auto;
      max-height: 100%;
    }
  }
</style>
