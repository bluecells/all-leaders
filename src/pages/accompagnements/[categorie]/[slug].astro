---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import LayoutAccompagnements from '../../../layouts/LayoutAccompagnements.astro';

export const prerender = true;

export const getStaticPaths = (async () => {
  const accompagnements = await getCollection('accompagnements');
  const categories = await getCollection('accompagnements-categories');

  return accompagnements.map((accompagnement) => {
    // Trouver la catégorie correspondante
    const category = categories.find(
      (cat) =>
        cat.data.name_fr === accompagnement.data.categorie ||
        cat.data.name_en === accompagnement.data.categorie
    );

    // Utiliser le slug de la catégorie selon la langue de l'accompagnement
    const lang = accompagnement.data.lang;
    const categorieSlug = lang === 'fr' ? category?.data.slug_fr : category?.data.slug_en;

    // Utiliser le slug approprié selon la langue
    const slug = lang === 'fr' ? accompagnement.data.slug_fr : accompagnement.data.slug_en;

    return {
      params: {
        categorie: categorieSlug || accompagnement.data.categorie.toLowerCase().replace(/\s+/g, '-'),
        slug: slug,
      },
      props: {
        accompagnementId: accompagnement.id,
        categoryId: category?.id,
      },
    };
  });
}) satisfies GetStaticPaths;

// Récupérer les données côté page
const { accompagnementId, categoryId } = Astro.props;
const accompagnements = await getCollection('accompagnements');
const categories = await getCollection('accompagnements-categories');

const accompagnement = accompagnements.find((a) => a.id === accompagnementId);
const category = categories.find((c) => c.id === categoryId);

if (!accompagnement) {
  return Astro.redirect('/accompagnements');
}

---

<LayoutAccompagnements
  accompagnement={accompagnement}
  category={category}
/>
