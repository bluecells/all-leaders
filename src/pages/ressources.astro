---
import { getCollection } from 'astro:content';
import { RESOURCES } from '../consts';
import Layout from '../layouts/Layout.astro';
import BlogSection from '../components/Blog.astro';

// Récupérer articles FR pour JSON-LD
const allArticles = await getCollection('articles', ({ data }) => data.lang === 'fr');
const recentArticles = allArticles
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 10);
---

<Layout
  title={RESOURCES.TITLE}
  metaTitle={RESOURCES.METATITLE}
  metaDescription={RESOURCES.METADESCRIPTION}
  lang="fr"
  jsonType="blogCollection"
  blogPosts={recentArticles}
  alternateUrls={{ fr: '/ressources', en: '/en/resources' }}
>
  <div class="mx-auto px-4 py-12">
    <h1 class="text-limolo-green mb-8 text-center">Ressources</h1>
    <h2>
      Nos articles et ressources de <span class="brand-text">
        ALL <span class="leaders">LE<span class="stylized-a">A</span>DERS</span>
        <span class="thin">INITIATIVE</span>
      </span>
    </h2>
    <!-- Blog Component -->
    <BlogSection lang="fr" fullBleed={true} />
  </div>
</Layout>

<style>
  h1 {
    margin-bottom: 0;
    padding-bottom: 1rem;
  }
  h2 {
    margin: 0 !important;
    padding: 0 0 1rem !important;
    max-width: 100%;
    text-align: center;
    font-size: large;
  }
  h2 .brand-text .stylized-a {
    height: 0.78em;
    vertical-align: -0.215em;
  }
</style>
