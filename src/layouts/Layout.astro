---
import '../styles/global.css';
import '../styles/animations.css';
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SeoAnalyzer from '../components/SeoAnalyzer/SeoAnalyzer.astro';
import NewsletterPopup from '@/components/NewsletterPopup.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import GoogleConsentMode from '@/components/GoogleConsentMode.astro';
import GoogleTagManager from '@/components/GoogleTagManager.astro';
import AhrefsAnalytics from '@/components/AhrefsAnalytics.astro';
import { getFaqQuestions } from '@/utils/faq';
import type { AlternateUrls } from '@/utils/hreflang';
import type { JsonLdType } from '@/types/jsonLd';
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  h1Title?: string;
  lang?: 'it' | 'fr' | 'en';
  seoSlug?: string;
  metaTitle?: string | undefined;
  metaDescription?: string | undefined;
  description?: string | undefined;
  ogImage?: string | undefined;
  ogType?: 'website' | 'article';
  jsonType?: JsonLdType;
  keyword?: string;
  publishDate?: Date;
  roomData?: {
    capacity?: number;
    amenities?: string[];
  };
  serviceData?: {
    serviceType?: string;
    areaServed?: string;
  };
  blogPosts?: Array<CollectionEntry<'articles'>>;
  alternateUrls?: AlternateUrls | null;
  isHomepage?: boolean;
  breadcrumbCategory?: string;
}

const {
  title,
  h1Title,
  lang = 'fr',
  seoSlug,
  metaTitle,
  metaDescription,
  description,
  ogImage,
  ogType = 'website',
  jsonType,
  keyword,
  publishDate,
  roomData,
  serviceData = {},
  blogPosts,
  alternateUrls,
  isHomepage = false,
  breadcrumbCategory,
} = Astro.props as Props;

const finalMetaDescription = metaDescription || description || '';
const finalMetaTitle = metaTitle ?? title;

const pageLang = lang;
const finalJsonType = jsonType ?? null;

let faqQuestions: Array<{ question: string; answer: string }> = [];

if (finalJsonType === 'faq') {
  faqQuestions = await getFaqQuestions({
    lang: pageLang,
  });
}

const finalOgImage = ogImage || undefined;
---

<!doctype html>
<html lang={pageLang}>
  <Head
    title={title}
    metaTitle={finalMetaTitle}
    metaDescription={finalMetaDescription}
    ogImage={finalOgImage}
    ogType={ogType}
    lang={pageLang}
    jsonType={finalJsonType}
    faqQuestions={faqQuestions}
    publishDate={publishDate}
    roomData={roomData}
    serviceData={serviceData}
    blogPosts={blogPosts}
    alternateUrls={alternateUrls}
  />

  <!-- Critical CSS for above-the-fold rendering -->
  <style is:inline>
    /* Critical rendering path styles */
    body {
      margin: 0;
      padding: 0;
      font-family: 'Open Sans', sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    html {
      height: auto;
    }

    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    main {
      width: 100%;
      flex: 1;
    }

    .header-main {
      width: 100%;
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(20px);
      background-color: rgba(192, 192, 192, 0.1);
      border-radius: 0 0 16px 16px;
    }

    .header-container {
      max-width: 78rem;
      margin: 0 auto;
      padding: 0.5rem;
    }

    .header-content {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 3.5rem;
      position: relative;
      background-color: rgba(255, 255, 255, 0.778);
      border-bottom: 1px solid rgba(74, 103, 65, 0.1);
      border-radius: 10px;
      padding: 0.5rem 1rem;
    }

    .logo-container {
      flex-shrink: 0;
    }

    .logo-img {
      display: block;
      width: 200px;
      height: auto;
    }

    @media (min-width: 1025px) {
      .logo-img {
        width: 12vw;
        height: auto;
      }
    }
  </style>

  <Header lang={pageLang} />
  <body>
    <main>
      <Breadcrumb lang={pageLang as 'fr' | 'en'} title={title} category={breadcrumbCategory} />
      <slot />
    </main>
    <Footer lang={pageLang} />
    <SeoAnalyzer keyword={keyword} />
    <CookieConsent lang={pageLang} />
    <!-- <GoogleConsentMode />
    <GoogleTagManager /> -->
    <AhrefsAnalytics />
    {isHomepage && <NewsletterPopup lang={pageLang} />}

    <script>
      // Only load animations if cards/elements exist to avoid waste
      const hasAnimatableElements = document.querySelector('.article-card, .service-card');

      if (hasAnimatableElements) {
        // Import dynamiquement les animations
        import('@/utils/animations').then(
          ({ initPageAnimations, animateOnScroll, animateCardHover }) => {
            // Déclencher après que le navigateur soit inactif (requestIdleCallback)
            if ('requestIdleCallback' in window) {
              requestIdleCallback(() => {
                initPageAnimations();
                animateOnScroll('.article-card');
                animateOnScroll('.service-card');
                animateCardHover('.article-card');
                animateCardHover('.service-card');
              });
            } else {
              // Fallback: setTimeout pour les navigateurs sans requestIdleCallback
              setTimeout(() => {
                initPageAnimations();
                animateOnScroll('.article-card');
                animateOnScroll('.service-card');
                animateCardHover('.article-card');
                animateCardHover('.service-card');
              }, 500);
            }
          }
        );
      }
    </script>
  </body>
</html>
