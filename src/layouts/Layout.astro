---
import '../styles/global.css';
import '../styles/animations.css';
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SeoAnalyzer from '../components/SeoAnalyzer/SeoAnalyzer.astro';
import NewsletterPopup from '@/components/NewsletterPopup.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import { getFaqQuestions } from '@/utils/faq';
import type { AlternateUrls } from '@/utils/hreflang';

type JsonLdType = 'page' | 'blog' | 'event' | 'faq' | 'blogCollection' | 'hotelRoom' | null;

interface Props {
  title: string;
  lang?: 'it' | 'fr' | 'en';
  seoSlug?: string;
  metaTitle?: string | undefined;
  metaDescription?: string | undefined;
  description?: string | undefined;
  ogImage?: string | undefined;
  ogType?: 'website' | 'article';
  jsonType?: JsonLdType;
  keyword?: string;
  publishDate?: Date;
  roomData?: {
    capacity?: number;
    amenities?: string[];
  };
  alternateUrls?: AlternateUrls | null;
  isHomepage?: boolean;
  breadcrumbCategory?: string;
}

const {
  title,
  lang = 'fr',
  seoSlug,
  metaTitle,
  metaDescription,
  description,
  ogImage,
  ogType = 'website',
  jsonType,
  keyword,
  publishDate,
  roomData,
  alternateUrls,
  isHomepage = false,
  breadcrumbCategory,
} = Astro.props as Props;

const finalMetaDescription = metaDescription || description || '';
const finalMetaTitle = metaTitle ?? title;

const pageLang = lang;
const finalJsonType = jsonType ?? null;

let faqQuestions: Array<{ question: string; answer: string }> = [];

if (finalJsonType === 'faq') {
  faqQuestions = await getFaqQuestions({
    lang: pageLang,
  });
}

const finalOgImage = ogImage || undefined;
---

<!doctype html>
<html lang={pageLang}>
  <Head
    title={title}
    metaTitle={finalMetaTitle}
    metaDescription={finalMetaDescription}
    ogImage={finalOgImage}
    ogType={ogType}
    lang={pageLang}
    jsonType={finalJsonType}
    faqQuestions={faqQuestions}
    publishDate={publishDate}
    roomData={roomData}
    alternateUrls={alternateUrls}
  />

  <Header lang={pageLang} />
  <body>
    <main>
      <Breadcrumb lang={pageLang as 'fr' | 'en'} title={title} category={breadcrumbCategory} />
      <slot />
    </main>
    <Footer lang={pageLang} />
    <SeoAnalyzer keyword={keyword} />
    <CookieConsent lang={pageLang} />
    {isHomepage && <NewsletterPopup lang={pageLang} />}

    <script>
      import { initPageAnimations, animateOnScroll, animateCardHover } from '@/utils/animations';

      // Initialiser les animations au chargement
      document.addEventListener('DOMContentLoaded', () => {
        // Animation de fade-in au chargement
        initPageAnimations();

        // Animation des articles au scroll
        animateOnScroll('.article-card');

        // Animation des services au scroll
        animateOnScroll('.service-card');

        // Animation hover des cartes
        animateCardHover('.article-card');
        animateCardHover('.service-card');

        // Observer les mutations pour les nouveaux éléments
        const observer = new MutationObserver(() => {
          animateCardHover('.article-card');
          animateCardHover('.service-card');
        });

        observer.observe(document.body, {
          childList: true,
          subtree: true,
        });
      });
    </script>
  </body>
</html>
